---
interface Props {
  title?: string;
  subtitle?: string;
  price: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
  lang?: 'en' | 'es';
}

const { title, subtitle, price, features, ctaText, ctaHref, lang = 'en' } = Astro.props;
const isEs = lang === 'es';
---

<section class="section-dark section-padding">
  <div class="container-content flex justify-center">
    <div id="pricing" class="w-full max-w-2xl rounded-2xl overflow-hidden pricing-reveal" style="scroll-margin-top: 2rem;">
      <!-- Card with gradient -->
      <div class="pricing-card relative bg-gradient-to-br from-dark-card via-accent-red-dark/20 to-dark-card p-6 md:p-14 text-center border border-white/10 rounded-2xl">
        <!-- Subtle glow -->
        <div class="pricing-glow absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-accent-red/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          {title && <h2 class="text-heading mb-2">{title}</h2>}
          {subtitle && <p class="text-white/60 text-lg mb-10 max-w-md mx-auto leading-relaxed" set:html={subtitle} />}

          <!-- Feature list -->
          <ul class="pricing-features space-y-3 mb-10 text-left max-w-sm mx-auto">
            {features.map((feature, i) => (
              <li class="pricing-feature flex items-start gap-3 text-white/80" style={`--delay: ${i * 0.08}s`}>
                <span class="text-accent-red mt-0.5">•</span>
                <span set:html={feature} />
              </li>
            ))}
          </ul>

          <!-- Price -->
          <p class="pricing-price text-5xl md:text-7xl font-extrabold text-white mb-8">{price}</p>

          <!-- CTA -->
          <a href={ctaHref} class="pricing-cta">
            <span>{ctaText}</span>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          {isEs && (
            <p class="pricing-disclaimer" role="note">
              <svg viewBox="0 0 20 20" width="13" height="13" fill="none" aria-hidden="true">
                <path d="M10 2.5 L18 17 L2 17 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                <path d="M10 8.5v3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                <circle cx="10" cy="14.4" r="0.85" fill="currentColor"/>
              </svg>
              <span>Los video-materiales están en Inglés, subtitulados en Español.</span>
            </p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-reveal {
    opacity: 0;
    transform: scale(0.92) translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pricing-reveal.is-visible {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  .pricing-glow {
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 1.2s ease 0.3s, transform 1.2s ease 0.3s;
  }

  .pricing-reveal.is-visible .pricing-glow {
    opacity: 1;
    transform: scale(1);
  }

  .pricing-feature {
    opacity: 0;
    transform: translateX(-20px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    transition-delay: var(--delay);
  }

  .pricing-reveal.is-visible .pricing-feature {
    opacity: 1;
    transform: translateX(0);
  }

  .pricing-price {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.5s ease 0.6s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.6s;
  }

  .pricing-reveal.is-visible .pricing-price {
    opacity: 1;
    transform: scale(1);
  }

  .pricing-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: 100%;
    max-width: 28rem;
    margin: 0 auto;
    padding: 22px 44px;
    border-radius: 14px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 1.125rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow:
      0 10px 30px rgba(221, 51, 51, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease 0.8s,
      transform 0.5s ease 0.8s,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }
  @media (min-width: 768px) {
    .pricing-cta {
      padding: 26px 52px;
      font-size: 1.25rem;
    }
  }
  .pricing-cta:hover,
  .pricing-cta:focus-visible {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    box-shadow:
      0 16px 50px rgba(221, 51, 51, 0.55),
      inset 0 0 0 1px rgba(255, 255, 255, 0.10);
    transform: translateY(-2px);
    outline: none;
  }
  .pricing-cta:active { transform: translateY(0); }

  .pricing-reveal.is-visible .pricing-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .pricing-reveal.is-visible .pricing-cta:hover,
  .pricing-reveal.is-visible .pricing-cta:focus-visible {
    transform: translateY(-2px);
  }

  .pricing-disclaimer {
    display: inline-flex;
    align-items: flex-start;
    gap: 8px;
    margin: 28px auto 0;
    font-size: 0.72rem;
    font-style: italic;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.55);
    text-align: left;
    opacity: 0;
    transition: opacity 0.5s ease 1s;
  }
  .pricing-reveal.is-visible .pricing-disclaimer {
    opacity: 1;
  }
  .pricing-disclaimer svg {
    color: rgba(221, 51, 51, 0.72);
    flex-shrink: 0;
    margin-top: 3px;
  }
  .pricing-disclaimer span {
    white-space: nowrap;
  }
  @media (max-width: 560px) {
    .pricing-disclaimer span { white-space: normal; }
  }

  /* Subtle pulse on the glow after reveal */
  @keyframes glow-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }

  .pricing-reveal.is-visible .pricing-glow {
    animation: glow-pulse 4s ease-in-out 1.5s infinite;
  }
</style>

<script>
  const pricingEl = document.querySelector('.pricing-reveal');
  if (pricingEl) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          pricingEl.classList.add('is-visible');
          observer.unobserve(pricingEl);
        }
      });
    }, { threshold: 0.2 });
    observer.observe(pricingEl);
  }

  document.querySelectorAll('.pricing-cta').forEach((el) => {
    el.addEventListener('click', () => {
      if (window.zaraz && localStorage.getItem('slatin_cookie_consent') === 'accepted') zaraz.track('InitiateCheckout');
    });
  });
</script>
