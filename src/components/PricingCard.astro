---
interface Props {
  title?: string;
  subtitle?: string;
  price: string;
  features: string[];
  ctaText: string;
  ctaHref: string;
}

const { title, subtitle, price, features, ctaText, ctaHref } = Astro.props;
---

<section class="section-dark section-padding" id="pricing">
  <div class="container-content flex justify-center">
    <div class="w-full max-w-2xl rounded-2xl overflow-hidden reveal">
      <!-- Card with gradient -->
      <div class="relative bg-gradient-to-br from-dark-card via-accent-red-dark/20 to-dark-card p-10 md:p-14 text-center border border-white/10">
        <!-- Subtle glow -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-accent-red/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="relative z-10">
          {title && <h2 class="text-heading mb-2">{title}</h2>}
          {subtitle && <p class="text-white/60 text-base mb-8 max-w-md mx-auto">{subtitle}</p>}

          <!-- Feature list -->
          <ul class="space-y-3 mb-10 text-left max-w-sm mx-auto">
            {features.map((feature) => (
              <li class="flex items-start gap-3 text-white/80">
                <span class="text-accent-red mt-0.5">•</span>
                {feature}
              </li>
            ))}
          </ul>

          <!-- Price -->
          <p class="text-6xl md:text-7xl font-extrabold text-white mb-8">{price}</p>

          <!-- CTA -->
          <a
            href={ctaHref}
            class="btn-primary text-xl px-12 py-5 w-full max-w-md block mx-auto"
          >
            {ctaText}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
