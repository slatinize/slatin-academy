<!-- Overlay -->
<div
  id="cookie-overlay"
  style="display:none; position:fixed; inset:0; z-index:9998; background:rgba(0,0,0,0.75); backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px);"
></div>

<!-- Modal -->
<div
  id="cookie-banner"
  style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); z-index:9999; background:#111; border:1px solid #2a2a2a; border-radius:16px; padding:2.5rem 2rem; width:min(480px,90vw); text-align:center; box-shadow:0 24px 64px rgba(0,0,0,0.6);"
>
  <p style="color:#fff; font-size:1.125rem; font-weight:700; margin:0 0 0.75rem; font-family:inherit; letter-spacing:-0.01em;">
    Before you continue
  </p>
  <p style="color:#aaa; font-size:0.875rem; margin:0 0 2rem; line-height:1.6;">
    We use cookies and similar technologies to improve your experience on this site.
  </p>
  <div style="display:flex; flex-direction:column; gap:0.75rem;">
    <button
      id="cookie-accept"
      style="display:block; width:100%; background:#DD3333; color:#fff; font-weight:700; font-size:0.9375rem; padding:0.875rem 1.5rem; border:2px solid #DD3333; border-radius:8px; cursor:pointer; font-family:inherit; letter-spacing:0.01em;"
    >
      Accept &amp; Continue
    </button>
    <button
      id="cookie-decline"
      style="display:block; width:100%; background:none; color:#aaa; font-weight:600; font-size:0.9375rem; padding:0.875rem 1.5rem; border:2px solid #2a2a2a; border-radius:8px; cursor:pointer; font-family:inherit; letter-spacing:0.01em;"
    >
      No thanks
    </button>
  </div>
</div>

<script>
  (function () {
    var CONSENT_KEY = 'slatin_cookie_consent';
    var stored = localStorage.getItem(CONSENT_KEY);

    function loadPixel() {
      if (typeof window.__initPixel === 'function') window.__initPixel();
    }

    if (stored === 'accepted') {
      loadPixel();
      return;
    }
    if (stored === 'declined') {
      return;
    }

    var banner = document.getElementById('cookie-banner');
    var overlay = document.getElementById('cookie-overlay');
    if (banner) banner.style.display = 'block';
    if (overlay) overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';

    function dismiss() {
      if (banner) banner.style.display = 'none';
      if (overlay) overlay.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.getElementById('cookie-accept')?.addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'accepted');
      dismiss();
      loadPixel();
    });

    document.getElementById('cookie-decline')?.addEventListener('click', function () {
      localStorage.setItem(CONSENT_KEY, 'declined');
      dismiss();
    });
  })();
</script>
