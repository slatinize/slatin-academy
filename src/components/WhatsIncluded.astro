---
interface ChangeCard {
  icon: string;
  image?: string;
  beforeAfter: { before: string; after: string };
  title: string;
  description: string;
  valueTag: string;
}

interface ExtraItem {
  highlight: string;
  text: string;
}

interface Props {
  sectionTitle: string;
  sectionSubtitle: string;
  cards: ChangeCard[];
  extrasTitle: string;
  extras: ExtraItem[];
  lang?: 'en' | 'es';
}

const { sectionTitle, sectionSubtitle, cards, extrasTitle, extras, lang = 'en' } = Astro.props;
const fromLabel = lang === 'es' ? 'De' : 'From';
const toLabel = lang === 'es' ? 'a' : 'to';

// Inline icon library
const icons: Record<string, string> = {
  fix: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/></svg>',
  guide: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  star: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
  money: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
};
---

<section class="wi-section section-dark">
  <div class="wi-container">
    <div class="reveal text-center">
      <h2 class="wi-title" set:html={sectionTitle} />
      <p class="wi-subtitle">{sectionSubtitle}</p>
    </div>

    <!-- Transformation cards -->
    <div class="wi-grid reveal">
      {cards.map((card) => (
        <div class="wi-card">
          {card.image && (
            <div class="wi-image-wrap">
              <img src={card.image} alt={card.title} loading="lazy" />
            </div>
          )}
          <h3 class="wi-card-title" set:html={card.title} />
          <p class="wi-card-desc" set:html={card.description} />
          <div class="wi-value-tag">
            <span class="dot"></span>
            <span set:html={card.valueTag} />
          </div>
        </div>
      ))}
    </div>

    <slot name="between" />

    <!-- Extras vault -->
    <div class="wi-extras reveal">
      <div class="wi-extras-header">
        <div class="wi-plus">+++</div>
        <div class="wi-extras-title">{extrasTitle}</div>
      </div>
      <div class="wi-extras-grid">
        {extras.map((extra) => (
          <div class="wi-extra-row">
            <div class="wi-check">✓</div>
            <div class="wi-extra-text"><strong set:html={extra.highlight + ':'} /> <span set:html={extra.text} /></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .wi-section {
    padding: 36px 6% 60px;
  }

  .wi-container {
    max-width: 1300px;
    margin: 0 auto;
  }

  .wi-title {
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 28px;
  }

  .wi-subtitle {
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    color: rgba(255,255,255,0.5);
    margin: 0 auto 56px;
    max-width: 580px;
    line-height: 1.6;
  }

  /* ── Cards ── */
  .wi-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin-bottom: 60px;
  }

  @media (min-width: 768px) {
    .wi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .wi-card {
    background: linear-gradient(145deg, rgba(20, 0, 0, 0.4) 0%, rgba(10, 10, 10, 0.6) 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 32px;
    position: relative;
    transition: all 0.3s ease;
  }

  .wi-card:hover {
    border-color: rgba(221, 51, 51, 0.25);
    transform: translateY(-3px);
  }

  .wi-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 24px;
    background: rgba(0, 0, 0, 0.4);
  }

  .wi-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wi-before-after {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 14px;
  }

  .wi-before-after .ba-bad {
    color: rgba(255, 255, 255, 0.55);
  }

  .wi-before-after .ba-good {
    color: #ed8e00;
  }

  .wi-card-title {
    font-size: clamp(1.2rem, 1.6vw, 1.4rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .wi-card-desc {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .wi-value-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(237, 142, 0, 0.08);
    border: 1px solid rgba(237, 142, 0, 0.25);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #ed8e00;
  }

  .wi-value-tag .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ed8e00;
    box-shadow: 0 0 8px rgba(237, 142, 0, 0.6);
  }

  /* ── Extras ── */
  .wi-extras {
    background: linear-gradient(145deg, rgba(20, 0, 0, 0.3) 0%, rgba(10, 10, 10, 0.5) 100%);
    border-radius: 24px;
    padding: 32px 24px;
  }

  @media (min-width: 768px) {
    .wi-extras {
      padding: 48px;
    }
  }

  .wi-extras-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .wi-plus {
    font-size: 2.4rem;
    font-weight: 800;
    line-height: 1;
    margin-top: calc(-0.22em - 1px);
    background: linear-gradient(90deg, #ed8e00, #dd3333);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .wi-extras-title {
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    font-weight: 700;
  }

  .wi-extras-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  @media (min-width: 768px) {
    .wi-extras-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .wi-extra-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    transition: all 0.25s;
  }

  .wi-extra-row:hover {
    background: rgba(221, 51, 51, 0.04);
    border-color: rgba(221, 51, 51, 0.15);
  }

  .wi-check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(221, 51, 51, 0.15);
    border: 1px solid rgba(221, 51, 51, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #DD3333;
    font-size: 0.7rem;
    font-weight: 700;
    margin-top: 2px;
  }

  .wi-extra-text {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.55;
  }

  .wi-extra-text strong {
    color: #fff;
    font-weight: 700;
  }
</style>
