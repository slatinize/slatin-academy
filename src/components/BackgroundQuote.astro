---
interface Props {
  backgroundImage: string;
  quote: string;
}

const { backgroundImage, quote } = Astro.props;
---

<section class="bg-quote-section relative overflow-hidden" style={`background-image: url('${backgroundImage}')`}>
  <div class="bg-quote-overlay"></div>
  <div class="relative z-10 max-w-4xl mx-auto px-6 py-10 md:py-16 text-center reveal">
    <p class="bg-quote-text" set:html={quote} />
  </div>
</section>

<style>
  .bg-quote-section {
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height: 28vh;
    margin-top: 24px;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bg-quote-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, #020202 0%, rgba(2, 2, 2, 0.6) 30%, rgba(2, 2, 2, 0.3) 60%, rgba(2, 2, 2, 0.7) 100%);
    z-index: 1;
  }

  .bg-quote-text {
    font-size: clamp(1rem, 1.6vw, 1.6rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.92);
    font-family: inherit;
  }
</style>
