---
interface Props {
  googleUrl?: string;
  lang?: 'en' | 'es';
}
const { googleUrl = 'https://share.google/s1OerdqIhmgp05KOr', lang = 'en' } = Astro.props;
const isEs = lang === 'es';

const translateDate = (d: string) => {
  if (!isEs) return d;
  return d
    .replace(/(\d+)\s+months?\s+ago/i, (_, n) => `hace ${n} ${Number(n) === 1 ? 'mes' : 'meses'}`)
    .replace(/(\d+)\s+years?\s+ago/i, (_, n) => `hace ${n} ${Number(n) === 1 ? 'año' : 'años'}`)
    .replace(/(\d+)\s+weeks?\s+ago/i, (_, n) => `hace ${n} ${Number(n) === 1 ? 'semana' : 'semanas'}`)
    .replace(/(\d+)\s+days?\s+ago/i, (_, n) => `hace ${n} ${Number(n) === 1 ? 'día' : 'días'}`);
};

type Review = { name: string; role: string; roleEs?: string; avatar: string; hasBadge?: boolean; date: string; quote: string; quoteEs?: string };

const reviews: Review[] = [
  { name: 'James Symington',              role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/alumni-marco-b.jpg',  date: '8 months ago',  quote: "By far the most enjoyable and effective audio mentoring out there. Slatin is an amazing educator who actually knows how to teach, every session leaves you with something you can use tomorrow", quoteEs: "Sin duda la mentoría de audio más disfrutable y efectiva que hay. Slatin es un educador increíble que realmente sabe enseñar, cada sesión te deja algo que puedes aplicar al día siguiente" },
  { name: 'dani',                         role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/avatar-nicolas.jpg',  date: '7 months ago',  quote: "You can tell right away he is a true professional who totally masters his field. The best mentor I've had, no fluff, just real, actionable guidance on every call", quoteEs: "Se nota desde el primer momento que es un verdadero profesional que domina totalmente su campo. El mejor mentor que he tenido, sin paja, solo guía real y aplicable en cada llamada" },
  { name: 'Luis J. Montoro',              role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-luis-montoro.jpg', hasBadge: true, date: '2 months ago',  quote: "Slatin is a genius. Not only is he technically flawless, he also has the musical sensitivity to know exactly what an artist wants to express and bring it to life. On top of that, he's an amazing mentor! Human and professional quality that's hard to find", quoteEs: "Slatin es un genio. No solo es impecable técnicamente, sino que también tiene la sensibilidad musical necesaria para saber qué es lo que quiere transmitir un artista y conseguirlo. ¡Además, es un mentor brutal! Calidad humana y profesional difícil de encontrar" },
  { name: 'Juan Viera Lopez',             role: 'Professional Musician', roleEs: 'Músico Profesional',     avatar: '/images/mentoring/review-juan-viera.jpg',     date: '7 months ago',  quote: "An experience on par with the very best! I'm a professional musician and I just finished their mix/master course, it's incredible. The amount of knowledge and the way they explain things… it was amazing! The customer care and personal treatment also make you feel great. Without a doubt, now I understand why they're number 1 in Spain", quoteEs: "¡Una experiencia a la altura de los mejores! Soy músico profesional y acabo de terminar su curso de <em>mix/master</em> y es increíble. La cantidad de conocimientos y forma de explicar… ¡fue genial! Así como la atención al cliente y el trato personalizado… Te hacen sentir muy bien. Sin duda alguna ahora entiendo por qué son los números 1 en España" },
  { name: 'Alex Granero',                 role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-alex-granero.jpg', date: '9 months ago',  quote: "Some of the best work I've ever seen. Besides having a top-notch team that looks after every detail, Slatin has an exceptional sensibility and ear. He always takes my sound to the next level, understanding exactly what I'm going for and adding a final touch that makes everything sound bigger, more defined and full of personality. If you're looking for someone who treats your music as if it were their own, I can't recommend him enough. A privilege to work with him!", quoteEs: "De lo mejor que he visto. Aparte de tener un equipo de 10 cuidando cada detalle, Slatin tiene una sensibilidad y un oído excepcionales. Siempre consigue llevar mi sonido al siguiente nivel entendiendo perfectamente lo que busco y aportando un toque final que hace que todo suene más grande, más definido y con mucha personalidad. Si buscas a alguien que cuide tu música como si fuera suya, no puedo recomendarlo lo suficiente. ¡Un lujo poder contar con él!" },
  { name: 'Eurofighterzz',               role: 'Engineer',              roleEs: 'Ingeniero',              avatar: '/images/mentoring/review-eurofighterzz.jpg',  date: '9 months ago',  quote: "One of the best mastering engineers in Spain, if not the best. On top of that, an excellent teacher if what you want is to learn about mix and mastering, or about the business side itself. Personally, he has taught and inspired me a lot over the past few years. If you ask me? Slatin and his team are the 🐐", quoteEs: "Uno de los mejores ingenieros de <em>mastering</em> de España, si no el mejor. Además, un excelente formador si lo que te interesa es aprender sobre <em>mix</em> y <em>mastering</em>, o sobre el negocio en sí. A mí personalmente me ha enseñado e inspirado muchísimo desde hace ya unos cuantos años. ¿Si me preguntan? Slatin y su equipo son la 🐐" },
  { name: 'jorge zuloaga gonzalez',       role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-jorge-zuloaga.jpg',     date: '9 months ago',  quote: "Since I started working with him, my mixes have taken a huge leap forward. Having someone like Slatin, who's not only a great teacher but also a mastering engineer with real industry experience, makes all the difference. His ear, his judgement and the way he guides you take your sound to another level. Slatin is the professional you need. Highly recommended", quoteEs: "Desde que empecé con él, mis mezclas han pegado un salto enorme. Tener a alguien como Slatin, que no solo es un gran profesor, sino también un ingeniero de <em>mastering</em> con experiencia real en la industria, marca la diferencia. Su oído, su criterio y la forma en que te guía elevan tu sonido a otro nivel. Slatin es el profesional que necesitas. Recomendadísimo" },
  { name: 'David Dare',                   role: 'Aspiring Producer',     roleEs: 'Productor Aspirante',    avatar: '/images/mentoring/review-david-dare.jpg',   date: '9 months ago',  quote: "As an aspiring producer, getting to enjoy a masterclass with Slatin and his team, right in their own studio, has been an incredible experience. Beyond being didactic, the closeness and professional inspiration they give off while you watch them work live is priceless", quoteEs: "Como aspirante a productor, el poder haber podido disfrutar de una <em>masterclass</em> con Slatin y su equipo, en su propio estudio, ha sido una experiencia increíble. Aparte de didáctica, la cercanía e inspiración profesional que transmiten al verlos trabajar en directo, no tiene precio" },
  { name: 'Carlos Chacon',               role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-carlos-chacon.jpg', date: '9 months ago',  quote: "Slatin is a true professional at what he does, you can tell the experience he has. Not only for mastering and mixing, he also has an incredible vocation for teaching, he makes it so simple and easy that in the end you really get it. I recommend his courses and masterclasses 100%, you won't regret it", quoteEs: "Slatin es un profesional en lo que hace, se nota la experiencia que tiene. No solo para masterizar y mezclar, también tiene una vocación increíble para enseñar, lo hace tan simple y sencillo que al final terminas comprendiendo. Recomiendo al 100% sus cursos o <em>masterclasses</em>, no se van a arrepentir" },
  { name: 'Immortal Music',              role: 'Artist',                roleEs: 'Artista',                avatar: '/images/mentoring/review-immortal-music.jpg',   date: '2 months ago',  quote: "Endless knowledge, this guy! Honestly, in his trainings he makes what sometimes seems very complicated look easy. Super happy with everything I've learned. Highly recommended", quoteEs: "¡Conocimiento infinito lo de este hombre! La verdad que en sus formaciones hace ver fácil lo que a veces parece muy complicado, muy contento con el aprendizaje. Súper recomendado" },
  { name: 'Juata · Grabaciones Nómada',  role: 'Engineer',              roleEs: 'Ingeniero',              avatar: '/images/mentoring/review-juata.jpg', date: '9 months ago',  quote: "A wonderful experience learning from this great professional. He's not only great because of his skills, knowledge and team, what I liked the most was the human treatment from the people working there. Everything taken care of down to the detail and a kindness that not every professional at this level has. I hope to repeat the experience with one of their services at some point", quoteEs: "Maravillosa experiencia aprendiendo de este gran profesional. No solamente es bueno por sus habilidades, conocimientos y equipo, lo que más me gustó fue el trato humano de las personas que trabajan ahí. Todo cuidado al detalle y una amabilidad que no todos los profesionales de ese nivel tienen. Espero repetir experiencia en algún momento con alguno de sus servicios" },
  { name: 'Pablo Mateo Pillajo Montero', role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-pablo-mateo.jpg',  date: '8 months ago',  quote: "My experience at the Mix and Master Accelerator has been incredible, with the classes and the private tutoring. I've learned a ton, especially in mastering. Highly recommended. Slatin, the best", quoteEs: "Mi experiencia en el Mix and Master Accelerator ha sido increíble, con las clases y las tutorías privadas. He aprendido muchísimo, sobre todo en <em>mastering</em>. Recomendadísimo, Slatin el mejor" },
  { name: 'Gus Barraca',                 role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-gus-barraca.jpg',    date: '9 months ago',  quote: "Slatin and his team are on another level. Very professional. Slatin is an exceptional teacher and gives you much more than you pay for. I recommend him 100%", quoteEs: "Slatin y su equipo son de otro nivel. Muy profesionales. Slatin es un profesor excepcional y te da mucho más de lo que pagas. Lo recomiendo 100%" },
  { name: 'Borya Producer',              role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-borya.jpg',     date: '10 months ago', quote: "I recommend consultations and courses with Slatin, he's among the best in the Spanish scene, both technically and in terms of his human side. If you're looking to level up, you'll be in the best hands", quoteEs: "Recomiendo las consultas y los cursos con Slatin, es de lo mejor en el panorama nacional, tanto técnicamente como su calidad humana. Si buscas hacer un <em>level up</em> estarás en las mejores manos" },
  { name: 'Esperanza Nogales',           role: 'Engineer',              roleEs: 'Ingeniera',              avatar: '/images/mentoring/review-esperanza.jpg',     date: '9 months ago',  quote: "Some of the best you can find in Spain to improve your sound. I went to one of their sessions and learned things you won't find just anywhere. On top of that, he and his team are super friendly", quoteEs: "De lo mejor que hay en España para mejorar tu sonido. Fui a una jornada y aprendí cosas que no encuentras en cualquier lado. Además él y su equipo son súper agradables" },
  { name: 'Marc Cano Sánchez',           role: 'Producer',              roleEs: 'Productor',              avatar: '/images/mentoring/review-marc-cano.jpg',  date: '1 month ago',   quote: "I went to do a course with Slatin at his studio and I couldn't have left happier. Great way of explaining and great treatment, both from him and his whole team! 🫡", quoteEs: "Fui con Slatin a hacer un curso en su estudio y no pude haber salido más contento. ¡Gran manera de explicar y gran trato, tanto de su parte como de todo su equipo! 🫡" },
];

const rowA = reviews.slice(0, 8);
const rowB = reviews.slice(8, 16);
---

<section class="gr-section section-dark">
  <svg width="0" height="0" aria-hidden="true" style="position:absolute">
    <defs>
      <linearGradient id="star-gradient" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#ED8E00" />
        <stop offset="60%" stop-color="#f5a623" />
        <stop offset="100%" stop-color="#fcd891" />
      </linearGradient>
    </defs>
  </svg>
  <div class="gr-inner">

    <!-- Dual marquee carousel -->
    <div class="gr-carousel">

      <!-- Row A — forward -->
      <div class="gr-track-wrap">
        <div class="gr-track gr-track-fwd">
          {[...rowA, ...rowA].map((r) => (
            <div class="gr-card">
              <div class="gr-card-head">
                <div class="gr-card-user">
                  <div class={`gr-avatar ${r.hasBadge ? 'has-badge' : ''}`}>
                    <img src={r.avatar} alt={r.name} width="44" height="44" loading="lazy" />
                  </div>
                  <div>
                    <div class="gr-name">{r.name}</div>
                    <div class="gr-role">{isEs && r.roleEs ? r.roleEs : r.role}</div>
                  </div>
                </div>
                <div class="gr-gmark" title="Google review" aria-label="Google review">
                  <svg viewBox="0 0 48 48" width="14" height="14" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                  </svg>
                </div>
              </div>
              <div class="gr-stars" aria-label="5 stars">
                {[0,1,2,3,4].map(() => (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <p class="gr-body" set:html={`"${isEs && r.quoteEs ? r.quoteEs : r.quote}".`} />
            </div>
          ))}
        </div>
      </div>

      <!-- Row B — reverse -->
      <div class="gr-track-wrap">
        <div class="gr-track gr-track-rev">
          {[...rowB, ...rowB].map((r) => (
            <div class="gr-card">
              <div class="gr-card-head">
                <div class="gr-card-user">
                  <div class={`gr-avatar ${r.hasBadge ? 'has-badge' : ''}`}>
                    <img src={r.avatar} alt={r.name} width="44" height="44" loading="lazy" />
                  </div>
                  <div>
                    <div class="gr-name">{r.name}</div>
                    <div class="gr-role">{isEs && r.roleEs ? r.roleEs : r.role}</div>
                  </div>
                </div>
                <div class="gr-gmark" title="Google review" aria-label="Google review">
                  <svg viewBox="0 0 48 48" width="14" height="14" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                  </svg>
                </div>
              </div>
              <div class="gr-stars" aria-label="5 stars">
                {[0,1,2,3,4].map(() => (
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <p class="gr-body" set:html={`"${isEs && r.quoteEs ? r.quoteEs : r.quote}".`} />
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Aggregate footer -->
    <div class="gr-agg">
      <div class="section-grid" aria-hidden="true" style="border-radius:0;"></div>
      <div class="gr-agg-left">
        <div class="gr-eyebrow">{isEs ? 'En Sus Palabras' : 'In Their Words'}</div>
        <h2 class="gr-h2">
          {isEs ? (
            <><span class="gr-grad">5.0</span> de Productores<br />e Ingenieros <span class="gr-italic">Como Tú</span></>
          ) : (
            <><span class="gr-grad">5.0</span> from Producers<br />and Engineers <span class="gr-italic">Like You</span></>
          )}
        </h2>
        <p class="gr-lead">
          {isEs ? 'Cuando por fin encaja. Nada vuelve a sonar igual.' : 'When it finally clicks. Nothing sounds the same again.'}
        </p>
      </div>
      <div class="gr-agg-right">
        <div class="gr-score-row">
          <span class="gr-score">5.0</span>
          <span class="gr-score-out">/ 5</span>
        </div>
        <div class="gr-big-stars" aria-label="5 out of 5 stars">
          {[0,1,2,3,4].map(() => (
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <a class="gr-cta-link gr-cta-inline" href={googleUrl} target="_blank" rel="noreferrer noopener">
          <svg viewBox="0 0 48 48" width="16" height="16" aria-hidden="true" style="flex-shrink:0">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          </svg>
          {isEs ? 'Leer todo en Google' : 'Read all on Google'}
          <span class="gr-arrow gr-arrow-inline" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .gr-section {
    position: relative;
    padding: 96px 64px 20px;
    overflow: visible;
    background: transparent;
    color: #fff;
    margin-top: -160px;
    padding-top: 230px;
  }

  .gr-halo {
    position: absolute;
    top: -25%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 1200px;
    aspect-ratio: 2 / 1;
    background: radial-gradient(ellipse at center, rgba(221,51,51,.06) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .gr-inner {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    transform: translateY(0);
  }

  /* --- Aggregate footer --- */
  .gr-agg {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 300px;
    padding-top: 41px;
    padding-bottom: 78px;
    margin-top: 38px;
    margin-bottom: 0;
  }

  .gr-agg-left {
    flex: 0 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gr-agg-right {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .gr-eyebrow {
    display: inline-block;
    font-size: .8rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 18px;
  }

  .gr-h2 {
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -.02em;
    color: #fff;
    margin: 0 0 20px;
  }

  .gr-grad {
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .gr-italic { font-weight: 900; }

  .gr-lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255,255,255,.6);
    max-width: 560px;
  }

  .gr-score-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 10px;
  }

  .gr-score {
    font-size: clamp(7rem, 13vw, 12rem);
    font-weight: 500;
    line-height: .9;
    letter-spacing: -.04em;
    background: linear-gradient(180deg, #fff 40%, rgba(255,255,255,.5));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .gr-score-out {
    font-size: 1.8rem;
    font-weight: 500;
    color: rgba(255,255,255,.4);
    letter-spacing: -.02em;
  }

  .gr-big-stars {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-bottom: 16px;
  }
  .gr-big-stars svg {
    width: 38px;
    height: 38px;
    filter: drop-shadow(0 0 10px rgba(237,142,0,.35));
  }
  .gr-big-stars svg path {
    fill: url(#star-gradient);
  }

  /* --- Cards --- */
  .gr-card {
    width: 380px;
    flex-shrink: 0;
    background: linear-gradient(145deg, rgba(20,0,0,.35), rgba(10,10,10,.55));
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 20px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: #fff;
    transition: border-color .3s ease, box-shadow .3s ease;
  }

  .gr-track:not(:is(.gr-track-fwd, .gr-track-rev)) .gr-card:hover,
  .gr-card:hover {
    border-color: rgba(221,51,51,.35);
    box-shadow: 0 16px 50px rgba(0,0,0,.4);
  }

  .gr-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .gr-card-user {
    display: flex;
    align-items: center;
    gap: 12px;
  }

