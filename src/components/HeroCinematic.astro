---
export interface AlumniFace {
  src: string;
  alt?: string;
}

export interface Props {
  eyebrow?: string;
  headlineHtml?: string;
  subCopyHtml?: string;
  ctaLabel?: string;
  ctaHref?: string;
  videoLabel?: string;
  videoHref?: string;
  backgroundImage?: string;
  rating?: string;
  proofTextHtml?: string;
  alumni?: AlumniFace[];
  showProof?: boolean;
  showVideoLink?: boolean;
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props;
const isEs = lang === 'es';

const {
  eyebrow = "Mix & Master Accelerator",
  headlineHtml = 'Build a <strong>Profitable Music Career</strong> on <span class="grad">Your Own Terms</span>',
  subCopyHtml = 'Everything you need to <strong>Mix &amp; Master</strong> like a pro and build a career that pays.',
  ctaLabel = isEs ? "Empieza Hoy" : "Start Today",
  ctaHref = "#getaccess",
  videoLabel = isEs ? "Ver intro de 2 min" : "Watch 2-min intro",
  videoHref = "#intro-video",
  backgroundImage = "/images/mentoring/studio-bg.jpg",
  rating = "5.0",
  proofTextHtml = isEs
    ? 'Avalado por <strong>+200 ingenieros</strong>'
    : 'Trusted by <strong>200+ engineers</strong>',
  alumni = [
    { src: "/images/mentoring/review-eurofighterzz.jpg", alt: "" },
    { src: "/images/mentoring/review-alex-granero.jpg", alt: "" },
    { src: "/images/mentoring/review-jorge-zuloaga.jpg", alt: "" },
    { src: "/images/mentoring/review-carlos-chacon.jpg", alt: "" },
    { src: "/images/mentoring/review-marc-cano.jpg", alt: "" },
  ],
  showProof = true,
  showVideoLink = false,
} = Astro.props;
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg" style={`background-image: url('${backgroundImage}')`} aria-hidden="true"></div>
  <div class="hero__vignette" aria-hidden="true"></div>
  <div class="hero__ambient" aria-hidden="true"></div>

  <div class="hero__inner">
    <div class="hero__eyebrow">{eyebrow}</div>

    <h1 id="hero-heading" class="hero__heading" set:html={headlineHtml} />

    <p class="hero__sub" set:html={subCopyHtml} />

    <div class="hero__ctas">
      <a class="hero__cta" href={ctaHref}>
        <span>{ctaLabel}</span>
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>

      {showVideoLink && (
        <a class="hero__video" href={videoHref}>
          <span class="hero__play" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
          {videoLabel}
        </a>
      )}
    </div>

    {showProof && (
      <div class="hero__proof">
        <div class="hero__stack" aria-hidden="true">
          {alumni.map((a) => (
            <img src={a.src} alt={a.alt ?? ""} width="40" height="40" loading="eager" />
          ))}
        </div>
        <div class="hero__proof-meta">
          <div class="hero__rating">
            <div class="hero__stars" aria-label={`Rated ${rating} out of 5`}>
              {Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l2.9 6.9 7.4.6-5.6 4.9 1.7 7.3L12 17.8 5.6 21.7l1.7-7.3L1.7 9.5l7.4-.6L12 2z"/>
                </svg>
              ))}
            </div>
            <span class="hero__rating-num">{rating}</span>
          </div>
          <div class="hero__proof-text" set:html={proofTextHtml} />
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    isolation: isolate;
    background: #020202;
    color: #fff;
    font-family: "Plus Jakarta Sans", system-ui, sans-serif;
  }

  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.4) contrast(1.1) saturate(0.85);
    z-index: 0;
  }
  .hero__vignette {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(2,2,2,0.70) 0%,
      rgba(2,2,2,0.30) 40%,
      rgba(2,2,2,0.95) 100%
    );
  }
  .hero__ambient {
    position: absolute; inset: 0; z-index: 1;
    background: radial-gradient(ellipse at center, rgba(221,51,51,0.15), transparent 60%);
  }

  .hero__inner {
    position: relative; z-index: 10;
    min-height: 100vh;
    padding: clamp(120px, 14vh, 160px) clamp(24px, 8vw, 120px) clamp(80px, 10vh, 120px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 36px;
  }

  .hero__eyebrow {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #DD3333;
    white-space: nowrap;
  }

  .hero__heading {
    margin: 0;
    max-width: 1200px;
    font-size: clamp(32px, 5.2vw, 72px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: #fff;
    overflow-wrap: break-word;
  }
  .hero__heading :global(strong) { font-weight: 800; }
  .hero__heading :global(.hero-line) {
    display: block;
    white-space: nowrap;
  }
  .hero__heading :global(.grad) {
    position: relative;
    display: inline-block;
    font-weight: 800;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero__heading :global(.grad)::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: -6px;
    height: 18px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 300 18' preserveAspectRatio='none'><path d='M4 10 C 40 2, 80 16, 120 8 S 200 2, 240 12 S 290 6, 296 10' fill='none' stroke='%23BA1616' stroke-width='3' stroke-linecap='round'/></svg>");
    background-repeat: no-repeat;
    background-size: 100% 100%;
    pointer-events: none;
  }

  .hero__sub {
    margin: 0;
    max-width: 760px;
    font-size: 1.125rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.65);
    text-wrap: balance;
  }
  .hero__sub :global(strong) { color: #fff; font-weight: 700; }

  .hero__ctas {
    display: flex;
    gap: 16px;
    margin-top: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__cta {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 26px 44px;
    border-radius: 14px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 30px rgba(221,51,51,0.35), inset 0 0 0 1px rgba(255,255,255,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .hero__cta:hover, .hero__cta:focus-visible {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    box-shadow: 0 16px 50px rgba(221,51,51,0.55), inset 0 0 0 1px rgba(255,255,255,0.10);
    transform: translateY(-2px);
    outline: none;
  }
  .hero__cta:active { transform: translateY(0); }

  .hero__video {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 20px 24px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    background: transparent;
    color: rgba(255,255,255,0.85);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    backdrop-filter: blur(8px);
    transition: all 0.2s ease;
  }
  .hero__video:hover, .hero__video:focus-visible {
    background: rgba(255,255,255,0.05);
    color: #fff;
    outline: none;
  }
  .hero__play {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .hero__proof {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
    padding: 10px 18px 10px 12px;
    background: rgba(10,10,10,0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 999px;
  }
  .hero__stack { display: flex; }
  .hero__stack img {
    width: 40px; height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #020202;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.08);
    margin-left: -12px;
    position: relative;
  }
  .hero__stack img:first-child { margin-left: 0; }

  .hero__proof-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left;
  }
  .hero__rating { display: flex; align-items: center; gap: 8px; }
  .hero__stars { display: inline-flex; gap: 2px; color: #ED8E00; }
  .hero__rating-num { font-size: 0.875rem; font-weight: 800; color: #fff; }
  .hero__proof-text { font-size: 0.8125rem; line-height: 1.3; color: rgba(255,255,255,0.6); }
  .hero__proof-text :global(strong) { color: #fff; font-weight: 700; }

  @media (max-width: 640px) {
    .hero__inner { padding: clamp(96px, 12vh, 140px) 20px clamp(64px, 8vh, 96px); gap: 28px; }
    .hero__eyebrow { font-size: 0.75rem; letter-spacing: 0.18em; white-space: normal; }
    .hero__heading :global(.hero-line) { white-space: normal; }
    .hero__cta { padding: 20px 28px; font-size: 0.9375rem; width: 100%; justify-content: center; }
    .hero__video { padding: 14px 20px; width: auto; align-self: center; }
    .hero__proof { flex-wrap: wrap; justify-content: center; text-align: center; }
    .hero__proof-meta { align-items: center; text-align: center; }
    .hero__heading :global(.grad)::after { display: none; }
  }
</style>
