---
const links = [
  { label: 'Mentoring', href: '/mentoring' },
  { label: 'Low End Mastery', href: '/low-end-mastery' },
  { label: 'Microdynamics', href: '/microdynamics' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" data-scrolled="false">
  <nav class="w-full flex items-center justify-between h-16 md:h-20 px-6 md:px-[1%] lg:px-[6%]">
    <!-- Logo -->
    <a href="https://www.slatin.pro" class="flex-shrink-0">
      <img
        src="https://www.slatin.pro/wp-content/uploads/2023/01/Recurso-21.png"
        alt="SLATIN"
        class="h-7 md:h-[30px] w-auto"
      />
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="font-medium text-white hover:text-white/80 transition-colors" style="font-size: 17px;"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA Button (desktop only) -->
    <a
      href="https://www.slatin.pro/submit-your-song/"
      class="hidden md:inline-flex btn-cta-orange text-sm"
    >
      <svg class="w-4 h-4 hidden md:block" viewBox="0 0 24 24" fill="currentColor">
        <rect x="2" y="6" width="2" height="12" rx="1" />
        <rect x="6" y="3" width="2" height="18" rx="1" />
        <rect x="10" y="8" width="2" height="8" rx="1" />
        <rect x="14" y="4" width="2" height="16" rx="1" />
        <rect x="18" y="6" width="2" height="12" rx="1" />
      </svg>
      Submit Your Song
    </a>

    <!-- Mobile Hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-6 h-0.5 bg-white transition-transform" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-opacity" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-white transition-transform" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-dark border-t border-white/10">
    <div class="px-6 py-6 flex flex-col gap-4">
      {links.map((link) => (
        <a href={link.href} class="text-lg font-medium text-white/80 hover:text-white">
          {link.label}
        </a>
      ))}
      <a href="https://www.slatin.pro/submit-your-song/" class="btn-cta-orange text-center mt-2">
        Submit Your Song
      </a>
    </div>
  </div>
</header>

<style>
  #site-header {
    background: transparent;
  }
  #site-header[data-scrolled="true"] {
    background: rgba(2, 2, 2, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: none;
  }
  /* Reduce compositing cost on mobile: only blur when scrolled */
  @media (max-width: 767px) {
    #site-header {
      will-change: background;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  const header = document.getElementById('site-header');
  function updateHeader() {
    if (!header) return;
    header.setAttribute('data-scrolled', window.scrollY > 50 ? 'true' : 'false');
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
</script>
