---
import { ui } from '../data/ui';
import { getAlternateUrl, type Locale } from '../utils/i18n';

interface Props { lang?: Locale }
const lang: Locale = Astro.props.lang ?? 'en';
const t = ui[lang];
const alternateLang: Locale = lang === 'en' ? 'es' : 'en';
const alternateHref = getAlternateUrl(Astro.url, alternateLang);
const links = t.nav.links;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50" data-scrolled="false">
  <nav class="relative w-full flex items-center justify-between h-16 md:h-20 px-6 md:px-[1%] lg:px-[6%]">
    <!-- Logo -->
    <a href="https://www.slatin.pro" class="flex-shrink-0" style="margin-left: calc(-2.2% - 2px);">
      <img
        src="https://www.slatin.pro/wp-content/uploads/2023/01/Recurso-21.png"
        alt="SLATIN"
        class="h-7 md:h-[30px] w-auto"
      />
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8 md:absolute md:left-1/2 md:top-1/2 md:-translate-x-1/2 md:-translate-y-1/2">
      {links.map((link) => (
        <a
          href={link.href}
          class="font-medium text-white hover:text-white/80 transition-colors"
          style="font-size: 17px;"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Desktop Right: Lang Switcher + CTA -->
    <div class="hidden md:flex items-center gap-5">
      <a
        href={alternateHref}
        class="lang-switcher"
        aria-label={t.langSwitcher.ariaLabel}
      >
        {t.langSwitcher.label}
      </a>
      <a
        href={t.nav.cta.href}
        class="nav-cta nav-cta-live"
      >
        <svg class="w-[18px] h-[18px]" viewBox="0 0 32 32" fill="currentColor">
          <path d="M0 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM4 24.667c-0.367 0-0.667-0.299-0.667-0.667v-16c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v16c0 0.368-0.3 0.667-0.667 0.667zM16 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM12 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM8 27.333c-0.367 0-0.667-0.299-0.667-0.667v-21.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v21.333c0 0.368-0.3 0.667-0.667 0.667zM20 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM32 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM28 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM24 26c-0.367 0-0.667-0.299-0.667-0.667v-18.667c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v18.667c0 0.368-0.3 0.667-0.667 0.667z"/>
        </svg>
        {t.nav.cta.label}
        <span class="nav-chip">LIVE</span>
      </a>
    </div>

    <!-- Mobile Hamburger / X -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 hamburger"
      aria-label="Toggle menu"
    >
      <span class="hamburger-bar" id="bar1"></span>
      <span class="hamburger-bar" id="bar2"></span>
      <span class="hamburger-bar" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-dark border-t border-white/10">
    <div class="px-6 py-6 flex flex-col gap-4">
      <a href={t.nav.cta.href} class="nav-cta nav-cta-mobile nav-cta-live">
        <svg class="w-[18px] h-[18px]" viewBox="0 0 32 32" fill="currentColor">
          <path d="M0 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM4 24.667c-0.367 0-0.667-0.299-0.667-0.667v-16c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v16c0 0.368-0.3 0.667-0.667 0.667zM16 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM12 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM8 27.333c-0.367 0-0.667-0.299-0.667-0.667v-21.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v21.333c0 0.368-0.3 0.667-0.667 0.667zM20 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM32 20.667c-0.367 0-0.667-0.299-0.667-0.667v-8c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v8c0 0.368-0.3 0.667-0.667 0.667zM28 23.333c-0.367 0-0.667-0.299-0.667-0.667v-13.333c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v13.333c0 0.368-0.3 0.667-0.667 0.667zM24 26c-0.367 0-0.667-0.299-0.667-0.667v-18.667c0-0.368 0.3-0.667 0.667-0.667s0.667 0.299 0.667 0.667v18.667c0 0.368-0.3 0.667-0.667 0.667z"/>
        </svg>
        {t.nav.cta.label}
        <span class="nav-chip">LIVE</span>
      </a>
      <div class="mobile-menu-divider"></div>
      {links.map((link) => (
        <a href={link.href} class="text-lg font-medium text-white/80 hover:text-white">
          {link.label}
        </a>
      ))}
      <a
        href={alternateHref}
        class="lang-switcher mt-2"
        aria-label={t.langSwitcher.ariaLabel}
      >
        {t.langSwitcher.label}
      </a>
    </div>
  </div>
</header>

<style>
  #site-header {
    background: transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, -webkit-backdrop-filter 0.3s ease;
  }
  #site-header[data-scrolled="true"] {
    background: rgba(2, 2, 2, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: none;
  }
  #site-header:not([data-ready]) {
    transition: none;
  }
  /* Reduce compositing cost on mobile: only blur when scrolled */
  @media (max-width: 767px) {
    #site-header {
      will-change: background;
    }
  }

  /* Language switcher */
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 5px 12px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    transition: border-color 0.2s, background-color 0.2s;
    text-decoration: none;
  }
  .lang-switcher:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background-color: rgba(255, 255, 255, 0.08);
  }

  /* CTA button — matches WP Salient animated gradient */
  .nav-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.02em;
    padding: 0;
    z-index: 1;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .nav-cta::before {
    content: "";
    position: absolute;
    top: -10px;
    left: -24px;
    right: -24px;
    bottom: -10px;
    border-radius: 4px;
    background: linear-gradient(90deg, #ed8e00, #dd3333, #ed8e00);
    background-size: 200% 100%;
    z-index: -1;
    transition: opacity 0.3s ease;
  }

  .nav-cta-live::before {
    animation: cta-gradient-shift 3s ease-in-out infinite;
  }

  @keyframes cta-gradient-shift {
    0%, 100% { background-position: 0% 0; }
    50% { background-position: 100% 0; }
  }

  .nav-cta:hover {
    opacity: 0.95;
  }

  /* LIVE chip — superscript badge */
  .nav-chip {
    position: absolute;
    top: -16px;
    right: -16px;
    padding: 2px 6px;
    background: #DD3333;
    color: #fff;
    font-size: 8px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.4;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  /* Mobile menu CTA */
  .nav-cta-mobile {
    justify-content: center;
    width: fit-content;
    font-size: 15px;
    margin-left: 24px;
  }

  /* Mobile menu divider */
  .mobile-menu-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 4px 0;
  }

  /* Hamburger → X animation */
  .hamburger-bar {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .hamburger.open #bar1 {
    transform: translateY(8px) rotate(45deg);
  }

  .hamburger.open #bar2 {
    opacity: 0;
  }

  .hamburger.open #bar3 {
    transform: translateY(-8px) rotate(-45deg);
  }

</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    toggle.classList.toggle('open');
  });

  const header = document.getElementById('site-header');
  function updateHeader() {
    if (!header) return;
    const scrolled = header.getAttribute('data-scrolled') === 'true';
    const y = window.scrollY;
    // Hysteresis to avoid flicker at threshold
    if (!scrolled && y > 60) header.setAttribute('data-scrolled', 'true');
    else if (scrolled && y < 30) header.setAttribute('data-scrolled', 'false');
  }
  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
  // Enable transitions after first paint to prevent flash on page load
  requestAnimationFrame(() => {
    header?.setAttribute('data-ready', '');
  });
</script>
