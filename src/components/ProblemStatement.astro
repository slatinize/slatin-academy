---
interface ProblemItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  headline: string;
  items: ProblemItem[];
  closing?: string;
}

const { eyebrow, headline, items, closing } = Astro.props;
---

<section class="ps__section section-padding" style="background:#1a1a1a; color:#fff;">
  <div class="container-content">
    <div class="text-center mb-12 md:mb-16 reveal">
      {eyebrow && <p class="ps__eyebrow">{eyebrow}</p>}
      <h2 class="text-heading" set:html={headline} />
    </div>

    <div class="grid md:grid-cols-3 gap-4 md:gap-6 mb-12">
      {items.map((item) => (
        <div class="ps__card reveal">
          <span class="ps__icon" set:html={item.icon} />
          <h3 class="text-xl font-bold mb-2">{item.title}</h3>
          <p class="text-base leading-relaxed ps__desc">{item.description}</p>
        </div>
      ))}
    </div>

    {closing && (
      <div class="text-center reveal">
        <p class="ps__closing" set:html={closing} />
      </div>
    )}
  </div>
</section>

<style>
  .ps__section {
    padding-top: 1.875rem !important;
    padding-bottom: 1.7rem !important;
  }

  @media (min-width: 768px) {
    .ps__section {
      padding-top: 4.5rem !important;
      padding-bottom: 4rem !important;
    }
  }

  @media (min-width: 1024px) {
    .ps__section {
      padding-top: 6rem !important;
      padding-bottom: 5.4rem !important;
    }
  }

  .ps__eyebrow {
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B52020;
    margin-bottom: 16px;
    position: relative;
    display: inline-block;
  }

  .ps__eyebrow::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: -4px;
    height: 2px;
    background: #DD3333;
    border-radius: 2px;
    opacity: 0.6;
  }

  .ps__card {
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.04);
    border-radius: 16px;
    padding: 32px 28px;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .ps__card:hover {
    transform: translateY(-3px);
    border-color: rgba(221,51,51,0.3);
  }

  .ps__desc {
    color: rgba(255,255,255,0.55);
  }

  .ps__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(221,51,51,0.15);
    color: #DD3333;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .ps__closing {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    color: rgba(255,255,255,0.65);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ps__closing :global(strong) {
    color: #fff;
    font-weight: 700;
  }
</style>
