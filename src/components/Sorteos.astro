---
interface SorteoItem {
  icon: string;
  image?: string;
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  items: SorteoItem[];
}

const { sectionTitle, items } = Astro.props;
---

<section class="sr section-dark">
  <div class="sr__inner">

    <div class="sr__header reveal">
      <h2 class="sr__heading" set:html={sectionTitle} />
    </div>

    <div class="sr__list">
      {items.map((item, i) => (
        <div class={`sr__row reveal ${i % 2 === 1 ? 'sr__row--reverse' : ''}`}>
          {item.image && (
            <div class="sr__img-wrap">
              <img src={item.image} alt={item.title} loading="lazy" class="sr__img" />
            </div>
          )}
          <div class="sr__body">
            {item.showBadge !== false && <span class="sr__badge">SORTEO</span>}
            <h3 class="sr__title" set:html={item.title} />
            <p class="sr__desc" set:html={item.description} />
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .sr {
    padding: 56px 7% 56px;
    position: relative;
  }

  .sr__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .sr__header {
    margin-bottom: 72px;
  }

  .sr__heading {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0;
  }
  .sr__heading :global(.sr-underline),
  .sr__title :global(.sr-underline) {
    text-decoration: underline;
    text-decoration-color: #DD3333;
    text-underline-offset: 6px;
    text-decoration-thickness: 3px;
  }

  /* List */
  .sr__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Row */
  .sr__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding: 6px 0;
    border-bottom: none;
  }

  .sr__row:last-child {
    border-bottom: none;
  }

  .sr__row--reverse {
    direction: rtl;
  }

  .sr__row--reverse > * {
    direction: ltr;
  }

  /* Image */
  .sr__img-wrap {
    aspect-ratio: 16 / 7;
    overflow: hidden;
    border-radius: 10px;
  }

  .sr__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.6s ease;
  }

  .sr__row:hover .sr__img {
    transform: scale(1.04);
  }

  /* Body */
  .sr__body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sr__badge {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #DD3333;
  }

  .sr__title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .sr__desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
  }

  @media (max-width: 768px) {
    .sr__row {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 40px 0;
    }

    .sr__row--reverse {
      direction: ltr;
    }
  }
</style>
