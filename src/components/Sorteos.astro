---
interface SorteoItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  items: SorteoItem[];
}

const { sectionTitle, items } = Astro.props;
---

<section class="section-dark section-padding">
  <div class="container-content">
    <div class="text-center mb-12 md:mb-16 reveal">
      <h2 class="text-heading" set:html={sectionTitle} />
    </div>

    <div class="grid md:grid-cols-3 gap-4 md:gap-6 max-w-4xl mx-auto">
      {items.map((item) => (
        <div class="sr__card reveal">
          <span class="sr__icon" set:html={item.icon} />
          <h3 class="text-lg font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-white/55 leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sr__card {
    border: 1px solid rgba(232,115,74,0.2);
    background: rgba(232,115,74,0.05);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .sr__card:hover {
    transform: translateY(-3px);
    border-color: rgba(232,115,74,0.4);
  }

  .sr__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    font-size: 1.5rem;
    margin-bottom: 16px;
  }
</style>
