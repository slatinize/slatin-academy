---
interface Step {
  number: string;
  title: string;
  description: string;
  tag?: string;
}

interface Props {
  sectionTitle: string;
  steps: Step[];
}

const { sectionTitle, steps } = Astro.props;
---

<section class="section-dark section-padding">
  <div class="container-content">
    <div class="text-center mb-12 md:mb-16 reveal">
      <h2 class="text-heading">{sectionTitle}</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {steps.map((step) => (
        <div class="hiw__card reveal">
          <span class="hiw__num">{step.number}</span>
          <h3 class="text-lg font-bold mb-2">{step.title}</h3>
          <p class="text-sm text-white/55 leading-relaxed">{step.description}</p>
          {step.tag && (
            <span class="hiw__tag">{step.tag}</span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hiw__card {
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .hiw__card:hover {
    transform: translateY(-3px);
    border-color: rgba(221,51,51,0.3);
  }

  .hiw__num {
    font-size: 2rem;
    font-weight: 800;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 16px;
  }

  .hiw__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: 16px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .hiw__tag::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #E8734A;
  }
</style>
