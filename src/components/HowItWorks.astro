---
interface Step {
  number: string;
  title: string;
  description: string;
  tag?: string;
}

interface Props {
  sectionTitle: string;
  eyebrow?: string;
  steps: Step[];
}

const { sectionTitle, eyebrow = 'El proceso', steps } = Astro.props;
---

<section class="hiw__section section-padding">
  <!-- Ambient halos -->
  <div class="hiw__halo hiw__halo--left" aria-hidden="true"></div>
  <div class="hiw__halo hiw__halo--right" aria-hidden="true"></div>

  <div class="section-grid" aria-hidden="true"></div>
  <div class="container-content" style="position:relative;z-index:1;">
    <div class="text-center mb-16 reveal">
      <p class="hiw__eyebrow">{eyebrow}</p>
      <h2 class="hiw__title">{sectionTitle}</h2>
    </div>

    <div class="timeline" id="hiw-timeline">
      <!-- Animated connector line overlay -->
      <div class="tl-line-fill" id="hiw-line-fill"></div>

      {steps.map((step, i) => (
        <div class="tl-step hiw-step" style={`--step-i:${i}`}>
          <div class="tl-node">{step.number}</div>
          <h3 class="tl-title">{step.title}</h3>
          <p class="tl-desc">{step.description}</p>
          {step.tag && <span class="tl-tag">{step.tag}</span>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Section with gradient fade from the dark-gray block above */
  .hiw__section {
    background: linear-gradient(180deg, #1a1a1a 0%, #020202 120px);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  /* Ambient halos */
  .hiw__halo {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    z-index: 0;
  }
  .hiw__halo--left {
    width: 480px; height: 480px;
    top: -60px; left: -120px;
    background: radial-gradient(circle, rgba(221,51,51,0.12), transparent 70%);
    animation: hiw-halo-drift 14s ease-in-out infinite alternate;
  }
  .hiw__halo--right {
    width: 400px; height: 400px;
    bottom: -40px; right: -80px;
    background: radial-gradient(circle, rgba(237,142,0,0.1), transparent 70%);
    animation: hiw-halo-drift 11s ease-in-out infinite alternate-reverse;
  }
  @keyframes hiw-halo-drift {
    0%   { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, -20px) scale(1.12); }
  }

  /* Eyebrow — same treatment as EL PROBLEMA */
  .hiw__eyebrow {
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B52020;
    margin-bottom: 16px;
    position: relative;
    display: inline-block;
  }

  .hiw__eyebrow::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: -4px;
    height: 2px;
    background: #DD3333;
    border-radius: 2px;
    opacity: 0.6;
  }

  /* Title — bigger, tighter, more weight */
  .hiw__title {
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.05;
    color: #fff;
    margin-top: 20px;
  }

  .timeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  /* Connector line — static base (dimmed) */
  .timeline::before {
    content: '';
    position: absolute;
    top: 27px;
    left: calc(12.5%);
    right: calc(12.5%);
    height: 2px;
    background: rgba(255,255,255,0.06);
    z-index: 0;
  }

  /* Animated fill line */
  .tl-line-fill {
    position: absolute;
    top: 27px;
    left: calc(12.5%);
    height: 2px;
    width: 0%;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    z-index: 0;
    transition: width 1.4s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 2px;
    box-shadow: 0 0 8px rgba(237,142,0,0.4);
  }
  .tl-line-fill.animated {
    width: 75%; /* matches right: calc(12.5%) */
  }

  .tl-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  /* Staggered entrance */
  .hiw-step {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: calc(var(--step-i) * 0.15s);
  }
  .hiw-step.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes node-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 6px #020202,
        0 0 0 10px rgba(221,51,51,0.5),
        0 0 28px 8px rgba(237,142,0,0.35),
        0 0 60px 16px rgba(221,51,51,0.2);
    }
    50% {
      box-shadow:
        0 0 0 6px #020202,
        0 0 0 14px rgba(221,51,51,0.15),
        0 0 10px 2px rgba(237,142,0,0.1),
        0 0 20px 4px rgba(221,51,51,0.05);
    }
  }

  .tl-node {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ED8E00, #DD3333);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 32px;
    flex-shrink: 0;
    animation: node-pulse 2.8s ease-in-out infinite;
    transition: transform 0.3s ease;
  }

  .tl-step:hover .tl-node {
    animation-play-state: paused;
    box-shadow:
      0 0 0 6px #020202,
      0 0 0 12px rgba(221,51,51,0.6),
      0 0 36px 12px rgba(237,142,0,0.45),
      0 0 70px 20px rgba(221,51,51,0.25);
    transform: scale(1.08);
  }

  .tl-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .tl-desc {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 16px;
  }

  .tl-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E8734A;
    background: rgba(232,115,74,0.1);
    padding: 4px 12px;
    border-radius: 999px;
    margin-top: auto;
  }

  /* Mobile: stack vertically, no connector line */
  @media (max-width: 767px) {
    .timeline {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .timeline::before {
      display: none;
    }

    .tl-step {
      flex-direction: row;
      text-align: left;
      align-items: flex-start;
      gap: 20px;
      padding: 0;
    }

    .tl-node {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .tl-step > div:last-child {
      flex: 1;
    }

    .tl-line-fill { display: none; }
  }
</style>

<script>
  function initHIW() {
    const steps = document.querySelectorAll<HTMLElement>('.hiw-step');
    const lineFill = document.getElementById('hiw-line-fill');

    if (!steps.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Animate steps in
          steps.forEach((s) => s.classList.add('visible'));
          // Animate the line fill after a short delay
          if (lineFill) setTimeout(() => lineFill.classList.add('animated'), 200);
          observer.disconnect();
        }
      });
    }, { threshold: 0.2 });

    observer.observe(steps[0]);
  }

  initHIW();
  document.addEventListener('astro:page-load', initHIW);
</script>
