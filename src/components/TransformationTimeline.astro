---
import AnimatedGradient from './AnimatedGradient.astro';

interface TimelinePhase {
  label: string;
  title: string;
  icon: string;
  color: string;
  items: string[];
}

interface Props {
  sectionTitle: string;
  phases: TimelinePhase[];
}

const { sectionTitle, phases } = Astro.props;
---

<section class="tl-section section-dark px-6 pt-6 pb-10 md:px-[5%] md:pt-12 md:pb-20 lg:px-[7%] lg:pt-16 lg:pb-24 overflow-hidden">
  <!-- Ambient gradient background -->
  <div class="tl-bg" aria-hidden="true">
    <AnimatedGradient color1="#DD3333" color2="#8B0000" speed={1600} blendingMode="organic" />
  </div>

  <div class="container-content relative z-10">
    <div class="text-center mb-10 md:mb-16 reveal">
      <h2 class="tl-section-title" set:html={sectionTitle} />
    </div>

    <div class="tl-timeline reveal">
      {phases.map((phase, i) => (
        <div class={`tl-node tl-phase-${i}`}>
          <div class="tl-label" style={`color: ${phase.color}`}>{phase.label}</div>
          <div class="tl-title">{phase.title}</div>
          <ul class="tl-items">
            {phase.items.map((item) => (
              <li>
                <span class="tl-icon" style={`color: ${phase.color}`}>{phase.icon}</span>
                <span set:html={item} />
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tl-section {
    position: relative;
  }

  /* Background gradient — covers the full section */
  .tl-section-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .tl-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.5;
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 0%, transparent 70%);
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 0%, transparent 70%);
  }

  .tl-timeline {
    position: relative;
    padding-left: 40px;
    max-width: 700px;
    margin: 0 auto;
  }

  .tl-timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    border-radius: 2px;
    background: linear-gradient(to bottom, #555 0%, #555 12%, #ed8e00 35%, #DD3333 70%);
    box-shadow: 0 0 8px rgba(221,51,51,0.2);
  }

  .tl-node {
    position: relative;
    margin-bottom: 56px;
    padding-left: 28px;
  }
  .tl-node:last-child { margin-bottom: 0; }

  .tl-label {
    font-size: clamp(0.75rem, 1vw, 0.9rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .tl-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .tl-phase-0 .tl-title { color: rgba(255,255,255,0.65); }
  .tl-phase-1 .tl-title,
  .tl-phase-2 .tl-title { color: rgba(255,255,255,1); }

  .tl-items {
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.6;
    list-style: none;
  }
  .tl-phase-0 .tl-items { color: rgba(255,255,255,0.5); }
  .tl-phase-1 .tl-items { color: rgba(255,255,255,0.85); }
  .tl-phase-2 .tl-items { color: rgba(255,255,255,0.95); }

  .tl-items li {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .tl-icon {
    flex-shrink: 0;
  }

  /* Desktop scaling */
  @media (min-width: 1024px) {
    .tl-timeline {
      max-width: 800px;
      padding-left: 48px;
    }
    .tl-node {
      margin-bottom: 72px;
      padding-left: 36px;
    }
    .tl-label {
      font-size: 0.9rem;
      margin-bottom: 10px;
    }
    .tl-title {
      font-size: 2.2rem;
      margin-bottom: 18px;
    }
    .tl-items {
      gap: 14px;
      font-size: 1.1rem;
    }
    .tl-items li {
      gap: 10px;
    }
  }

  @media (min-width: 1440px) {
    .tl-timeline {
      max-width: 900px;
      padding-left: 56px;
    }
    .tl-node {
      margin-bottom: 80px;
      padding-left: 40px;
    }
    .tl-title {
      font-size: 2.4rem;
    }
  }
</style>
