---
import AnimatedGradient from './AnimatedGradient.astro';

interface Stat {
  value: string;
  label: string;
  highlight?: boolean;
}

interface Props {
  tagline: string;
  name: string;
  nameAccent: string;
  bio: string;
  imageSrc: string;
  logosSrc: string;
  stats: Stat[];
}

const { tagline, name, nameAccent, bio, imageSrc, logosSrc, stats } = Astro.props;
---

<section class="mi section-dark overflow-hidden">
  <!-- Ambient gradient -->
  <div class="mi__bg" aria-hidden="true">
    <AnimatedGradient color1="#DD3333" color2="#1a0000" speed={1500} blendingMode="organic" />
  </div>
  <div class="section-grid" aria-hidden="true"></div>

  <div class="mi__content">

    <!-- Top: text + photo side by side -->
    <div class="mi__grid">

      <!-- Left: text -->
      <div class="mi__text reveal">
        <p class="mi__tagline">{tagline}</p>
        <h2 class="mi__name">
          {name} <span class="mi__name-accent">{nameAccent}</span>
        </h2>
        <p class="mi__bio" set:html={bio} />
        <div class="mi__stats">
          {stats.map((stat) => (
            <div class="mi__stat">
              <div class={`mi__stat-value ${stat.highlight ? 'mi__stat-highlight' : ''}`}>{stat.value}</div>
              <div class="mi__stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: photo -->
      <div class="mi__photo-wrap reveal">
        <div class="mi__photo">
          <img src={imageSrc} alt={`${name} ${nameAccent}`} loading="lazy" />
        </div>
      </div>

    </div>

    <!-- Bottom: logos full width -->
    <div class="mi__logos reveal">
      <div class="mi__logos-rule"></div>
      <img src={logosSrc} alt="Client logos" loading="lazy" />
    </div>

  </div>
</section>

<style>
  .mi {
    position: relative;
    overflow: hidden;
  }

  .mi__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.28;
    -webkit-mask-image: radial-gradient(ellipse 70% 90% at 80% 30%, black 0%, transparent 70%);
    mask-image: radial-gradient(ellipse 70% 90% at 80% 30%, black 0%, transparent 70%);
  }

  /* ── Content ── */
  .mi__content {
    position: relative;
    z-index: 1;
    padding: 48px 7% 0;
  }

  /* ── Top grid ── */
  .mi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 0;
  }

  @media (min-width: 768px) {
    .mi__grid {
      grid-template-columns: 1fr auto;
      gap: 6%;
      margin-bottom: 0;
    }
    .mi__content {
      padding: 61px 7% 0;
    }
  }

  @media (min-width: 1280px) {
    .mi__content {
      padding: 75px 7% 0;
    }
  }

  /* ── Text ── */
  .mi__tagline {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 14px;
  }

  .mi__name {
    font-size: clamp(3rem, 6.5vw, 6rem);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
    color: #fff;
  }

  .mi__name-accent {
    background: linear-gradient(90deg, #FF4444, #DD3333, #aa1111);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .mi__bio {
    font-size: clamp(0.95rem, 1.15vw, 1.1rem);
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    margin-bottom: 40px;
    max-width: 580px;
  }

  /* ── Stats ── */
  .mi__stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .mi__stat-value {
    font-size: clamp(1.8rem, 2.8vw, 2.6rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .mi__stat-highlight {
    color: #DD3333;
  }

  .mi__stat-label {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 5px;
  }

  /* ── Photo ── */
  .mi__photo-wrap {
    display: flex;
    justify-content: center;
  }

  .mi__photo {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    box-shadow:
      0 0 0 1px rgba(221,51,51,0.15),
      0 32px 80px rgba(0,0,0,0.6),
      0 0 60px rgba(221,51,51,0.08);
  }

  .mi__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  @media (min-width: 768px) {
    .mi__photo {
      width: 420px;
      height: 420px;
    }
  }

  @media (min-width: 1280px) {
    .mi__photo {
      width: 460px;
      height: 460px;
    }
  }

  @media (min-width: 1600px) {
    .mi__photo {
      width: 520px;
      height: 520px;
    }
  }

  /* ── Logos — full width below grid ── */
  .mi__logos {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 32px 0 56px;
    width: 100%;
  }

  .mi__logos img {
    width: 100%;
    max-width: 100%;
    display: block;
    object-fit: contain;
    opacity: 0.4;
  }

  @media (min-width: 768px) {
    .mi__logos {
      padding: 40px 0 72px;
    }
  }

  @media (min-width: 1280px) {
    .mi__logos {
      padding: 48px 0 88px;
    }
  }
</style>
