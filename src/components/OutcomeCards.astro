---
interface OutcomeCard {
  title: string;
  icon: string;
  bgColor: string;
  textColor?: string;
}

interface Props {
  sectionTitle?: string;
  cards: OutcomeCard[];
}

const { sectionTitle, cards } = Astro.props;

const icons: Record<string, string> = {
  wrench: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>',
  volume: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>',
  crosshairs: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12"><path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3A8.994 8.994 0 0013 3.06V1h-2v2.06A8.994 8.994 0 003.06 11H1v2h2.06A8.994 8.994 0 0011 20.94V23h2v-2.06A8.994 8.994 0 0020.94 13H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"/></svg>',
  money: '<svg viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 md:w-12 md:h-12"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>',
};
---

<section class="section-dark px-6 py-6 md:px-[5%] md:py-10 lg:px-[7%] lg:py-12">
  <div class="container-content">
    {sectionTitle && (
      <div class="text-center mb-8 md:mb-12 reveal">
        <h2 class="text-heading" set:html={sectionTitle} />
      </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
      {cards.map((card) => (
        <div
          class="outcome-card rounded-2xl p-7 md:p-8 text-center reveal"
          style={`background-color: ${card.bgColor}; color: ${card.textColor || '#ffffff'}`}
        >
          <div class="flex justify-center mb-4 opacity-90" set:html={icons[card.icon] || ''} />
          <p class="outcome-title" set:html={card.title} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .outcome-title {
    font-size: clamp(1.1rem, 1.8vw, 1.4rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .outcome-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .outcome-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }
</style>
