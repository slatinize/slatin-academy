---
interface FAQItem {
  question: string;
  answer: string;
  category?: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

// Extract unique categories preserving order
const categories = [...new Set(items.map(item => item.category).filter(Boolean))] as string[];
const hasCategories = categories.length > 1;
---

<section class="section-dark section-padding">
  <div class="container-content max-w-3xl">
    <!-- Marquee banner -->
    <div class="overflow-hidden mb-12 -mx-6 md:-mx-12 reveal">
      <div class="flex whitespace-nowrap animate-marquee-cat">
        {[...Array(4)].map(() => (
          <span class="text-3xl md:text-7xl font-extrabold mx-8">
            <span class="text-white">Frequently Asked Questions</span>
            <span class="text-accent-red ml-8">Frequently Asked Questions</span>
          </span>
        ))}
      </div>
    </div>

    <!-- Category tabs -->
    {hasCategories && (
      <div class="flex flex-wrap gap-2 mb-10 reveal" id="faq-cat-tabs">
        <button
          class="faq-cat-tab active"
          data-faq-cat="all"
        >
          All
        </button>
        {categories.map((cat) => (
          <button
            class="faq-cat-tab"
            data-faq-cat={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    )}

    <!-- Accordion -->
    <div class="space-y-0 divide-y divide-white/10" id="faq-cat-list">
      {items.map((item, index) => (
        <div class="faq-cat-item reveal" data-faq-category={item.category || ''}>
          <button
            class="w-full flex items-center justify-between py-6 text-left group"
            data-faq-cat-toggle={index}
          >
            <span class="text-base md:text-lg font-medium pr-8 group-hover:text-accent-red transition-colors">
              {item.question}
            </span>
            <span class="flex-shrink-0 w-8 h-8 rounded-full border border-white/30 flex items-center justify-center transition-transform" data-faq-cat-icon={index}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" class="faq-cat-vertical" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </button>
          <div class="faq-cat-content hidden pb-6" data-faq-cat-content={index}>
            <p class="text-white/60 text-base leading-relaxed" set:html={item.answer} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee-cat {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee-cat {
    animation: marquee-cat 20s linear infinite;
  }

  /* Tab styles */
  .faq-cat-tab {
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }
  .faq-cat-tab:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: rgba(255, 255, 255, 0.8);
  }
  .faq-cat-tab.active {
    background: #FB4141;
    border-color: #FB4141;
    color: #fff;
  }

  /* Accordion open states */
  .faq-cat-item.open .faq-cat-vertical {
    display: none;
  }
  .faq-cat-item.open [data-faq-cat-icon] {
    transform: rotate(0deg);
  }
  .faq-cat-item.open button span:first-child {
    color: #FB4141;
  }

  /* Filter animation */
  .faq-cat-item {
    transition: opacity 0.25s ease, max-height 0.3s ease;
    overflow: hidden;
  }
  .faq-cat-item.faq-hidden {
    display: none;
  }
</style>

<script>
  // Category filtering
  const tabs = document.querySelectorAll('.faq-cat-tab');
  const items = document.querySelectorAll('.faq-cat-item');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const category = tab.getAttribute('data-faq-cat');

      // Update active tab
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      // Close all open items
      document.querySelectorAll('.faq-cat-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-cat-item').forEach(i => i.classList.remove('open'));

      // Filter items
      items.forEach((item) => {
        const itemCat = item.getAttribute('data-faq-category');
        if (category === 'all' || itemCat === category) {
          item.classList.remove('faq-hidden');
        } else {
          item.classList.add('faq-hidden');
        }
      });
    });
  });

  // Accordion toggle
  document.querySelectorAll('[data-faq-cat-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-faq-cat-toggle');
      const content = document.querySelector(`[data-faq-cat-content="${index}"]`);
      const item = btn.closest('.faq-cat-item');
      if (content && item) {
        const isOpen = !content.classList.contains('hidden');
        // Close all
        document.querySelectorAll('.faq-cat-content').forEach(c => c.classList.add('hidden'));
        document.querySelectorAll('.faq-cat-item').forEach(i => i.classList.remove('open'));
        // Open this one if it was closed
        if (!isOpen) {
          content.classList.remove('hidden');
          item.classList.add('open');
        }
      }
    });
  });
</script>
