---
interface ChallengePlan {
  tierLabel: string;
  tierName: string;
  price: string;
  currency?: string;
  features: string[];
  highlightFeatures?: string[];
  badge?: string;
  ctaText: string;
  ctaHref: string;
  variant: 'dark' | 'light';
}

interface Props {
  eyebrow?: string;
  headline: string;
  subtitle: string;
  plans: ChallengePlan[];
}

const { eyebrow, headline, subtitle, plans } = Astro.props;
---

<section class="section-dark px-6 pt-16 pb-16 md:px-[5%] md:pt-28 md:pb-20 lg:px-[10%]" id="pricing">
  <div class="pc-wrap">

    <header class="pc-header reveal">
      {eyebrow && <div class="pc-eyebrow">{eyebrow}</div>}
      <h2 class="pc-title" set:html={headline} />
      <p class="pc-sub" set:html={subtitle} />
    </header>

    <div class="pc-grid">
      {plans.map((plan) => {
        const isPro = plan.variant === 'light';
        const hasHighlights = plan.highlightFeatures && plan.highlightFeatures.length > 0;

        return (
          <article class={`pc-card ${isPro ? 'pc-card--pro' : ''} reveal`}>
            {plan.badge && <span class="pc-badge">{plan.badge}</span>}
            <div class="pc-tier-label">{plan.tierLabel}</div>
            <h3 class="pc-tier-name" set:html={plan.tierName} />

            <div class="pc-price-row">
              <span class="pc-price">{plan.price}<span class="pc-cur">{plan.currency ?? '€'}</span></span>
            </div>

            <ul class="pc-feats">
              {plan.features.map((f) => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span set:html={f} />
                </li>
              ))}
              {hasHighlights && <li class="pc-split" aria-hidden="true" />}
              {plan.highlightFeatures?.map((f) => (
                <li class="pc-hot">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span set:html={f} />
                </li>
              ))}
            </ul>

            <a
              href={plan.ctaHref}
              target="_blank"
              rel="noopener noreferrer"
              class="pc-cta"
            >
              {plan.ctaText} <span class="pc-arrow">→</span>
            </a>
          </article>
        );
      })}
    </div>

  </div>
</section>

<style>
  .pc-wrap {
    max-width: 880px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .pc-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .pc-eyebrow {
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 16px;
  }

  .pc-title {
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin: 0 0 14px;
    color: #fff;
  }
  .pc-title :global(em) {
    font-style: italic;
    font-weight: 500;
    color: rgba(255,255,255,.85);
  }
  .pc-title :global(.grad) {
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .pc-sub {
    font-size: 1rem;
    color: rgba(255,255,255,.62);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* ── Grid ── */
  .pc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    align-items: stretch;
  }

  @media (max-width: 680px) {
    .pc-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ── */
  .pc-card {
    position: relative;
    border-radius: 18px;
    padding: 32px 28px 26px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,.08);
    background: #0e0e0e;
    transition: border-color .25s ease;
  }
  .pc-card:hover { border-color: rgba(255,255,255,.16); }

  .pc-card--pro {
    background: #fafafa;
    color: #070219;
    border: 1px solid rgba(0,0,0,.06);
    box-shadow: 0 20px 50px rgba(221,51,51,.10);
  }
  .pc-card--pro:hover { border-color: rgba(0,0,0,.14); }

  /* ── Badge ── */
  .pc-badge {
    position: absolute;
    top: -11px;
    right: 20px;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    background: #DD3333;
    color: #fff;
    padding: 6px 12px;
    border-radius: 999px;
    box-shadow: 0 6px 18px rgba(221,51,51,.45);
  }

  /* ── Tier label ── */
  .pc-tier-label {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 8px;
  }
  .pc-card--pro .pc-tier-label { color: #BA1616; }

  /* ── Tier name ── */
  .pc-tier-name {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
  }
  .pc-tier-name :global(.accent) {
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ── Price ── */
  .pc-price-row { margin-bottom: 22px; }
  .pc-price {
    font-size: 2.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pc-cur {
    font-size: 1.4rem;
    font-weight: 700;
    opacity: .6;
    margin-left: 2px;
  }

  /* ── Features ── */
  .pc-feats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .pc-feats li {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 12px;
    align-items: flex-start;
    font-size: .95rem;
    line-height: 1.5;
    color: rgba(255,255,255,.78);
  }
  .pc-card--pro .pc-feats li { color: rgba(7,2,25,.82); }

  .pc-feats svg {
    width: 14px;
    height: 14px;
    margin-top: 5px;
    color: #DD3333;
    flex-shrink: 0;
  }
  .pc-card--pro .pc-feats svg { color: #BA1616; }

  /* Separator */
  .pc-split {
    display: block !important;
    grid-template-columns: none;
    height: 1px;
    background: rgba(7,2,25,.12);
    margin: 4px 0 0;
  }

  /* Exclusive features */
  .pc-hot {
    color: #BA1616 !important;
    font-weight: 600;
  }
  .pc-hot svg { color: #BA1616 !important; }

  /* ── CTA ── */
  .pc-cta {
    margin-top: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 18px;
    border-radius: 10px;
    background: #DD3333;
    color: #fff;
    font-weight: 700;
    font-size: .95rem;
    letter-spacing: .01em;
    text-decoration: none;
    transition: all .2s ease;
  }
  .pc-cta:hover {
    background: #FB4141;
    box-shadow: 0 10px 28px rgba(221,51,51,.4);
  }
  .pc-arrow { transition: transform .2s ease; }
  .pc-cta:hover .pc-arrow { transform: translateX(3px); }
</style>

<script>
  document.querySelectorAll('.pc-cta').forEach((el) => {
    el.addEventListener('click', () => {
      if (window.zaraz) zaraz.track('InitiateCheckout');
    });
  });
</script>
