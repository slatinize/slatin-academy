---
interface DayItem {
  day: number;
  genre: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  days: DayItem[];
  note?: string;
}

const { sectionTitle, days } = Astro.props;

const genreColors: Record<string, string> = {
  "Techno Melódico": "#DD3333",
  "EDM": "#E8734A",
  "Urbano": "#ED8E00",
  "Rock": "#FB4141",
  "Pop": "#D4882B",
};

// Assign bento sizes: big(5), med(4), sm(3) — pattern: big, med, sm, sm, big, med
const bentoSizes = ["big", "med", "sm", "sm", "big", "med"];
---

<section class="ws section-dark section-padding" id="semana" style="position:relative;">
  <div class="section-grid" aria-hidden="true"></div>
  <div class="container-content" style="position:relative;z-index:1;">
    <div class="ws__header reveal">
      <!-- Animated connector from HowItWorks -->
      <div class="ws__connector" aria-hidden="true">
        <div class="ws__connector-line">
          <div class="ws__connector-dot"></div>
        </div>
        <span class="ws__connector-label">05 días</span>
      </div>

      <h2 class="ws__title">
        <span class="ws__title-la">La</span>
        <span class="ws__title-semana">{sectionTitle.replace('La ', '')}</span>
      </h2>
    </div>

    <div class="bento">
      {days.map((d, i) => {
        const color = genreColors[d.genre] || "#DD3333";
        const size = bentoSizes[i] ?? "med";
        const num = String(d.day).padStart(2, "0");
        return (
          <div class={`bento-card ${size} reveal`} style={`--bc:${color}`}>
            <div class="bento-bg-num">{num}</div>
            <div class="bento-content">
              <div class="bento-day">Día {d.day}</div>
              <div class="bento-genre">{d.genre}</div>
              <p class="bento-desc">{d.description}</p>
            </div>
          </div>
        );
      })}

      <!-- Días 6 & 7 — Feedback card -->
      <div class="bento-card med feedback-card reveal">
        <div class="bento-bg-num feedback-nums"><span class="fn-num">6</span><span class="fn-amp">&amp;</span><span class="fn-num">7</span></div>
        <div class="bento-content">
          <div class="bento-day">Días 6 &amp; 7</div>
          <div class="bento-genre">Feedback en vivo</div>
          <p class="bento-desc">Revisión de masters y cierre de la semana con la comunidad.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Reduce padding — tighten gap from sections above/below */
  .ws {
    padding-top: 2rem !important;
    padding-bottom: 2rem !important;
  }
  @media (min-width: 768px) {
    .ws {
      padding-top: 3.5rem !important;
      padding-bottom: 2rem !important;
    }
  }

  /* Header */
  .ws__header {
    margin-bottom: 3rem;
    margin-top: 10%;
    text-align: center;
  }

  /* ── Connector ── */
  .ws__connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 2.5rem;
  }

  .ws__connector-line {
    width: 1px;
    height: 72px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.08), rgba(221,51,51,0.5), rgba(237,142,0,0.3));
    position: relative;
  }

  .ws__connector-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ED8E00, #DD3333);
    box-shadow: 0 0 10px rgba(237,142,0,0.7), 0 0 24px rgba(221,51,51,0.35);
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    top: 0;
    animation: flow-down 2.2s ease-in-out infinite;
  }

  @keyframes flow-down {
    0%   { top: 0;            opacity: 0;   }
    15%  { opacity: 1;                      }
    85%  { opacity: 1;                      }
    100% { top: calc(100% - 7px); opacity: 0; }
  }

  .ws__connector-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.22);
  }

  .ws__title {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25em;
    line-height: 1;
  }

  .ws__title-la {
    font-size: clamp(3.5rem, 7vw, 7rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ws__title-semana {
    font-size: clamp(3.5rem, 7vw, 7rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 260px;
    gap: 12px;
  }

  .bento-card {
    border-radius: 20px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background: linear-gradient(145deg, color-mix(in srgb, var(--bc) 12%, #050505), color-mix(in srgb, var(--bc) 6%, #050505));
    border: 1px solid color-mix(in srgb, var(--bc) 20%, transparent);
  }

  .bento-card:hover {
    transform: scale(1.015);
    box-shadow: 0 24px 60px color-mix(in srgb, var(--bc) 20%, transparent);
  }

  .bento-card.big { grid-column: span 5; }
  .bento-card.med { grid-column: span 4; }
  .bento-card.sm  { grid-column: span 3; }

  .feedback-card {
    --bc: #DD3333;
  }

  .bento-bg-num {
    position: absolute;
    top: -10px;
    right: 16px;
    font-size: 9rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
    color: #fff;
    opacity: 0.07;
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .feedback-nums {
    display: flex;
    align-items: flex-end;
    gap: 0.05em;
    white-space: nowrap;
    line-height: 1;
  }
  .fn-num {
    font-size: 8rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
  }
  .fn-amp {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1;
    opacity: 0.55;
    margin-bottom: 0.6rem;
    margin-right: -0.18em;
  }

  .bento-content {
    position: relative;
    z-index: 1;
  }

  .bento-day {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bc);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .bento-day::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--bc);
    flex-shrink: 0;
  }

  .bento-genre {
    font-size: clamp(1.1rem, 1.8vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 10px;
    color: #fff;
  }

  .bento-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .feedback-emoji {
    font-size: 2.4rem;
    line-height: 1;
    margin-bottom: 10px;
  }

  /* Tablet: 2 equal cols */
  @media (max-width: 900px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    .bento-card.big,
    .bento-card.med,
    .bento-card.sm { grid-column: span 1; }
  }

  /* Mobile: single col */
  @media (max-width: 520px) {
    .bento { grid-template-columns: 1fr; grid-auto-rows: 180px; gap: 10px; }
    .bento-card.big,
    .bento-card.med,
    .bento-card.sm { grid-column: span 1; }
    .bento-bg-num { font-size: 6rem; }
    .fn-num { font-size: 5rem; }
    .fn-amp { font-size: 2rem; }
  }
</style>
