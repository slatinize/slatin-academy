---
interface DayItem {
  day: number;
  genre: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  days: DayItem[];
  note?: string;
}

const { sectionTitle, days } = Astro.props;

const genreColors: Record<string, string> = {
  "Techno Melódico": "#DD3333",
  "EDM": "#E8734A",
  "Urbano": "#ED8E00",
  "Rock": "#FB4141",
  "Pop": "#D4882B",
};

// Assign bento sizes: big(5), med(4), sm(3) — pattern: big, med, sm, sm, big, med
const bentoSizes = ["big", "med", "sm", "sm", "big", "med"];
---

<section class="ws section-dark section-padding" id="semana">
  <div class="container-content">
    <div class="text-center mb-12 md:mb-16 reveal">
      <h2 class="text-heading">{sectionTitle}</h2>
    </div>

    <div class="bento">
      {days.map((d, i) => {
        const color = genreColors[d.genre] || "#DD3333";
        const size = bentoSizes[i] ?? "med";
        const num = String(d.day).padStart(2, "0");
        return (
          <div class={`bento-card ${size} reveal`} style={`--bc:${color}`}>
            <div class="bento-bg-num">{num}</div>
            <div class="bento-content">
              <div class="bento-day">Día {d.day}</div>
              <div class="bento-genre">{d.genre}</div>
              <p class="bento-desc">{d.description}</p>
            </div>
          </div>
        );
      })}

      <!-- Días 6 & 7 — Feedback card -->
      <div class="bento-card med feedback-card reveal">
        <div class="bento-bg-num feedback-nums">06 07</div>
        <div class="bento-content">
          <div class="bento-day">Días 6 &amp; 7</div>
          <div class="feedback-emoji">🎧</div>
          <div class="bento-genre">Feedback en vivo</div>
          <p class="bento-desc">Revisión de masters y cierre de la semana con la comunidad.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 12px;
  }

  .bento-card {
    border-radius: 20px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 220px;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background: linear-gradient(145deg, color-mix(in srgb, var(--bc) 12%, #050505), color-mix(in srgb, var(--bc) 6%, #050505));
    border: 1px solid color-mix(in srgb, var(--bc) 20%, transparent);
  }

  .bento-card:hover {
    transform: scale(1.015);
    box-shadow: 0 24px 60px color-mix(in srgb, var(--bc) 20%, transparent);
  }

  .bento-card.big  { grid-column: span 5; min-height: 280px; }
  .bento-card.med  { grid-column: span 4; }
  .bento-card.sm   { grid-column: span 3; }

  .feedback-card {
    --bc: #DD3333;
  }

  .bento-bg-num {
    position: absolute;
    top: -10px;
    right: 16px;
    font-size: 9rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
    color: #fff;
    opacity: 0.07;
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .feedback-nums {
    font-size: 6rem;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .bento-content {
    position: relative;
    z-index: 1;
  }

  .bento-day {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bc);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .bento-day::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--bc);
    flex-shrink: 0;
  }

  .bento-genre {
    font-size: clamp(1.1rem, 1.8vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 10px;
    color: #fff;
  }

  .bento-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.6;
  }

  .feedback-emoji {
    font-size: 2.4rem;
    line-height: 1;
    margin-bottom: 10px;
  }

  /* Tablet: simplify to 2 cols */
  @media (max-width: 900px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento-card.big,
    .bento-card.med,
    .bento-card.sm { grid-column: span 1; min-height: 180px; }
  }

  /* Mobile: single col */
  @media (max-width: 520px) {
    .bento { grid-template-columns: 1fr; gap: 10px; }
    .bento-card.big,
    .bento-card.med,
    .bento-card.sm { grid-column: span 1; min-height: 160px; }
    .bento-bg-num { font-size: 6rem; }
    .feedback-nums { font-size: 4rem; }
  }
</style>
