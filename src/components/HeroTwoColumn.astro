---
/**
 * HeroTwoColumn — Two-column hero matching slatin.pro/microdynamics
 * Badge above grid, title LEFT aligns with subtitle RIGHT at top
 * Background: animated noise pattern + grid lines (grid applied at wrapper level)
 */
interface Props {
  badgeText?: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  buttonGap?: string;
  titleSize?: string;
  subtitleSize?: string;
  badgeTopMargin?: string;
  gridRatio?: string;
  fullHeight?: boolean;
}

const { badgeText = 'Course', title, subtitle, ctaText, ctaHref = '#pricing', secondaryCtaText, secondaryCtaHref, buttonGap, titleSize, subtitleSize, badgeTopMargin, gridRatio, fullHeight = false } = Astro.props;
---

<section class={`hero-section relative flex text-white overflow-hidden ${fullHeight ? 'items-center pt-28 pb-10 hero-full' : 'items-center pt-28 md:pt-52 pb-10'}`}>
  <div class="w-full px-6 md:px-[4%] lg:px-[9%] relative z-10">
    {badgeText && (
      <span class="inline-block text-white font-medium mb-6" style={`background: #DD3333; padding: 8.5px 17px; border-radius: 20px; font-size: 17px; letter-spacing: -0.34px; line-height: 17px;${badgeTopMargin ? ` margin-top: ${badgeTopMargin};` : ''}`}>
        {badgeText}
      </span>
    )}
    <div class="hero-grid gap-8 lg:gap-16 items-center" style={`--hero-ratio: ${gridRatio || '1.2fr 1fr'};`}>
      <!-- Left column: title -->
      <div>
        <h1 class="hero-title leading-[1.05] font-medium" style={titleSize ? `font-size: ${titleSize}` : undefined} set:html={title} />
      </div>

      <!-- Right column: subtitle + CTA -->
      {subtitle && (
        <div class="flex flex-col justify-start pt-6 md:pt-10">
          <p class={`${subtitleSize || 'text-base md:text-lg'} text-white leading-relaxed`} set:html={subtitle} />
          {(ctaText || secondaryCtaText) && (
            <div class="hero-ctas mt-8" style={`gap: ${buttonGap || '1rem'};`}>
              {ctaText && (
                <a href={ctaHref} class="hero-cta-primary">
                  <span>{ctaText}</span>
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                    <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
              {secondaryCtaText && (
                <a href={secondaryCtaHref} class="hero-cta-outline">
                  <span>{secondaryCtaText}</span>
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
                    <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
  }
  .hero-title {
    font-size: clamp(3rem, 7.5vw, 8rem);
    font-weight: 600;
    line-height: 1.05;
  }
  .hero-section {
    min-height: auto;
  }
  @media (min-width: 768px) {
    .hero-grid {
      grid-template-columns: var(--hero-ratio, 1.2fr 1fr);
    }
    .hero-section {
      min-height: calc(100vh - 300px);
    }
    .hero-full {
      min-height: 100vh;
    }
  }
  .hero-ctas {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .hero-ctas {
      flex-direction: row;
    }
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 20px 36px;
    border-radius: 14px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 0.875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    box-shadow:
      0 10px 30px rgba(221, 51, 51, 0.3),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    cursor: pointer;
  }
  .hero-cta-primary:hover,
  .hero-cta-primary:focus-visible {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    box-shadow:
      0 16px 50px rgba(221, 51, 51, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.10);
    transform: translateY(-2px);
    outline: none;
  }
  .hero-cta-primary:active { transform: translateY(0); }

  .hero-cta-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 20px 32px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 14px;
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .hero-cta-outline:hover,
  .hero-cta-outline:focus-visible {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
    outline: none;
  }

  @media (max-width: 640px) {
    .hero-cta-primary,
    .hero-cta-outline {
      width: 100%;
      padding: 20px 24px;
    }
  }
</style>
