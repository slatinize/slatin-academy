---
/**
 * HeroTwoColumn — Two-column hero matching slatin.pro/microdynamics
 * Left: badge + title with squiggle
 * Right: subtitle + outlined CTA
 * Background: dark with subtle vertical grid lines
 */
interface Props {
  badgeText?: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { badgeText = 'Course', title, subtitle, ctaText, ctaHref = '#pricing' } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-end section-dark overflow-hidden pt-28 pb-24">
  <!-- Grid line pattern overlay -->
  <div class="hero-grid-lines absolute inset-0 z-0"></div>

  <div class="container-content px-6 md:px-12 lg:px-20 relative z-10">
    <div class="grid md:grid-cols-[1.1fr_1fr] gap-10 lg:gap-20 items-end">
      <!-- Left column: badge + title -->
      <div>
        {badgeText && (
          <span class="inline-block bg-accent-red text-white text-sm font-semibold px-5 py-2 rounded-full mb-8">
            {badgeText}
          </span>
        )}
        <h1 class="text-display leading-[1.05]" set:html={title} />
      </div>

      <!-- Right column: subtitle + CTA -->
      {subtitle && (
        <div class="flex flex-col justify-end pb-2">
          <p class="text-base md:text-lg text-white leading-relaxed" set:html={subtitle} />
          {ctaText && (
            <div class="mt-10">
              <a href={ctaHref} class="hero-cta-outline">
                {ctaText}
              </a>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-grid-lines {
    background-image:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.07) 0px,
        rgba(255, 255, 255, 0.07) 1px,
        transparent 1px,
        transparent
      );
    background-size: calc(100% / 5) 100%;
  }

  .hero-cta-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    border: 2px solid rgba(221, 51, 51, 0.6);
    color: white;
    font-weight: 600;
    font-size: 1.05rem;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .hero-cta-outline:hover {
    border-color: rgba(221, 51, 51, 1);
    background: rgba(221, 51, 51, 0.1);
  }
</style>
