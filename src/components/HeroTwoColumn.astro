---
/**
 * HeroTwoColumn — Two-column hero matching slatin.pro/microdynamics
 * Badge above grid, title LEFT aligns with subtitle RIGHT at top
 * Background: animated noise pattern + grid lines (grid applied at wrapper level)
 */
interface Props {
  badgeText?: string;
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { badgeText = 'Course', title, subtitle, ctaText, ctaHref = '#pricing' } = Astro.props;
---

<section class="hero-section relative flex items-center text-white overflow-hidden pt-28 md:pt-32 pb-10">
  <div class="w-full px-6 md:px-[4%] lg:px-[9%] relative z-10">
    {badgeText && (
      <span class="inline-block text-white font-medium mb-6" style="background: #DD3333; padding: 8.5px 17px; border-radius: 20px; font-size: 17px; letter-spacing: -0.34px; line-height: 17px;">
        {badgeText}
      </span>
    )}
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-8 lg:gap-16 items-start">
      <!-- Left column: title -->
      <div>
        <h1 class="text-display leading-[1.05] font-medium" set:html={title} />
      </div>

      <!-- Right column: subtitle + CTA -->
      {subtitle && (
        <div class="flex flex-col justify-start pt-1">
          <p class="text-base md:text-lg text-white leading-relaxed" set:html={subtitle} />
          {ctaText && (
            <div class="mt-8">
              <a href={ctaHref} class="hero-cta-outline">
                {ctaText}
              </a>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: auto;
  }
  @media (min-width: 768px) {
    .hero-section {
      min-height: calc(100vh - 300px);
    }
  }
  .hero-cta-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    border: 2px solid rgba(221, 51, 51, 0.6);
    color: white;
    font-weight: 600;
    font-size: 1.05rem;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .hero-cta-outline:hover {
    border-color: rgba(221, 51, 51, 1);
    background: rgba(221, 51, 51, 0.1);
  }
</style>
