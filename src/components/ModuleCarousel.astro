---
interface Module {
  title: string;
  moduleNumber: string;
  topics: string[];
  imageSrc?: string;
}

interface Props {
  modules: Module[];
}

const { modules } = Astro.props;
---

<section class="bg-cream">
  <!-- Navigation arrows -->
  <div class="flex justify-center gap-4 py-10">
    <button id="module-prev" class="w-10 h-10 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 transition-colors" aria-label="Previous module">
      <svg class="w-4 h-4 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button id="module-next" class="w-10 h-10 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 transition-colors" aria-label="Next module">
      <svg class="w-4 h-4 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <!-- Module cards grid - full width, no padding -->
  <div class="module-grid" id="module-track">
    {modules.map((mod) => (
      <div class="module-card relative overflow-hidden group cursor-pointer">
        <!-- Background image or dark fallback -->
        <div class="absolute inset-0 bg-dark-card">
          {mod.imageSrc && (
            <img src={mod.imageSrc} alt={mod.title} class="w-full h-full object-cover transition-opacity duration-500" loading="lazy" />
          )}
        </div>
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <!-- Content -->
        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
          <h3 class="text-2xl md:text-3xl font-bold text-white leading-tight">{mod.title}</h3>
          <p class="text-sm text-white/50 mt-2 uppercase tracking-wider">{mod.moduleNumber}</p>
          <!-- Topics - visible on hover -->
          {mod.topics && mod.topics.length > 0 && (
            <ul class="module-topics mt-4 space-y-1">
              {mod.topics.map((topic) => (
                <li class="text-sm text-white/80 leading-relaxed">+ {topic}</li>
              ))}
            </ul>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .module-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    width: 100%;
  }

  .module-card {
    aspect-ratio: 4 / 3;
  }

  .module-topics {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.5s ease, opacity 0.4s ease;
  }

  .module-card:hover .module-topics {
    max-height: 300px;
    opacity: 1;
  }

  @media (max-width: 768px) {
    .module-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .module-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  const grid = document.getElementById('module-track');
  const prev = document.getElementById('module-prev');
  const next = document.getElementById('module-next');

  prev?.addEventListener('click', () => {
    grid?.scrollBy({ left: -window.innerWidth, behavior: 'smooth' });
  });
  next?.addEventListener('click', () => {
    grid?.scrollBy({ left: window.innerWidth, behavior: 'smooth' });
  });
</script>
