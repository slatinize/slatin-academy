---
interface Module {
  title: string;
  moduleNumber: string;
  topics: string[];
  imageSrc?: string;
}

interface Props {
  modules: Module[];
}

const { modules } = Astro.props;
---

<section class="section-cream section-padding overflow-hidden">
  <div class="container-content">
    <!-- Navigation arrows -->
    <div class="flex justify-center gap-4 mb-10">
      <button id="module-prev" class="w-10 h-10 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 transition-colors" aria-label="Previous module">
        <svg class="w-4 h-4 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="module-next" class="w-10 h-10 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 transition-colors" aria-label="Next module">
        <svg class="w-4 h-4 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Module cards -->
    <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" id="module-track">
      {modules.map((mod) => (
        <div class="flex-shrink-0 w-[350px] md:w-[420px] snap-center relative rounded-xl overflow-hidden group cursor-pointer aspect-[4/3]">
          <!-- Background image or dark fallback -->
          <div class="absolute inset-0 bg-dark-card">
            {mod.imageSrc && (
              <img src={mod.imageSrc} alt={mod.title} class="w-full h-full object-cover opacity-60 group-hover:opacity-80 transition-opacity" loading="lazy" />
            )}
          </div>
          <!-- Gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
          <!-- Content -->
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <h3 class="text-2xl md:text-3xl font-bold text-white leading-tight">{mod.title}</h3>
            <p class="text-sm text-white/50 mt-2 uppercase tracking-wider">{mod.moduleNumber}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const track = document.getElementById('module-track');
  const prev = document.getElementById('module-prev');
  const next = document.getElementById('module-next');
  const scrollAmount = 440;

  prev?.addEventListener('click', () => {
    track?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });
  next?.addEventListener('click', () => {
    track?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });
</script>
