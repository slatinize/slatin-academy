---
interface IconFeature {
  title: string;
  description: string;
}

interface Props {
  sectionTitle?: string;
  subtitle?: string;
  features: IconFeature[];
  variant?: 'dark' | 'cream';
}

const { sectionTitle, subtitle, features, variant = 'cream' } = Astro.props;
const sectionClass = variant === 'cream' ? 'section-cream' : 'section-dark';
---

<section class={`${sectionClass} section-padding`} style="padding-bottom: 4.5rem;">
  <div class="container-content">
    <div class="grid md:grid-cols-[1fr_2fr] gap-10 md:gap-16 items-start">
      <!-- Left heading -->
      <div class="reveal">
        {sectionTitle && <h2 class="text-heading">{sectionTitle}</h2>}
        {subtitle && <p class="mt-3 text-base md:text-lg opacity-70">{subtitle}</p>}
      </div>

      <!-- Right cards -->
      <div class="grid sm:grid-cols-3 gap-6 reveal">
        {features.map((feature) => (
          <div class="text-center sm:text-left">
            <div class="w-16 h-16 rounded-full bg-accent-red flex items-center justify-center mx-auto sm:mx-0 mb-4">
              <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor">
                <rect x="2" y="6" width="2" height="12" rx="1" />
                <rect x="6" y="3" width="2" height="18" rx="1" />
                <rect x="10" y="8" width="2" height="8" rx="1" />
                <rect x="14" y="4" width="2" height="16" rx="1" />
                <rect x="18" y="6" width="2" height="12" rx="1" />
              </svg>
            </div>
            <p class={`text-base md:text-lg leading-relaxed ${variant === 'cream' ? 'text-text-dark/80' : 'text-white/70'}`}>
              <Fragment set:html={feature.description} />
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
