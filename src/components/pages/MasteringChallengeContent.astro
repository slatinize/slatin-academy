---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroChallenge from '../HeroChallenge.astro';
import MarqueeBanner from '../MarqueeBanner.astro';
import ProblemStatement from '../ProblemStatement.astro';
import HowItWorks from '../HowItWorks.astro';
import WeekSchedule from '../WeekSchedule.astro';
import LearnSplit from '../LearnSplit.astro';
import MentorIntro from '../MentorIntro.astro';
import LogoBar from '../LogoBar.astro';
import PricingDuo from '../PricingDuo.astro';
import Credits from '../Credits.astro';
import Sorteos from '../Sorteos.astro';
import TestimonialSlider from '../TestimonialSlider.astro';
import FAQ from '../FAQ.astro';
import ClosingCTA from '../ClosingCTA.astro';

import LanguageBanner from '../LanguageBanner.astro';
import GoogleReviews from '../GoogleReviews.astro';
import type { Locale } from '../../utils/i18n';
import type { Feature, FaqItem } from '../../data/types';

interface Props {
  lang: Locale;
  meta: { title: string; description: string; ogImage?: string };
  hero: {
    eyebrow?: string;
    headline: string;
    subtitle: string;
    ctaText: string;
    ctaHref: string;
    backgroundImage: string;
    countdownTarget: string;
    alumni: { src: string; alt?: string }[];
    proofText?: string;
    pills?: { number: string; label: string }[];
  };
  marquee: { text: string };
  problems: {
    eyebrow?: string;
    headline: string;
    items: { icon: string; title: string; description: string }[];
    closing?: string;
  };
  howItWorks: {
    sectionTitle: string;
    steps: { number: string; title: string; description: string; tag?: string }[];
  };
  weekSchedule: {
    sectionTitle: string;
    days: { day: number; genre: string; description: string }[];
    note?: string;
  };
  learn: {
    sectionTitle: string;
    features: Feature[];
  };
  about: {
    tagline: string;
    name: string;
    nameAccent: string;
    bio: string;
    stats: { value: string; label: string; highlight?: boolean }[];
  };
  pricing: {
    eyebrow?: string;
    headline: string;
    subtitle: string;
    plans: any[];
  };
  sorteos: {
    sectionTitle: string;
    items: { icon: string; title: string; description: string }[];
  };
  testimonials: {
    sectionTitle: string;
    slides: { quote: string; name: string; role: string; avatar: string }[];
  };
  faqItems: FaqItem[];
  closing: {
    kicker?: string;
    headline: string;
    ctaText: string;
    ctaHref: string;
  };
}

const {
  lang, meta, hero, marquee, problems, howItWorks, weekSchedule,
  learn, about, pricing, whyDifferent, sorteos, testimonials,
  faqItems, closing, modal,
} = Astro.props;
---

<BaseLayout title={meta.title} description={meta.description} ogImage={meta.ogImage} lang={lang}>
  <!-- Language notice for non-Spanish speakers -->
  <LanguageBanner
    message="This event is in Spanish only — all sessions, materials, and community interactions."
    dismissLabel="Got it"
  />

  <!-- 1. Hero with countdown -->
  <HeroChallenge
    eyebrow={hero.eyebrow}
    headline={hero.headline}
    subtitle={hero.subtitle}
    ctaText={hero.ctaText}
    ctaHref={hero.ctaHref}
    backgroundImage={hero.backgroundImage}
    countdownTarget={hero.countdownTarget}
    alumni={hero.alumni}
    proofText={hero.proofText}
    pills={hero.pills}
    videoLabel="Ver video"
    videoId="mMNVWPlg6sM"
  />

  {hero.eyebrow && (
    <div class="eyebrow-badge">
      <span class="eyebrow-badge__pulse" aria-hidden="true"></span>
      {hero.eyebrow}
    </div>
  )}

  <!-- 2. Marquee divider -->
  <MarqueeBanner text={marquee.text} speed="60s" />

  <!-- 3. Slatin bio -->
  <MentorIntro
    tagline={about.tagline}
    name={about.name}
    nameAccent={about.nameAccent}
    bio={about.bio}
    imageSrc="/images/slatin-sofa.jpg"
    logosSrc="/images/mentoring/logos-white.png"
    stats={about.stats}
  />

  <!-- 4. Problem statement -->
  <ProblemStatement
    eyebrow={problems.eyebrow}
    headline={problems.headline}
    items={problems.items}
    closing={problems.closing}
  />

  <!-- 4. How it works -->
  <HowItWorks
    sectionTitle={howItWorks.sectionTitle}
    steps={howItWorks.steps}
  />

  <!-- 5. Week schedule -->
  <WeekSchedule
    sectionTitle={weekSchedule.sectionTitle}
    days={weekSchedule.days}
    note={weekSchedule.note}
  />

  <!-- 6. Giveaways -->
  <Sorteos
    sectionTitle={sorteos.sectionTitle}
    items={sorteos.items}
  />

  <!-- 7. What you'll learn -->
  <LearnSplit
    sectionTitle={learn.sectionTitle}
    features={learn.features}
  />

  <!-- 8. Google Reviews -->
  <GoogleReviews lang="es" />

  <!-- 8. Analog gear photo -->
  <div class="gear-shot">
    <div class="gear-shot__inner">
      <img src="/images/analog-gear.jpg" alt="Analog mastering equipment" loading="lazy" />
      <div class="gear-shot__vignette" aria-hidden="true"></div>
    </div>
  </div>

  <!-- 9b. Credits -->
  <Credits />

  <!-- 9. Pricing -->
  <PricingDuo
    eyebrow={pricing.eyebrow}
    headline={pricing.headline}
    subtitle={pricing.subtitle}
    plans={pricing.plans}
  />

  <!-- 11. Testimonials -->
  <TestimonialSlider
    sectionTitle={testimonials.sectionTitle}
    slides={testimonials.slides}
    autoplayInterval={4000}
  />

  <!-- 13. FAQ -->
  <FAQ items={faqItems} lang={lang} />

  <!-- 14. Closing CTA -->
  <ClosingCTA
    kicker={closing.kicker}
    headline={closing.headline}
    ctaText={closing.ctaText}
    ctaHref={closing.ctaHref}
    countdownTarget={hero.countdownTarget}
  />

</BaseLayout>

<style>
  .eyebrow-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #DD3333;
    padding: 66px 0 2px;
    background: #020202;
  }

  .eyebrow-badge__pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #DD3333;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  /* ── Gear shot ── */
  .gear-shot {
    background: #020202;
    padding: 0 7%;
    padding-bottom: 0;
  }

  .gear-shot__inner {
    position: relative;
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    border-radius: 16px 16px 0 0;
  }

  .gear-shot__inner img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: center 40%;
    display: block;
    filter: brightness(0.82) contrast(1.05) saturate(0.9);
  }

  .gear-shot__vignette {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(2,2,2,0.35) 0%, transparent 30%, transparent 65%, rgba(2,2,2,0.85) 100%),
      linear-gradient(to right, rgba(2,2,2,0.25) 0%, transparent 20%, transparent 80%, rgba(2,2,2,0.25) 100%);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .gear-shot {
      padding: 0 4%;
    }
    .gear-shot__inner {
      max-height: 300px;
    }
    .gear-shot__inner img {
      height: 300px;
    }
  }

  /* Animated wavy underline for pricing headline */
  :global(.line-anim) {
    position: relative;
    display: inline-block;
  }
  :global(.wavy-line) {
    position: absolute;
    bottom: -12px;
    left: 0;
    width: 100%;
    height: 14px;
    overflow: visible;
    animation: wavy-float 3s ease-in-out 1.4s infinite;
  }
  :global(.wavy-line path) {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: wavy-draw 1s cubic-bezier(0.22, 1, 0.36, 1) 0.3s forwards;
  }
  @keyframes wavy-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes wavy-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-3px); }
  }
</style>

<script>
  if (window.zaraz && localStorage.getItem('slatin_cookie_consent') === 'accepted') zaraz.track('ViewContent', {
    content_name: 'Mastering Challenge', content_type: 'product',
  });
</script>

