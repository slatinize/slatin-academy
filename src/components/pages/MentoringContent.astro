---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroCinematic from '../HeroCinematic.astro';
import SplitSection from '../SplitSection.astro';
import MentorIntro from '../MentorIntro.astro';
import IntroStatement from '../IntroStatement.astro';
import FullWidthImage from '../FullWidthImage.astro';
import BackgroundQuote from '../BackgroundQuote.astro';
import TestimonialSlider from '../TestimonialSlider.astro';
import CenteredHeadline from '../CenteredHeadline.astro';
import TransformationTimeline from '../TransformationTimeline.astro';
import GoogleReviews from '../GoogleReviews.astro';
import WhatsIncluded from '../WhatsIncluded.astro';
import MarqueeBanner from '../MarqueeBanner.astro';
import FAQ from '../FAQ.astro';
import StartNowCTA from '../StartNowCTA.astro';
import type { Locale } from '../../utils/i18n';
import type { Testimonial, FaqItem } from '../../data/types';

interface Props {
  lang: Locale;
  meta: {
    title: string;
    description: string;
    keywords?: string;
    ogImage?: string;
    ogImageAlt?: string;
  };
  hero: { tagline?: string; title: string; subtitle: string; ctaText: string; ctaHref: string; subCtaText: string };
  intro: { tagline: string; name: string; nameAccent: string; bio: string; stats: { value: string; label: string; highlight?: boolean }[] };
  backgroundQuote: string;
  whatsIncluded: {
    sectionTitle: string;
    sectionSubtitle: string;
    cards: { icon: string; image?: string; beforeAfter: { before: string; after: string }; title: string; description: string; valueTag: string }[];
    extrasTitle: string;
    extras: { highlight: string; text: string }[];
  };
  outcomes: { sectionTitle: string; phases: { label: string; title: string; icon: string; color: string; items: string[] }[] };
  marquee: { text: string; subtitle: string };
  alumniTitle: string;
  testimonials: Testimonial[];
  featuredTestimonials: { quote: string; name: string; role: string; avatar: string }[];
  faqItems: FaqItem[];
}

const {
  lang, meta, hero, intro, backgroundQuote, whatsIncluded,
  outcomes, marquee, alumniTitle, featuredTestimonials, faqItems,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://academy.slatin.pro');
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const courseImage = new URL(meta.ogImage ?? '/images/hero-gear.jpg', siteUrl).toString();

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: lang === 'es' ? 'Mentoring de Mezcla y Mastering' : 'Mixing & Mastering Mentoring',
  description: meta.description,
  inLanguage: lang === 'es' ? 'es' : 'en',
  url: pageUrl,
  image: courseImage,
  provider: {
    '@type': 'Organization',
    name: 'SLATIN Academy',
    url: siteUrl.toString(),
    sameAs: ['https://slatin.pro'],
  },
  instructor: {
    '@type': 'Person',
    name: 'Ruslan Slatin',
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    inLanguage: lang === 'es' ? 'es' : 'en',
  },
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  keywords={meta.keywords}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  ogType="product"
  lang={lang}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
  <!-- 1. Hero -->
  <HeroCinematic
    eyebrow={hero.tagline}
    headlineHtml={lang === 'es'
      ? `<span class="hero-line">Convierte Tu <strong>Música</strong> en una</span><span class="hero-line">Carrera <span class="grad">Sólida y Rentable</span></span>`
      : `<span class="hero-line">Build a <strong>Profitable Music Career</strong></span><span class="hero-line">on <span class="grad">Your Own Terms</span></span>`}
    subCopyHtml={hero.subtitle}
    ctaLabel={hero.ctaText}
    ctaHref="#decision"
    showVideoLink={true}
    lang={lang}
  />

  <!-- 2. Mentor Intro + Logos -->
  <MentorIntro
    tagline={intro.tagline}
    name={intro.name}
    nameAccent={intro.nameAccent}
    bio={intro.bio}
    imageSrc="/images/mentoring/headshot.jpg"
    logosSrc="/images/mentoring/logos-white.png"
    stats={intro.stats}
  />

  <!-- 3. Intro Statement (animated, with CTA line built in) -->
  <IntroStatement imageSrc="/images/mentoring/studio-bg.jpg" imageAlt="SLATIN Studio" lang={lang} hideImage={true} />

  <!-- 4. Google Reviews -->
  <GoogleReviews lang={lang} />

  <!-- 5. Transformation Timeline -->
  <TransformationTimeline
    sectionTitle={outcomes.sectionTitle}
    phases={outcomes.phases}
  />

  <!-- 5. What's Included (cards → "Start Today" marquee → extras vault) -->
  <WhatsIncluded
    sectionTitle={whatsIncluded.sectionTitle}
    sectionSubtitle={whatsIncluded.sectionSubtitle}
    cards={whatsIncluded.cards}
    extrasTitle={whatsIncluded.extrasTitle}
    extras={whatsIncluded.extras}
    lang={lang}
  >
    <MarqueeBanner
      slot="between"
      text={marquee.text}
      id="getaccess"
    />
  </WhatsIncluded>

  <!-- 7. Start Now CTA -->
  <StartNowCTA
    id="decision"
    href={hero.ctaHref}
    eyebrow={marquee.subtitle}
    ctaLabel={hero.ctaText}
    lang={lang}
  />

  <!-- 8. Real Results — slidable testimonials -->
  <TestimonialSlider
    sectionTitle={alumniTitle}
    slides={featuredTestimonials}
    autoplayInterval={1500}
  />

  <!-- 9. FAQ -->
  <FAQ items={faqItems} lang={lang} />
</BaseLayout>

<script>
  if (window.zaraz && localStorage.getItem('slatin_cookie_consent') === 'accepted') zaraz.track('ViewContent', {
    content_name: 'Mentoring', content_type: 'product',
  });
</script>
