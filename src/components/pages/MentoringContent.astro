---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimatedGradient from '../AnimatedGradient.astro';
import HeroCentered from '../HeroCentered.astro';
import SplitSection from '../SplitSection.astro';
import MentorIntro from '../MentorIntro.astro';
import FullWidthImage from '../FullWidthImage.astro';
import BackgroundQuote from '../BackgroundQuote.astro';
import TestimonialCarousel from '../TestimonialCarousel.astro';
import CenteredHeadline from '../CenteredHeadline.astro';
import TransformationTimeline from '../TransformationTimeline.astro';
import MarqueeBanner from '../MarqueeBanner.astro';
import PricingDuo from '../PricingDuo.astro';
import TabbedTestimonials from '../TabbedTestimonials.astro';
import FAQ from '../FAQ.astro';
import type { Locale } from '../../utils/i18n';
import type { Testimonial, FaqItem, FeatureCard, PricingPlan, AlumniTestimonial } from '../../data/types';

interface Props {
  lang: Locale;
  meta: { title: string; description: string };
  hero: { tagline?: string; title: string; subtitle: string; ctaText: string; ctaHref: string; subCtaText: string };
  intro: { tagline: string; name: string; nameAccent: string; bio: string; stats: { value: string; label: string; highlight?: boolean }[] };
  backgroundQuote: string;
  whatsIncluded: string;
  extras: { title: string; lines: string[] };
  outcomes: { sectionTitle: string; phases: { label: string; title: string; icon: string; color: string; items: string[] }[] };
  marquee: { text: string; subtitle: string };
  alumniTitle: string;
  testimonials: Testimonial[];
  featureCards: FeatureCard[];
  pricingPlans: PricingPlan[];
  alumniTestimonials: AlumniTestimonial[];
  faqItems: FaqItem[];
}

const {
  lang, meta, hero, intro, backgroundQuote, whatsIncluded, extras,
  outcomes, marquee, alumniTitle, testimonials, featureCards,
  pricingPlans, alumniTestimonials, faqItems,
} = Astro.props;
---

<BaseLayout title={meta.title} description={meta.description} lang={lang}>
  <!-- 1. Hero -->
  <div class="section-dark relative">
    <div class="absolute inset-0 z-0" style="width: 100%; height: 100%; -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%); mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%);">
      <AnimatedGradient color1="#DD3333" color2="#1a0000" speed={1300} blendingMode="linear" />
    </div>
    <HeroCentered
      tagline={hero.tagline}
      title={hero.title}
      subtitle={hero.subtitle}
      ctaText={hero.ctaText}
      ctaHref={hero.ctaHref}
      subCtaText={hero.subCtaText}
    />
  </div>

  <!-- 2. Mentor Intro + Logos -->
  <MentorIntro
    tagline={intro.tagline}
    name={intro.name}
    nameAccent={intro.nameAccent}
    bio={intro.bio}
    imageSrc="/images/mentoring/headshot.jpg"
    logosSrc="/images/mentoring/logos-white.png"
    stats={intro.stats}
  />

  <!-- 4. Testimonial carousel -->
  <TestimonialCarousel testimonials={testimonials} />

  <!-- 5. Background quote -->
  <BackgroundQuote
    backgroundImage="/images/mentoring/studio-bg.jpg"
    quote={backgroundQuote}
  />

  <!-- 6. "What's Included?" title -->
  <section class="section-dark px-6 pt-4 pb-4 md:px-[5%] md:pt-20 md:pb-10 lg:px-[10%]">
    <div class="container-content text-center max-w-5xl mx-auto reveal">
      <h2 class="text-5xl md:text-heading" set:html={whatsIncluded} />
    </div>
  </section>

  <!-- 7. Feature cards -->
  <section class="section-dark px-[2%] pt-4 pb-4 md:pt-6 md:pb-8">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {featureCards.map((card) => (
          <div class="included-card rounded-2xl p-[2%] text-center reveal">
            <img
              src={card.iconSrc}
              alt=""
              class="w-full aspect-video object-cover rounded-xl mb-4"
              loading="lazy"
            />
            <h3 class="included-title" set:html={card.title} />
            <p class="text-white/50 text-xs md:text-sm mt-1" style="max-width: 550px; margin: 0 auto;">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .included-card {
      transition: background-color 0.35s ease;
    }
    .included-card:hover {
      background-color: #1e0000;
    }
    .included-title {
      font-size: clamp(1.2rem, 1.8vw, 1.5rem);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
  </style>

  <!-- 8. "+++ Extras" list -->
  <section class="section-dark px-6 py-2 md:px-[5%] md:py-3 lg:px-[10%] text-center">
    <div class="container-content max-w-3xl mx-auto reveal">
      <h2 class="text-4xl md:text-5xl font-bold gradient-text-red mb-5">{extras.title}</h2>
      <p class="text-white/60 text-base leading-loose">
        {extras.lines.map((line, i) => (
          <Fragment>
            <Fragment set:html={line} />
            {i < extras.lines.length - 1 && <br />}
          </Fragment>
        ))}
      </p>
    </div>
  </section>

  <!-- 9. Transformation Timeline -->
  <TransformationTimeline
    sectionTitle={outcomes.sectionTitle}
    phases={outcomes.phases}
  />

  <!-- 10. "Start Today" marquee -->
  <MarqueeBanner
    text={marquee.text}
    subtitle={marquee.subtitle}
    id="getaccess"
  />

  <!-- 11. Pricing cards -->
  <PricingDuo plans={pricingPlans} />

  <!-- 12. Alumni feedback (tabbed) -->
  <TabbedTestimonials
    title={alumniTitle}
    alumni={alumniTestimonials}
  />

  <!-- 13. FAQ -->
  <FAQ items={faqItems} lang={lang} />
</BaseLayout>
