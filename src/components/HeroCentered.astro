---
interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref: string;
  subCtaText?: string;
  tagline?: string;
  avatars?: string[];
}

const { title, subtitle, ctaText, ctaHref, subCtaText, tagline, avatars = [] } = Astro.props;
---

<section class="relative min-h-screen flex items-center justify-center text-center px-6 py-20 overflow-hidden">
  <div class="relative z-10 max-w-[900px] mx-auto">
    {tagline && (
      <p class="hero-tagline reveal">{tagline}</p>
    )}
    <h1 class="hero-title reveal" set:html={title} />
    <p class="hero-subtitle reveal" set:html={subtitle} />

    <a href={ctaHref} class="hero-cta reveal">
      {ctaText}
    </a>

    {subCtaText && (
      <p class="hero-sub-cta reveal">
        <strong set:html={subCtaText} />
      </p>
    )}

    {avatars.length > 0 && (
      <div class="flex items-center justify-center mt-8 reveal">
        <div class="flex -space-x-2">
          {avatars.map((src, i) => (
            <img
              src={src}
              alt=""
              class="w-11 h-11 rounded-full border-2 border-dark/80 object-cover ring-1 ring-white/10"
              style={`z-index: ${100 - i}`}
              loading="lazy"
            />
          ))}
          <div class="w-11 h-11 rounded-full border-2 border-dark/80 bg-dark-secondary flex items-center justify-center text-white/60 text-sm font-bold ring-1 ring-white/10">
            +
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .hero-tagline {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: clamp(2.7rem, 5.4vw, 4.8rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.2rem;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 400;
    color: rgba(255,255,255,0.5);
    margin-bottom: 2.2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 3rem;
    background: #DD3333;
    color: white;
    font-weight: 700;
    font-size: clamp(0.9rem, 1.2vw, 1rem);
    letter-spacing: 0.06em;
    border-radius: 0.5rem;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .hero-cta:hover {
    background: #FB4141;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(221, 51, 51, 0.35);
  }

  .hero-cta:active {
    transform: translateY(0);
  }

  .hero-sub-cta {
    font-size: clamp(0.75rem, 0.9vw, 0.85rem);
    margin-top: 1rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.05em;
  }
</style>
