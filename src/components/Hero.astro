---
import AnimatedGradient from './AnimatedGradient.astro';

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
  gradientColor1?: string;
  gradientColor2?: string;
  gradientSpeed?: number;
}

const { title, subtitle, ctaText, ctaHref = '#pricing', secondaryCtaText, secondaryCtaHref, gradientColor1 = '#ff6363', gradientColor2 = '#ff0008', gradientSpeed = 1300 } = Astro.props;
---

<section class="relative min-h-screen flex items-center section-dark overflow-hidden pt-20">
  <!-- Animated gradient background -->
  <div class="absolute inset-0 z-0">
    <AnimatedGradient
      color1={gradientColor1}
      color2={gradientColor2}
      speed={gradientSpeed}
    />
  </div>

  <div class="container-content px-6 md:px-12 lg:px-20 relative z-10">
    {subtitle && (
      <span class="inline-block text-white font-medium mb-6" style="background: #DD3333; padding: 8.5px 17px; border-radius: 20px; font-size: 17px; letter-spacing: -0.34px; line-height: 17px;">
        Course
      </span>
    )}
    <h1 class="text-display max-w-4xl" set:html={title} />
    {subtitle && (
      <p class="text-lg md:text-xl text-white/70 mt-6 max-w-2xl">{subtitle}</p>
    )}

    <div class="flex flex-wrap gap-4 mt-10">
      {ctaText && (
        <a href={ctaHref} class="btn-primary">
          {ctaText}
        </a>
      )}
      {secondaryCtaText && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="btn-outline">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5,3 19,12 5,21" />
          </svg>
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
</section>
