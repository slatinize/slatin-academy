---
import LiquidEther from './LiquidEther.astro';

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const { title, subtitle, ctaText, ctaHref = '#pricing', secondaryCtaText, secondaryCtaHref } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center section-dark overflow-hidden pt-20">
  <!-- Fluid simulation background -->
  <div class="absolute inset-0 z-0">
    <LiquidEther
      colors={['#5C2800', '#B84A1C', '#DD3333', '#FB4141']}
      mouseForce={30}
      cursorSize={160}
      autoDemo={true}
      autoSpeed={0.18}
      autoIntensity={3.5}
      autoResumeDelay={500}
      autoRampDuration={0.3}
      resolution={0.5}
      BFECC={true}
    />
  </div>

  <div class="container-content px-6 md:px-12 lg:px-20 relative z-10">
    {subtitle && (
      <p class="text-sm md:text-base font-semibold tracking-widest uppercase text-white/60 mb-4">
        Course
      </p>
    )}
    <h1 class="text-display max-w-4xl" set:html={title} />
    {subtitle && (
      <p class="text-lg md:text-xl text-white/70 mt-6 max-w-2xl">{subtitle}</p>
    )}

    <div class="flex flex-wrap gap-4 mt-10">
      {ctaText && (
        <a href={ctaHref} class="btn-primary">
          {ctaText}
        </a>
      )}
      {secondaryCtaText && secondaryCtaHref && (
        <a href={secondaryCtaHref} class="btn-outline">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <polygon points="5,3 19,12 5,21" />
          </svg>
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
</section>
