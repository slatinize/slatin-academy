---
interface Tier {
  label: string;
  price: string;
}

interface Props {
  tiers: Tier[];
  fields: {
    name: string;
    email: string;
    experience: string;
    experienceOptions: string[];
  };
  submitText: string;
  successMessage: string;
}

const { tiers, fields, submitText, successMessage } = Astro.props;
---

<div class="rm" id="reserve-modal" aria-hidden="true">
  <div class="rm__backdrop"></div>
  <div class="rm__dialog" role="dialog" aria-modal="true" aria-label="Reservar plaza">
    <button class="rm__close" type="button" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <!-- Form state -->
    <div class="rm__form-state">
      <h3 class="rm__title">Reservar plaza</h3>

      <!-- Tier picker -->
      <div class="rm__tiers">
        {tiers.map((tier, i) => (
          <label class="rm__tier">
            <input type="radio" name="tier" value={String(i + 1)} checked={i === 0} />
            <span class="rm__tier-inner">
              <span class="rm__tier-label">{tier.label}</span>
              <span class="rm__tier-price">{tier.price}</span>
            </span>
          </label>
        ))}
      </div>

      <!-- Fields -->
      <div class="rm__fields">
        <div class="rm__field">
          <label for="rm-name">{fields.name}</label>
          <input type="text" id="rm-name" required />
        </div>
        <div class="rm__field">
          <label for="rm-email">{fields.email}</label>
          <input type="email" id="rm-email" required />
        </div>
        <div class="rm__field">
          <label for="rm-experience">{fields.experience}</label>
          <select id="rm-experience" required>
            <option value="" disabled selected>Selecciona una opción</option>
            {fields.experienceOptions.map((opt) => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>
      </div>

      <button class="rm__submit" type="button">{submitText}</button>
    </div>

    <!-- Success state -->
    <div class="rm__success-state" style="display:none">
      <div class="rm__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="#DD3333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <p class="rm__success-text">{successMessage}</p>
    </div>
  </div>
</div>

<style>
  .rm {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .rm.open {
    opacity: 1;
    visibility: visible;
  }

  .rm__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .rm__dialog {
    position: relative;
    width: 100%;
    max-width: 480px;
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 40px 32px;
    transform: translateY(16px);
    transition: transform 0.3s ease;
  }

  .rm.open .rm__dialog {
    transform: translateY(0);
  }

  .rm__close {
    position: absolute;
    top: 16px; right: 16px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    padding: 4px;
    transition: color 0.2s;
  }
  .rm__close:hover { color: #fff; }

  .rm__title {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 24px;
    text-align: center;
  }

  /* Tier picker */
  .rm__tiers {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
  }

  .rm__tier {
    cursor: pointer;
  }

  .rm__tier input {
    display: none;
  }

  .rm__tier-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    transition: border-color 0.2s, background 0.2s;
  }

  .rm__tier input:checked + .rm__tier-inner {
    border-color: #DD3333;
    background: rgba(221,51,51,0.08);
  }

  .rm__tier-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  .rm__tier-price {
    font-size: 0.9rem;
    font-weight: 800;
    color: #fff;
  }

  /* Fields */
  .rm__fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }

  .rm__field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 6px;
  }

  .rm__field input,
  .rm__field select {
    width: 100%;
    padding: 12px 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    color: #fff;
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }

  .rm__field input:focus,
  .rm__field select:focus {
    border-color: #DD3333;
  }

  .rm__field select {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path d='M1 1l5 5 5-5' fill='none' stroke='rgba(255,255,255,0.4)' stroke-width='1.5' stroke-linecap='round'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }

  .rm__field select option {
    background: #111;
    color: #fff;
  }

  /* Submit */
  .rm__submit {
    width: 100%;
    padding: 16px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .rm__submit:hover {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(221,51,51,0.35);
  }

  /* Success */
  .rm__success-state {
    text-align: center;
    padding: 24px 0;
  }

  .rm__check {
    margin-bottom: 20px;
  }

  .rm__success-text {
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    max-width: 360px;
    margin: 0 auto;
  }

  @media (max-width: 480px) {
    .rm__dialog {
      padding: 32px 20px;
    }
  }
</style>

<script>
  function initReserveModal() {
    const modal = document.getElementById('reserve-modal');
    if (!modal) return;

    const backdrop = modal.querySelector('.rm__backdrop');
    const closeBtn = modal.querySelector('.rm__close');
    const submitBtn = modal.querySelector('.rm__submit');
    const formState = modal.querySelector('.rm__form-state') as HTMLElement;
    const successState = modal.querySelector('.rm__success-state') as HTMLElement;

    function open() {
      modal!.classList.add('open');
      modal!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      modal!.classList.remove('open');
      modal!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Reset to form after closing
      setTimeout(() => {
        if (formState) formState.style.display = '';
        if (successState) successState.style.display = 'none';
      }, 300);
    }

    // Open triggers
    document.querySelectorAll('[data-open-modal]').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    // Close triggers
    backdrop?.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal!.classList.contains('open')) close();
    });

    // Submit → success
    submitBtn?.addEventListener('click', () => {
      if (formState) formState.style.display = 'none';
      if (successState) successState.style.display = '';
    });
  }

  initReserveModal();
</script>
