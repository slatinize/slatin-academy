---
interface Props {
  variant?: 'dark' | 'cream';
  imagePosition?: 'left' | 'right';
  imageSrc?: string;
  imageAlt?: string;
  videoSrc?: string;
  alignTop?: boolean;
  fullBleed?: boolean;
  imageObjectPosition?: string;
  imageClass?: string;
}

const {
  variant = 'dark',
  imagePosition = 'right',
  imageSrc,
  imageAlt = '',
  videoSrc,
  alignTop = false,
  fullBleed = false,
  imageObjectPosition,
  imageClass,
} = Astro.props;

const sectionClass = variant === 'cream' ? 'section-cream' : 'section-dark';
const hasMedia = imageSrc || videoSrc;
const isVideoMedia = !!videoSrc;
const useFullBleed = isVideoMedia || fullBleed;
---

{useFullBleed ? (
  <!-- Full-bleed split: media fills entire column edge-to-edge -->
  <section class={`${sectionClass} relative overflow-hidden`}>
    <div class="split-video-grid grid md:grid-cols-2">
      <!-- Text column -->
      <div class={`flex items-center justify-center ${imagePosition === 'left' ? 'md:order-last' : ''}`}>
        <div class="px-6 py-10 md:p-[15%] reveal">
          <slot />
        </div>
      </div>
      <!-- Media column — full bleed -->
      <div class={`relative min-h-[250px] md:min-h-0 ${imagePosition === 'left' ? 'md:order-first' : ''}`}>
        {isVideoMedia ? (
          <video
            autoplay
            muted
            loop
            playsinline
            class="absolute inset-0 w-full h-full object-cover"
          >
            <source src={videoSrc} type="video/mp4" />
          </video>
        ) : (
          <img
            src={imageSrc}
            alt={imageAlt}
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
          />
        )}
      </div>
    </div>
  </section>
) : (
  <!-- Image split: standard layout with padding -->
  <section class={`${sectionClass} section-padding-split`}>
    <div class="container-content">
      <div class={`grid md:grid-cols-2 gap-10 md:gap-16 ${alignTop ? 'items-start' : 'items-center'}`}>
        <div class="reveal">
          <slot />
        </div>
        {imageSrc && (
          <div class={`${imagePosition === 'left' ? 'md:order-first' : ''} reveal ${imageClass?.includes('rounded-full') ? 'split-img-wrap-circle' : 'split-img-wrap'}`}>
            <img
              src={imageSrc}
              alt={imageAlt}
              class={`${imageClass?.includes('rounded-full') ? 'split-img-circle' : 'split-img rounded-xl'} shadow-2xl ${imageClass || ''}`}
              style={imageObjectPosition ? `object-position: ${imageObjectPosition}` : ''}
              loading="lazy"
            />
          </div>
        )}
      </div>
    </div>
  </section>
)}

<style>
  .split-img-wrap {
    overflow: hidden;
    border-radius: 0.75rem;
  }

  .split-img-wrap-circle {
    display: flex;
    justify-content: center;
  }

  .split-img-circle {
    width: 350px;
    height: 350px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
  }

  .split-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    object-position: center;
  }

  @media (min-width: 768px) {
    .split-img {
      height: 330px;
    }
  }

  @media (min-width: 768px) {
    .split-video-grid {
      min-height: 550px;
    }
  }
</style>
