---
interface Props {
  videoId: string;
  platform?: 'vimeo' | 'youtube';
  title?: string;
  thumbnailSrc?: string;
  standalone?: boolean;
}

const { videoId, platform = 'vimeo', title = 'Video', thumbnailSrc, standalone = true } = Astro.props;

const defaultThumb = platform === 'youtube'
  ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
  : undefined;
const thumbnail = thumbnailSrc || defaultThumb;

const embedUrl = platform === 'youtube'
  ? `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`
  : `https://player.vimeo.com/video/${videoId}?autoplay=1&title=0&byline=0&portrait=0`;
---

{standalone ? (
  <section class="section-dark section-padding" id="video">
    <div class="container-content">
      <div class="relative aspect-video rounded-2xl overflow-hidden bg-dark-card group cursor-pointer" data-video-id={videoId} data-embed-url={embedUrl}>
        {thumbnail ? (
          <img src={thumbnail} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-dark-card to-dark-secondary"></div>
        )}
        <div class="absolute inset-0" style="background: linear-gradient(90deg, #000000 0%, #3a3a3a 100%); opacity: 0.8;"></div>
        <div class="absolute inset-0 flex items-center justify-center transition-colors">
          <div class="flex items-center gap-4 group-hover:scale-105 transition-transform">
            <div class="play-btn w-12 h-12 md:w-14 md:h-14 rounded-full bg-accent-red flex items-center justify-center shadow-lg">
              <svg class="w-5 h-5 md:w-6 md:h-6 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5,3 19,12 5,21" />
              </svg>
            </div>
            {title && (
              <span class="text-base md:text-lg font-bold text-white">{title}</span>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
) : (
  <div class="px-6 md:px-[4%] lg:px-[7%] mt-6 pb-10 relative z-10" id="video">
    <div class="container-content">
      <div class="relative aspect-video rounded-2xl overflow-hidden bg-dark-card group cursor-pointer" data-video-id={videoId} data-embed-url={embedUrl}>
        {thumbnail ? (
          <img src={thumbnail} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-dark-card to-dark-secondary"></div>
        )}
        <div class="absolute inset-0" style="background: linear-gradient(90deg, #000000 0%, #3a3a3a 100%); opacity: 0.8;"></div>
        <div class="absolute inset-0 flex items-center justify-center transition-colors">
          <div class="flex items-center gap-4 group-hover:scale-105 transition-transform">
            <div class="play-btn w-12 h-12 md:w-14 md:h-14 rounded-full bg-accent-red flex items-center justify-center shadow-lg">
              <svg class="w-5 h-5 md:w-6 md:h-6 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5,3 19,12 5,21" />
              </svg>
            </div>
            {title && (
              <span class="text-base md:text-lg font-bold text-white">{title}</span>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
)}

<script>
  document.querySelectorAll('[data-video-id]').forEach((el) => {
    el.addEventListener('click', function() {
      const embedUrl = this.getAttribute('data-embed-url');
      this.innerHTML = `<iframe src="${embedUrl}" class="w-full h-full absolute inset-0" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen" allowfullscreen></iframe>`;
    });
  });
</script>

<style>
  .play-btn {
    position: relative;
  }
  .play-btn::before,
  .play-btn::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    animation: pulse-ring 2.6s cubic-bezier(0.25, 0.9, 0.2, 1) 0.4s infinite;
  }
  .play-btn::after {
    animation-delay: 0.8s;
  }
  @keyframes pulse-ring {
    0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    100% { transform: translate(-50%, -50%) scale(1.7); opacity: 0; }
  }
</style>
