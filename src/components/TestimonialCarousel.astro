---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  featured?: boolean;
  avatar?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
// Double the array for seamless infinite loop
const doubled = [...testimonials, ...testimonials];
---

<section class="section-dark py-16 lg:py-28 overflow-hidden" id="testimonials">
  <!-- Marquee wrapper with alpha mask -->
  <div class="testimonial-marquee relative">
    <!-- Alpha fade masks on edges -->
    <div class="marquee-track flex gap-6" style="will-change: transform;">
      {doubled.map((t) => (
        <div class="testimonial-card flex-shrink-0 w-[340px] md:w-[400px] rounded-2xl border border-white/[0.06] bg-dark-card p-8 flex flex-col justify-between">
          <!-- Quote icon -->
          <div>
            <svg class="w-8 h-8 mb-5 text-accent-red opacity-70" viewBox="0 0 24 24" fill="currentColor">
              <path d="M11 7.05C7.28 7.56 4.5 10.59 4.5 14.25c0 2.07 1.68 3.75 3.75 3.75S12 16.32 12 14.25c0-1.81-1.29-3.32-3-3.67 0-1.86 1.37-3.44 3.18-3.7L11 7.05zm7 0C14.28 7.56 11.5 10.59 11.5 14.25c0 2.07 1.68 3.75 3.75 3.75S19 16.32 19 14.25c0-1.81-1.29-3.32-3-3.67 0-1.86 1.37-3.44 3.18-3.7L18 7.05z"/>
            </svg>
            <p class="text-[15px] leading-relaxed text-white/80">{t.quote}</p>
          </div>
          <!-- Divider + attribution -->
          <div class="mt-6">
            <div class="h-px bg-white/[0.08] mb-5"></div>
            <div class="flex items-center gap-3">
              {t.avatar ? (
                <img src={t.avatar} alt={t.name} class="w-10 h-10 rounded-full object-cover flex-shrink-0" loading="lazy" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
                  {t.name.charAt(0)}
                </div>
              )}
              <div>
                <p class="text-white font-semibold text-sm">{t.name}</p>
                <p class="text-cream/40 text-xs">{t.role}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-marquee {
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  .marquee-track {
    animation: marquee-scroll 60s linear infinite;
    width: max-content;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .testimonial-card {
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .testimonial-card:hover {
    border-color: rgba(251, 65, 65, 0.2);
    box-shadow: 0 0 30px rgba(251, 65, 65, 0.06);
  }
</style>
