---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  featured?: boolean;
  avatar?: string;
}

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
const featuredIndex = testimonials.findIndex((t) => t.featured);
const initialIndex = featuredIndex >= 0 ? featuredIndex : 0;
---

<section class="section-cream section-padding overflow-hidden" id="testimonials">
  <div class="max-w-[1400px] mx-auto">
    <!-- Carousel viewport -->
    <div class="testimonial-carousel relative" data-initial={initialIndex}>
      <!-- Cards container -->
      <div class="testimonial-stage relative min-h-[360px] md:min-h-[320px]">
        {testimonials.map((t, i) => (
          <div
            class="testimonial-card absolute top-0 left-0 w-[85vw] max-w-[560px] cursor-pointer"
            data-index={i}
          >
            <!-- Speech bubble -->
            <div class="relative rounded-2xl px-8 py-8 md:px-10 md:py-10 transition-all duration-500 ease-out">
              <span class="text-5xl font-black leading-none select-none opacity-25 block mb-2">&ldquo;</span>
              <p class="text-[15px] md:text-base leading-relaxed">{t.quote}</p>
              <!-- Triangle pointer -->
              <div class="bubble-arrow absolute left-1/2 -translate-x-1/2 -bottom-3 w-6 h-6 rotate-45 transition-colors duration-500"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- Avatars row -->
      <div class="testimonial-avatars flex items-end justify-center gap-0 mt-8 relative h-[100px]">
        {testimonials.map((t, i) => (
          <div
            class="testimonial-avatar absolute flex flex-col items-center cursor-pointer transition-all duration-500 ease-out"
            data-avatar-index={i}
          >
            <div class="avatar-circle rounded-full flex items-center justify-center font-bold text-white bg-text-dark/80 transition-all duration-500 overflow-hidden">
              {t.avatar ? (
                <img src={t.avatar} alt={t.name} class="w-full h-full object-cover" loading="lazy" />
              ) : (
                t.name.charAt(0)
              )}
            </div>
            <p class="font-bold text-sm mt-2 whitespace-nowrap transition-opacity duration-500">{t.name}</p>
            <p class="text-xs text-text-dark/50 whitespace-nowrap transition-opacity duration-500">{t.role}</p>
          </div>
        ))}
      </div>

      <!-- Navigation arrows -->
      <div class="flex justify-center gap-4 mt-8">
        <button class="testimonial-prev w-12 h-12 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 hover:bg-text-dark/5 transition-all duration-200" aria-label="Previous testimonial">
          <svg class="w-5 h-5 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="testimonial-next w-12 h-12 rounded-full border-2 border-text-dark/20 flex items-center justify-center hover:border-text-dark/60 hover:bg-text-dark/5 transition-all duration-200" aria-label="Next testimonial">
          <svg class="w-5 h-5 text-text-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-card > div {
    background: rgba(255, 255, 255, 0.5);
    color: var(--color-text-dark, #070219);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }

  .testimonial-card > div .bubble-arrow {
    background: rgba(255, 255, 255, 0.5);
    border-right: 1px solid rgba(0, 0, 0, 0.05);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .testimonial-card.active > div {
    background: #FB4141;
    color: #fff;
    border-color: transparent;
    box-shadow: 0 25px 60px -12px rgba(251, 65, 65, 0.35);
  }

  .testimonial-card.active > div .bubble-arrow {
    background: #FB4141;
    border-color: transparent;
  }

  .testimonial-card.active > div span {
    opacity: 0.3;
    color: #fff;
  }

  .testimonial-avatar .avatar-circle {
    width: 48px;
    height: 48px;
    font-size: 16px;
  }

  .testimonial-avatar.active .avatar-circle {
    width: 64px;
    height: 64px;
    font-size: 20px;
    background: #070219;
  }
</style>

<script>
  function initCarousel(container: Element) {
    const cards = Array.from(container.querySelectorAll('.testimonial-card')) as HTMLElement[];
    const avatars = Array.from(container.querySelectorAll('.testimonial-avatar')) as HTMLElement[];
    const prevBtn = container.querySelector('.testimonial-prev') as HTMLElement;
    const nextBtn = container.querySelector('.testimonial-next') as HTMLElement;
    const stage = container.querySelector('.testimonial-stage') as HTMLElement;
    const initial = parseInt(container.getAttribute('data-initial') || '0');
    const total = cards.length;
    let current = initial;

    function update() {
      const stageWidth = stage.offsetWidth;

      cards.forEach((card, i) => {
        const diff = i - current;
        card.classList.toggle('active', i === current);

        // Position cards: center the active one, offset the rest
        const cardWidth = card.offsetWidth;
        const centerX = (stageWidth - cardWidth) / 2;

        let tx: number;
        let scale: number;
        let opacity: number;
        let zIndex: number;

        if (diff === 0) {
          tx = centerX;
          scale = 1;
          opacity = 1;
          zIndex = 10;
        } else if (Math.abs(diff) === 1) {
          tx = centerX + diff * (cardWidth * 0.65);
          scale = 0.85;
          opacity = 0.4;
          zIndex = 5;
        } else {
          tx = centerX + diff * (cardWidth * 0.65);
          scale = 0.75;
          opacity = 0;
          zIndex = 1;
        }

        card.style.transform = `translateX(${tx}px) scale(${scale})`;
        card.style.opacity = String(opacity);
        card.style.zIndex = String(zIndex);
        card.style.pointerEvents = Math.abs(diff) <= 1 ? 'auto' : 'none';
      });

      // Position avatars similarly
      avatars.forEach((avatar, i) => {
        const diff = i - current;
        avatar.classList.toggle('active', i === current);

        let tx: number;
        let opacity: number;

        if (diff === 0) {
          tx = 0;
          opacity = 1;
        } else if (Math.abs(diff) === 1) {
          tx = diff * 180;
          opacity = 0.5;
        } else if (Math.abs(diff) === 2) {
          tx = diff * 180;
          opacity = 0.25;
        } else {
          tx = diff * 180;
          opacity = 0;
        }

        avatar.style.transform = `translateX(${tx}px)`;
        avatar.style.opacity = String(opacity);
        avatar.style.pointerEvents = Math.abs(diff) <= 2 ? 'auto' : 'none';
      });
    }

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      update();
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    // Click on side cards to navigate
    cards.forEach((card, i) => {
      card.addEventListener('click', () => {
        if (i !== current) goTo(i);
      });
    });

    // Click on avatars to navigate
    avatars.forEach((avatar, i) => {
      avatar.addEventListener('click', () => goTo(i));
    });

    // Touch/swipe support
    let startX = 0;
    let isDragging = false;

    stage.addEventListener('touchstart', (e) => {
      startX = (e as TouchEvent).touches[0].clientX;
      isDragging = true;
    }, { passive: true });

    stage.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const endX = (e as TouchEvent).changedTouches[0].clientX;
      const diff = startX - endX;
      if (Math.abs(diff) > 50) {
        goTo(current + (diff > 0 ? 1 : -1));
      }
    }, { passive: true });

    // Resize handler
    window.addEventListener('resize', update);

    // Init
    update();
  }

  document.querySelectorAll('.testimonial-carousel').forEach(initCarousel);
</script>
