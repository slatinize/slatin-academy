---
interface ListItem {
  number: string;
  text: string;
}

interface Props {
  title?: string;
  items: ListItem[];
  imageSrc?: string;
  variant?: 'dark' | 'cream';
}

const { title, items, imageSrc, variant = 'cream' } = Astro.props;
const sectionClass = variant === 'cream' ? 'section-cream' : 'section-dark';
const numColor = variant === 'cream' ? 'text-accent-orange/50' : 'text-accent-red/70';
---

<section class={`${sectionClass}`} style="padding: 3.5rem 5%; ">
  <div class="container-content">
    {title && <h2 class="text-heading text-center mb-12 reveal">{title}</h2>}
    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
      <div class="reveal">
        <div class="space-y-8">
          {items.map((item) => (
            <div class="flex gap-5 items-center">
              <span class={`text-5xl md:text-[4rem] font-extrabold ${numColor} leading-none shrink-0`} style="min-width: 5rem; display: inline-block; transform: translateY(-2px);">{item.number}</span>
              <p class={`text-base md:text-[1.2rem] leading-relaxed ${variant === 'cream' ? 'text-text-dark/80' : 'text-white/70'}`} set:html={item.text} />
            </div>
          ))}
        </div>
      </div>

      {imageSrc && (
        <div class="reveal">
          <img src={imageSrc} alt="" class="w-full rounded-xl shadow-2xl" loading="lazy" />
        </div>
      )}
    </div>
  </div>
</section>
