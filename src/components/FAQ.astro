---
interface FAQItem {
  question: string;
  answer: string;
  category?: string;
}

interface Props {
  items: FAQItem[];
  lang?: string;
}

const { items, lang = 'en' } = Astro.props;
const faqTitle = lang === 'es' ? 'Preguntas Frecuentes' : 'Frequently Asked Questions';

// Extract unique categories preserving insertion order
const categories = [...new Set(items.map(item => item.category).filter(Boolean))] as string[];
const hasCategories = categories.length > 1;

// Count items per category
const categoryCounts = hasCategories
  ? Object.fromEntries(categories.map(cat => [cat, items.filter(i => i.category === cat).length]))
  : {};
---

<section class="section-dark pt-4 pb-10 md:pt-8 md:pb-24 lg:pt-12 lg:pb-32">
  <!-- Marquee banner — full width, no horizontal padding -->
  <div class="overflow-hidden mb-16 pb-4 reveal">
    <div class="flex whitespace-nowrap animate-marquee-faq">
      {[...Array(6)].map(() => (
        <span class="text-6xl md:text-8xl lg:text-9xl font-extrabold mx-6">
          <span class="text-white">{faqTitle}</span>
          <span class="text-accent-red ml-8">{faqTitle}</span>
        </span>
      ))}
    </div>
  </div>

  <div class="px-6 md:px-[5%] lg:px-[10%]"><div class="container-content max-w-3xl">
    <!-- Category tabs (only when multiple categories exist) -->
    {hasCategories && (
      <div class="flex flex-wrap gap-2 mb-10 reveal" data-faq-tabs>
        {categories.map((cat, i) => (
          <button
            class={`faq-tab ${i === 0 ? 'active' : ''}`}
            data-faq-cat={cat}
          >
            {cat}
            <span class="faq-tab-count">{categoryCounts[cat]}</span>
          </button>
        ))}
      </div>
    )}

    <!-- Accordion -->
    <div data-faq-list>
      {items.map((item, index) => (
        <div
          class={`faq-item reveal ${hasCategories && item.category !== categories[0] ? 'faq-hidden' : ''}`}
          data-faq-category={item.category || ''}
        >
          <button
            class="w-full flex items-center justify-between py-6 text-left group"
            data-faq-toggle={index}
          >
            <span class="text-base md:text-lg font-medium pr-8 group-hover:text-accent-red transition-colors" set:html={item.question} />
            <span class="flex-shrink-0 w-8 h-8 rounded-full border border-white/30 flex items-center justify-center transition-transform" data-faq-icon={index}>
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" class="faq-vertical" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
            </span>
          </button>
          <div class="faq-content hidden pb-6" data-faq-content={index}>
            <p class="text-white/60 text-base leading-relaxed" set:html={item.answer} />
          </div>
        </div>
      ))}
    </div>
  </div></div>
</section>

<style>
  @keyframes marquee-faq {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee-faq {
    animation: marquee-faq 60s linear infinite;
    width: max-content;
  }
  /* Tab styles — matches TabbedTestimonials design language */
  .faq-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.1rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .faq-tab:hover {
    color: rgba(255, 255, 255, 0.8);
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.04);
  }
  .faq-tab.active {
    background: #DD3333;
    border-color: #DD3333;
    color: #fff;
  }
  .faq-tab-count {
    font-size: 0.7rem;
    opacity: 0.6;
  }
  .faq-tab.active .faq-tab-count {
    opacity: 0.8;
  }

  /* Item borders — manual bottom border avoids divide-y artifacts on hidden items */
  .faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Fade transition for category switching */
  [data-faq-list] {
    transition: opacity 0.15s ease;
  }
  [data-faq-list].faq-fading {
    opacity: 0;
  }

  /* Hidden items — instant, no height animation */
  .faq-item.faq-hidden {
    display: none;
  }

  /* Accordion open states */
  .faq-item.open .faq-vertical {
    display: none;
  }
  .faq-item.open [data-faq-icon] {
    transform: rotate(0deg);
  }
  .faq-item.open button span:first-child {
    color: #FB4141;
  }
</style>

<script>
  // Category filtering
  document.querySelectorAll('[data-faq-tabs]').forEach((tabContainer) => {
    const tabs = tabContainer.querySelectorAll('.faq-tab');
    const section = tabContainer.closest('section');
    if (!section) return;
    const items = section.querySelectorAll('.faq-item');

    const list = section.querySelector('[data-faq-list]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const category = tab.getAttribute('data-faq-cat');
        if (tab.classList.contains('active')) return;

        // Update active tab
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        // Fade out, swap content, fade in
        if (list) {
          list.classList.add('faq-fading');
          setTimeout(() => {
            // Close all open items
            section.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
            section.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));

            // Filter items
            items.forEach((item) => {
              const itemCat = item.getAttribute('data-faq-category');
              item.classList.toggle('faq-hidden', itemCat !== category);
            });

            list.classList.remove('faq-fading');
          }, 150);
        }
      });
    });
  });

  // Accordion toggle (scoped per section for multi-instance support)
  document.querySelectorAll('[data-faq-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = btn.getAttribute('data-faq-toggle');
      const section = btn.closest('section');
      const content = section?.querySelector(`[data-faq-content="${index}"]`);
      const item = btn.closest('.faq-item');
      if (content && item && section) {
        const isOpen = !content.classList.contains('hidden');
        // Close all within this section
        section.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
        section.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        // Open this one if it was closed
        if (!isOpen) {
          content.classList.remove('hidden');
          item.classList.add('open');
        }
      }
    });
  });
</script>
