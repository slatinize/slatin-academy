---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  impactLine?: string;
  lead?: string;
  features: Feature[];
}

const {
  sectionTitle,
  impactLine = 'Sal con criterio. No con teoría.',
  lead = '6 habilidades concretas que transforman cómo abordas un mastering para siempre.',
  features,
} = Astro.props;
---

<section class="ls section-dark section-padding">
  <!-- Grid texture -->
  <div class="section-grid" aria-hidden="true"></div>
  <!-- Ambient halos -->
  <div class="ls__halo ls__halo--a" aria-hidden="true"></div>
  <div class="ls__halo ls__halo--b" aria-hidden="true"></div>

  <div class="container-content" style="position:relative;z-index:1;">

    <!-- Header row -->
    <div class="ls__header">
      <div class="ls__header-left">
        <p class="ls__eyebrow">{sectionTitle}</p>
        <h2 class="ls__big-title" set:html={impactLine.replace('criterio', '<span class="grad">criterio</span>')} />
      </div>
      <p class="ls__lead">{lead}</p>
    </div>

  </div>
</section>

<style>
  .ls {
    background: #030303;
    position: relative;
    overflow: hidden;
    padding-top: 2.5rem !important;
    padding-bottom: 4rem !important;
  }
  @media (min-width: 768px) {
    .ls {
      padding-top: 4rem !important;
      padding-bottom: 5rem !important;
    }
  }

  /* Ambient halos */
  .ls__halo {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .ls__halo--a {
    width: 600px; height: 600px;
    top: -100px; left: -200px;
    background: radial-gradient(circle, rgba(221,51,51,0.07), transparent 70%);
  }
  .ls__halo--b {
    width: 500px; height: 500px;
    bottom: -80px; right: -100px;
    background: radial-gradient(circle, rgba(237,142,0,0.07), transparent 70%);
  }

  /* ── Header ── */
  .ls__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: end;
    margin-bottom: 0;
  }

  .ls__eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #DD3333;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ls__eyebrow::before {
    content: '';
    width: 20px;
    height: 2px;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .ls__big-title {
    font-size: clamp(2.8rem, 4.5vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: #fff;
    margin: 0;
  }
  .ls__big-title :global(.grad) {
    background: linear-gradient(135deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ls__lead {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.7;
    align-self: end;
    padding-bottom: 4px;
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .ls__header {
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 40px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 520px) {
    .ls__big-title {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }
  }
</style>
