---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  impactLine?: string;
  lead?: string;
  features: Feature[];
}

const {
  sectionTitle,
  impactLine = 'Sal haciendo másters profesionales.<br/>No acumulando teoría.',
  lead = '',
  features,
} = Astro.props;
---

<section class="ls section-dark section-padding">
  <!-- Grid texture -->
  <div class="section-grid" aria-hidden="true"></div>

  <div class="container-content" style="position:relative;z-index:1;">

    <!-- Header -->
    <div class="ls__header">
      <p class="ls__eyebrow">{sectionTitle}</p>
      <h2 class="ls__big-title" set:html={impactLine.replace('másters profesionales', '<span class="grad">másters profesionales</span>')} />
      {lead && <p class="ls__lead">{lead}</p>}
    </div>

  </div>
</section>

<style>
  .ls {
    background: #030303;
    position: relative;
    overflow: hidden;
    padding-top: 7rem !important;
    padding-bottom: 1.5rem !important;
  }
  @media (max-width: 767px) {
    .ls {
      padding-top: 4rem !important;
    }
  }
  @media (min-width: 768px) {
    .ls {
      padding-top: 10rem !important;
      padding-bottom: 2rem !important;
    }
  }


  /* ── Header ── */
  .ls__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 720px;
    margin: 0 auto;
  }

  .ls__eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #DD3333;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ls__eyebrow::before {
    content: '';
    width: 20px;
    height: 2px;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .ls__big-title {
    font-size: clamp(2.8rem, 4.5vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: #fff;
    margin: 0;
  }
  .ls__big-title :global(.grad) {
    background: linear-gradient(135deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ls__lead {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.38);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 520px) {
    .ls__big-title {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }
  }
</style>
