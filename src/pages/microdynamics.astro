---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroTwoColumn from '../components/HeroTwoColumn.astro';
import AnimatedGradient from '../components/AnimatedGradient.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import SplitSection from '../components/SplitSection.astro';
import CenteredHeadline from '../components/CenteredHeadline.astro';
import IconFeatures from '../components/IconFeatures.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import NumberedList from '../components/NumberedList.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import ModuleCarousel from '../components/ModuleCarousel.astro';
import TeacherBio from '../components/TeacherBio.astro';
import LogoBar from '../components/LogoBar.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQ from '../components/FAQ.astro';
import FullWidthImage from '../components/FullWidthImage.astro';
import { testimonials, modules, faqItems } from '../data/microdynamics';
---

<BaseLayout
  title="Advanced Microdynamics - Mixing & Mastering Course"
  description="Learn advanced microdynamic processing techniques for mixing and mastering. 4+ hours of practical video lessons by SLATIN."
>
  <!-- 1. Hero + Video (parallax wrapper with scroll spacer) -->
  <div style="margin-bottom: 15vh;">
  <div class="parallax-wrapper section-dark">
    <!-- Animated gradient background spanning hero + video -->
    <div class="absolute inset-0 z-0" style="width: 100%; height: 100%; -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%); mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%);">
      <AnimatedGradient color1="#282828" color2="#282828" speed={850} blendingMode="organic" />
    </div>
    <!-- Grid lines spanning hero + video, fading at edges -->
    <div class="parallax-grid-overlay"></div>
    <HeroTwoColumn
      badgeText="Course"
      title='Advanced <span class="squiggle">Microdynamics</span>'
      subtitle="As an experienced Producer or Mixing Engineer, you've likely mastered EQ, Compression, and Spatial effects...<br><br>Yet, there's a critical aspect many talented professionals overlook: Microdynamics."
      ctaText="Learn All About It"
      ctaHref="#pricing"
    />
    <VideoEmbed videoId="1081820388" platform="vimeo" title="The Magic of Microdynamics ✨" thumbnailSrc="https://www.slatin.pro/wp-content/uploads/2025/05/micro-scaled.jpg" standalone={false} />
  </div>
  </div>

  <!-- Remaining sections scroll over the hero+video -->
  <div class="parallax-content-over">

  <!-- 2. Intro text + 3D visualization video -->
  <SplitSection
    variant="dark"
    imagePosition="right"
    videoSrc="https://www.slatin.pro/wp-content/uploads/2025/05/3D_Insight_resized.mp4"
  >
    <p class="text-white font-medium mb-4" style="font-size: 21px; line-height: 25px;">
      Consider this: 90% of today's hit records are surprisingly simple arrangements!
    </p>
    <p class="text-white font-medium mb-4" style="font-size: 21px; line-height: 25px;">
      They don't rely on countless layers to sound impressive.<br>So, what separates these top-tier mixes from amateur productions? 🤔
    </p>
    <p class="text-white font-medium" style="font-size: 21px; line-height: 24px;">
      → Microdynamics 🏆
    </p>
  </SplitSection>

  <!-- 4. Compressor image + definition -->
  <SplitSection
    variant="dark"
    imagePosition="left"
    videoSrc="https://www.slatin.pro/wp-content/uploads/2025/05/3D_OzoneMultiband_resized.mp4"
  >
    <p class="text-white font-medium mb-4" style="font-size: 21px; line-height: 25px;">
      Microdynamic control is the precise management of transients and bodies across the entire frequency range
    </p>
    <p class="text-white font-medium mb-4" style="font-size: 21px; line-height: 25px;">
      + subtle dynamic variations within individual sounds ☝️
    </p>
    <p class="text-white font-medium" style="font-size: 21px; line-height: 25px;">
      And THIS is the least-discussed secret to achieving clarity, depth, and precise sonic definition in professional mixes 🔑
    </p>
  </SplitSection>

  <!-- 5. Centered headline -->
  <CenteredHeadline preTitle="THE HIDDEN KEY TO SONIC EXCELLENCE" variant="cream">
    The effective use of <span class="text-accent-red">Microdynamics</span> is what allows simple arrangements to captivate listeners, <span class="text-accent-red">sound polished</span>, and translate flawlessly across all playback systems.
  </CenteredHeadline>

  <!-- 6. "Does this sound familiar?" -->
  <IconFeatures
    sectionTitle="Does this sound familiar?"
    subtitle="These are common signs of insufficient microdynamic attention:"
    variant="cream"
    features={[
      {
        title: "",
        description: 'Your tracks sound "good," but not quite "finished" or world-class. Something is missing.',
      },
      {
        title: "",
        description: "You layer a ton of elements to ensure your music is dynamic and engaging.",
      },
      {
        title: "",
        description: "Your mixes have great balance, but you struggle to achieve loud and dynamic masters.",
      },
    ]}
  />

  <!-- 7. What You Will Master (2x2 grid) -->
  <FeatureGrid
    subtitle="WHAT YOU WILL MASTER"
    variant="dark"
    columns={2}
    features={[
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-6-150x150.png",
        title: "Advanced Microdynamic Processing",
        description: 'Achieve sonic precision through transient shaping, transparent "resonant body" band-focused compression, parallel dynamics, and mid-side processing.',
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-5-150x150.png",
        title: 'Get That "Analog" Sound fully ITB',
        description: 'Most top engineers work fully in the box – no outboard gear. So how do they get that "analog" feel? By understanding the microdynamic variations that analog gear adds – and knowing how to recreate them.',
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-4-150x150.png",
        title: "Mastering-Level Detail",
        description: "Deliver polished and LOUD songs through advanced mastering techniques, preserving and enhancing dynamic integrity.",
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-3-150x150.png",
        title: "Critical Listening and Analysis",
        description: "Sharpen your ability to identify and rectify subtle microdynamic issues, ensuring professional results every time.",
      },
    ]}
  />

  <!-- 8. "This course is ideal if you" numbered list -->
  <NumberedList
    title="This course is ideal if you"
    variant="cream"
    imageSrc="https://www.slatin.pro/wp-content/uploads/2025/05/Screenshot-2025-05-05-at-13.10.21-1024x624.jpg"
    items={[
      {
        number: "01",
        text: "Are already comfortable with mixing fundamentals and want the <strong>next-level refinement</strong> that distinguishes professional mixes.",
      },
      {
        number: "02",
        text: "Struggle with mixes that sound technically correct yet fail to <strong>fully translate emotionally</strong> and dynamically.",
      },
      {
        number: "03",
        text: "Want <strong>advanced techniques</strong>, demonstrated clearly, without fluff or filler.",
      },
    ]}
  />

  <!-- 9. Testimonials -->
  <TestimonialCarousel testimonials={testimonials} />

  <!-- 10. Module Carousel -->
  <ModuleCarousel modules={modules} />

  <!-- 11. Teacher Bio -->
  <TeacherBio
    name="SLATIN"
    imageSrc="https://www.slatin.pro/wp-content/uploads/2025/04/Slatin_Microdynamics.jpg"
    variant="cream"
    bio={[
      `Ruslan Slatin is an <strong>award-winning</strong> producer and <strong>sound engineer</strong> with decades of experience in the global music industry.`,
      `Celebrated for his distinctive sound and top-tier productions, he has collaborated with some of the most prestigious <strong>international labels</strong> and artists.`,
      `In addition to running a high-performing commercial mastering studio – completing over 1,000 projects annually – <strong>Ruslan</strong> is a passionate educator.`,
      `Through specialized courses and private mentoring, he empowers music producers to elevate their sound using proven and novel sound sculpting techniques.`,
    ]}
  />

  <!-- 12. Logo Bar -->
  <LogoBar
    logoSrc="https://www.slatin.pro/wp-content/uploads/2025/05/LOGOS-SLATIN-1500-%C3%97-300-px.png"
    variant="cream"
  />

  <!-- 13. "+4 Hours, All Value" -->
  <SplitSection
    variant="dark"
    imagePosition="left"
    videoSrc="https://www.slatin.pro/wp-content/uploads/2025/05/V4_Multiplicity_resized-1.mp4"
  >
    <h2 class="text-heading mb-6">
      <span class="squiggle">+4 Hours</span>, All Value
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      <strong class="text-white">Practical lessons</strong> divided into short (2–15 min) videos you can actually use in your sessions.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      Whether you're brushing up on fundamentals or tightening your workflow, it's solid info you'll go back to <strong class="text-white">more than once</strong>.
    </p>
  </SplitSection>

  <!-- 14. "Much More than a Simple Course" -->
  <SplitSection
    variant="dark"
    imagePosition="right"
    imageSrc="https://www.slatin.pro/wp-content/uploads/2025/04/AnityEUl6LpfPozJvQCWwv4KvOgMI0IuVuzqFXS6-1-1024x462.webp"
    imageAlt="SLATIN Academy community video call"
  >
    <h2 class="text-heading mb-6">
      <span class="squiggle">Much More</span> than a Simple Course
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      What sets our programs apart? The <strong class="text-white">built-in community</strong>.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      With exclusive access to our <strong class="text-white">private Discord</strong>, you're not just learning – you're connecting with other engineers, getting feedback, and growing together at your own pace.
    </p>
  </SplitSection>

  <!-- 15. "Multiple Genres" -->
  <SplitSection
    variant="dark"
    imagePosition="left"
    videoSrc="https://www.slatin.pro/wp-content/uploads/2025/05/3D_OzoneMultiband_resized.mp4"
  >
    <h2 class="text-heading mb-6">
      <span class="squiggle italic">Multiple Genres</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      From Pop & Rock to House, Techno, and Latin – everything we teach applies to <strong class="text-white">Real-World projects</strong>.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      Only the latest techniques and <strong class="text-white">up-to-date</strong> plugins, always grounded in practical examples.
    </p>
  </SplitSection>

  <!-- 16. Full-width studio photo -->
  <FullWidthImage
    src="https://www.slatin.pro/wp-content/uploads/2025/05/Advanced-Microdynamics_03.jpg"
    alt="Advanced Microdynamics course overview"
  />

  <!-- 17. Pricing -->
  <PricingCard
    subtitle="Elevate your production, mixing, and mastering skills through deep understanding of microdynamics."
    price="149€"
    features={[
      "Access to The Course (+4h)",
      "Access to Private Community",
      "Presets and Resources",
      "Bonus Modules and Videos",
      "Frequent Updates",
      "Live Q&A Sessions with SLATIN",
    ]}
    ctaText="JOIN NOW 🔑"
    ctaHref="https://learn.slatin.pro/purchase?product_id=6205122"
  />

  <!-- 18. FAQ -->
  <FAQ items={faqItems} />

  </div><!-- end parallax-content-over -->
</BaseLayout>
