---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroTwoColumn from '../components/HeroTwoColumn.astro';
import AnimatedGradient from '../components/AnimatedGradient.astro';
import SplitSection from '../components/SplitSection.astro';
import CenteredHeadline from '../components/CenteredHeadline.astro';
import IconFeatures from '../components/IconFeatures.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import NumberedList from '../components/NumberedList.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import ModuleCarousel from '../components/ModuleCarousel.astro';
import TeacherBio from '../components/TeacherBio.astro';
import LogoBar from '../components/LogoBar.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQ from '../components/FAQ.astro';
import { testimonials, modules, faqItems } from '../data/low-end-mastery';
---

<BaseLayout
  title="Low End Mastery - Kick & Bass Mixing Course"
  description="Master low-end frequencies, kick and bass relationships, and achieve loud, dynamic mixes that translate everywhere. By SLATIN."
>
  <!-- 1. Hero -->
  <div class="relative section-dark overflow-hidden" style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding-bottom: 6vh;">
    <div class="absolute inset-0 z-0">
      <AnimatedGradient color1="#ff6363" color2="#ff0008" speed={1300} />
    </div>
    <div class="relative z-10">
      <HeroTwoColumn
        badgeText="Course"
        title='Low-End<br><span class="squiggle">Mastery</span>'
        subtitle='<span style="font-size: 1.25rem; line-height: 1.6;"><strong>Struggling to get your low end right?</strong> From kick and bass chemistry to perfect translation across all systems...</span><br><br><span style="font-size: 1.05rem; line-height: 1.6; opacity: 0.8;">Acquire the techniques, tools, and ear training you need to achieve punchy, polished low-end mixes.</span>'
        ctaText="Get Full Access"
        ctaHref="#pricing"
        secondaryCtaText="See Curriculum"
        secondaryCtaHref="#modules"
      />
    </div>
  </div>

  <div class="section-dark" style="height: 3.45rem;"></div>

  <!-- 2. "Get Real Loud" -->
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="https://uploads.teachablecdn.com/attachments/BauKxvLpQYqLoxR7j01z_low+end+1+copy.jpg"
    imageAlt="StandardCLIP plugin interface for loudness"
  >
    <h2 class="text-heading mb-6">
      Get Real <span class="squiggle">Loud</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Can't hit your target LUFS without destroying your dynamics?
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      In most cases, it is a <strong class="text-white">low-end issue.</strong>
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      In this course, I'll show you exactly what it takes to achieve loud, punchy mixes that still breathe.
    </p>
    <p class="text-base md:text-lg font-bold text-accent-red">
      And it is much more than clipping and limiting... 😏
    </p>
  </SplitSection>

  <!-- 4. "Nail Your Kick & Bass" -->
  <div style="margin-top: -1.5rem;"></div>
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="https://uploads.teachablecdn.com/attachments/mQyIVU7NQEbQB6k6p4kA_sidechain.jpg"
    imageAlt="Sidechain compression and kick bass mixing"
  >
    <h2 class="text-heading mb-6">
      Nail Your <span class="squiggle">Kick & Bass</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      You probably already use sidechain.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      BUT, what if I told you that...
    </p>
    <p class="text-base md:text-lg font-semibold text-accent-red leading-relaxed mb-4">
      Sidechain is not enough... 🫣
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      ...when you're chasing that tight, punchy Kick & Bass relationship that pros obsess over.
    </p>
    <p class="text-base md:text-lg text-white font-semibold leading-relaxed">
      I'll walk you through the exact process I use on every project.
    </p>
  </SplitSection>

  <!-- 5. "Perfect Translation" -->
  <div style="margin-top: -1.5rem;"></div>
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="https://uploads.teachablecdn.com/attachments/5LOiP0Txl2oQno23I0gW_low+end.jpg"
    imageAlt="Tonal balance comparison between tracks"
  >
    <h2 class="text-heading mb-6">
      Perfect <span class="squiggle">Translation</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Sounds great in the studio but a <strong class="text-white">disaster in the car or club?</strong> 🙉
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Discover the <strong class="text-accent-red">3 keys to flawless low-end translation.</strong>
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Make your tracks hit hard on every system and keep your clients coming back.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      + Stop wasting hours on revision after revision...
    </p>
  </SplitSection>

  <!-- 6. "Mono and Wide" -->
  <div style="margin-top: -1.5rem;"></div>
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="https://uploads.teachablecdn.com/attachments/9GER2ESQpyYJYAdxuM3v_mono.jpg"
    imageAlt="Mono-compatible wide bass techniques"
  >
    <h2 class="text-heading mb-6">
      Mono and <span class="squiggle">Wide</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Think mono-compatible wide bass is impossible? <strong class="text-white">Think again.</strong>
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      Learn the exact techniques top sound designers use to craft <strong class="text-accent-red">powerful, wide, and fully mono-compatible</strong> basslines.
    </p>
  </SplitSection>

  <div class="section-dark" style="height: 3.3rem;"></div>

  <!-- 7. Headline + Pain Points (Option B) -->
  <section class="section-cream section-padding" style="padding-bottom: 1.5rem;">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="reveal">
          <span class="inline-block text-white font-medium mb-6" style="background: #DD3333; padding: 10px 20px; border-radius: 20px; font-size: 15px; letter-spacing: -0.3px; line-height: 15px;">+ 400 Happy Students ⭐️⭐️⭐️⭐️⭐️</span>
          <h2 class="text-heading">
            Your low end is the foundation, <span class="text-accent-red">everything else follows.</span>
          </h2>
        </div>
        <div class="flex flex-col gap-8 reveal">
          <div class="flex gap-5 items-start">
            <span class="text-4xl md:text-5xl font-extrabold text-accent-red leading-none min-w-[55px]">01</span>
            <p class="text-lg md:text-xl leading-relaxed opacity-80">Mixes sound <strong>muddy or thin</strong> and the low end never sits right, no matter what you try.</p>
          </div>
          <div class="flex gap-5 items-start">
            <span class="text-4xl md:text-5xl font-extrabold text-accent-red leading-none min-w-[55px]">02</span>
            <p class="text-lg md:text-xl leading-relaxed opacity-80">Tracks sound great in the studio but <strong>fall apart</strong> on other systems: car, club, or phone.</p>
          </div>
          <div class="flex gap-5 items-start">
            <span class="text-4xl md:text-5xl font-extrabold text-accent-red leading-none min-w-[55px]">03</span>
            <p class="text-lg md:text-xl leading-relaxed opacity-80">Can't get masters <strong>loud enough</strong> without the low end distorting or losing punch.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. What You Will Master (2x2 grid) -->
  <div style="margin-top: -3rem; padding-bottom: 2.5rem;">
  <FeatureGrid
    subtitle="WHAT YOU WILL MASTER"
    variant="cream"
    columns={2}
    features={[
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-6-150x150.png",
        title: "Kick & Bass Chemistry",
        description: "Learn the science behind the perfect kick and bass relationship, including dynamic phase rotation and advanced sidechain techniques.",
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-5-150x150.png",
        title: "Perfect Low-End Translation",
        description: "Discover the 3 keys to flawless low-end translation that makes your songs bang on every playback system: studio, car, or club.",
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-4-150x150.png",
        title: "Loudness Without Compromise",
        description: "Hit your target LUFS levels with punchy, club-ready mixes. It's much more than just clipping and limiting.",
      },
      {
        iconSrc: "https://www.slatin.pro/wp-content/uploads/2025/05/Ellipse-3-150x150.png",
        title: "Sound Selection & Shaping",
        description: "Master the art of selecting the right samples and shaping kicks for any genre, the foundation of 80% of your final sound.",
      },
    ]}
  />
  </div>

  <!-- 10. "This course is ideal if you" numbered list -->
  <NumberedList
    title="This course is ideal if you"
    variant="dark"
    imageSrc="https://uploads.teachablecdn.com/attachments/iduxgXajRo6h1LaC7Ahw_dQUY9H3oZvvbU7wsrJUyyvruMXwsYj8G2SdTfqv3+copy.jpg"
    items={[
      {
        number: "01",
        text: "Struggle with <strong>low-end translation</strong>: your mixes sound different on every playback system.",
      },
      {
        number: "02",
        text: "Want to understand the <strong>kick and bass relationship</strong> at a deep, professional level.",
      },
      {
        number: "03",
        text: "Need to achieve <strong>loud, punchy masters</strong> without sacrificing low-end clarity and translation.",
      },
    ]}
  />

  <!-- 11. Testimonials -->
  <div style="margin-top: -4rem; padding-bottom: 2rem;">
  <TestimonialCarousel testimonials={testimonials} />
  </div>

  <!-- 12. Module Carousel -->
  <ModuleCarousel modules={modules} />

  <!-- 13. Teacher Bio -->
  <TeacherBio
    name="SLATIN"
    imageSrc="/images/slatin-sofa.jpg"
    variant="cream"
    bgColor="#d9d4ab"
    compact
    bio={[
      `Ruslan Slatin is an <strong>award-winning</strong> producer and <strong>sound engineer</strong> with decades of experience in the global music industry.`,
      `Celebrated for his distinctive sound and top-tier productions, he has collaborated with some of the most prestigious <strong>international labels</strong> and artists.`,
      `In addition to running a high-performing commercial mastering studio, completing over 1,000 projects annually, <strong>Ruslan</strong> is a passionate educator.`,
      `Through specialized courses and private mentoring, he empowers music producers to elevate their sound using proven and novel sound sculpting techniques.`,
    ]}
    logoSrc="https://uploads.teachablecdn.com/attachments/izlXe81QyOr1dO25BGS3_YP0ovoEFDRt3h3qRWZaOeB4HCRat2ldNAkIuKstn.webp"
  />

  <!-- 14. "Save Your Time" -->
  <div class="section-dark" style="height: 2rem;"></div>
  <SplitSection
    variant="dark"
    imagePosition="right"
    imageSrc="https://uploads.teachablecdn.com/attachments/iduxgXajRo6h1LaC7Ahw_dQUY9H3oZvvbU7wsrJUyyvruMXwsYj8G2SdTfqv3+copy.jpg"
    imageAlt="Kick frequency analysis and sound selection"
  >
    <h2 class="text-heading mb-6">
      Save Your <span class="squiggle">Time</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Sound Selection is <strong class="text-white">KEY</strong> 🔑
    </p>
    <p class="text-base md:text-lg text-accent-red leading-relaxed mb-4">
      ...and it's 80% of your final sound.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      Whether you use Splice or have an extensive sample library, I'll show you how to pick the right samples and <strong class="text-white">stop second-guessing</strong>. ❌
    </p>
  </SplitSection>

  <!-- 16. "Multiple Genres" -->
  <div style="margin-top: -2.5rem;">
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="https://uploads.teachablecdn.com/attachments/aq3se6LNQkGTFfZVURXp_genre.jpg"
    imageAlt="Multiple genre examples in DAW"
  >
    <h2 class="text-heading mb-6">
      <span class="squiggle">Multiple Genres</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      Each genre has its unique way of addressing low-end frequencies.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      This course is tailored for <strong class="text-accent-red">creators of modern and loud music</strong>.
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      You'll see exactly how to handle kick and bass in <strong class="text-white">EDM, Pop/Funk, Trap, and Reggaeton</strong>.
    </p>
  </SplitSection>
  </div>

  <!-- 17. "Private Community" -->
  <div style="margin-top: -1.5rem;"></div>
  <SplitSection
    variant="dark"
    imagePosition="right"
    imageSrc="https://uploads.teachablecdn.com/attachments/Es8zQjMTzmUufKqvzLXF_ezgif.com-optimize2.gif"
    imageAlt="SLATIN Academy private community"
    alignTop
  >
    <h2 class="text-heading mb-6">
      Private <span class="squiggle">Community</span>
    </h2>
    <p class="text-base md:text-lg text-white/70 leading-relaxed mb-4">
      This is not your average video course...
    </p>
    <p class="text-base md:text-lg text-accent-red leading-relaxed mb-4">
      If you have any questions left, join the chat! 📱
    </p>
    <p class="text-base md:text-lg text-white/70 leading-relaxed">
      Share your work, <strong class="text-white">get feedback</strong> and answers to your questions, and find like-minded people.
    </p>
  </SplitSection>

  <!-- 18. Pricing -->
  <PricingCard
    subtitle="Get the kick and bass clarity, punch, and translation that your mixes have been missing."
    price="159€"
    features={[
      "Unlimited Access to The Course",
      "Access to Private Community",
      "Presets and Resources",
      "Bonus Modules and Videos",
      "Ongoing Updates",
      "Live Q&A Sessions with SLATIN",
    ]}
    ctaText="GET FULL ACCESS 🔑"
    ctaHref="https://learn.slatin.pro/purchase?product_id=5700498"
  />

  <!-- 19. FAQ -->
  <FAQ items={faqItems} />
</BaseLayout>
