---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Section Alternatives">

<!-- OPTION A: Bold statement + 3 pain-point cards -->
<section style="background-color: #f5f0e8; padding: 5rem 6%;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <p style="text-align: center; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.75rem;">OPTION A</p>

    <div style="text-align: center; margin-bottom: 3rem;">
      <p style="font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin-bottom: 1rem;">+ 400 HAPPY STUDENTS ⭐️⭐️⭐️⭐️⭐️</p>
      <h2 style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 700; line-height: 1.2; max-width: 700px; margin: 0 auto;">
        Your low end is the foundation. <span style="color: #DD3333;">Get it right, everything else follows.</span>
      </h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;">
      <div style="background: rgba(0,0,0,0.05); border-radius: 16px; padding: 2rem;">
        <div style="width: 48px; height: 48px; background: #DD3333; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Mixes sound <strong>muddy or thin</strong> and the low end never sits right, no matter what you try.</p>
      </div>
      <div style="background: rgba(0,0,0,0.05); border-radius: 16px; padding: 2rem;">
        <div style="width: 48px; height: 48px; background: #DD3333; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Tracks sound great in the studio but <strong>fall apart</strong> on other systems: car, club, or phone.</p>
      </div>
      <div style="background: rgba(0,0,0,0.05); border-radius: 16px; padding: 2rem;">
        <div style="width: 48px; height: 48px; background: #DD3333; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        </div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Can't get masters <strong>loud enough</strong> without the low end distorting or losing punch.</p>
      </div>
    </div>
  </div>
</section>

<div style="height: 3rem; background: #ddd;"></div>

<!-- OPTION B: Left-aligned headline + right side numbered pain points -->
<section style="background-color: #f5f0e8; padding: 5rem 6%;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <p style="text-align: center; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.75rem;">OPTION B</p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
      <div>
        <p style="font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin-bottom: 1rem;">+ 400 HAPPY STUDENTS ⭐️⭐️⭐️⭐️⭐️</p>
        <h2 style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 700; line-height: 1.2;">
          Your low end is the foundation. <span style="color: #DD3333;">Get it right, everything else follows.</span>
        </h2>
      </div>
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <span style="font-size: 2rem; font-weight: 800; color: #DD3333; line-height: 1; min-width: 40px;">01</span>
          <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Mixes sound <strong>muddy or thin</strong> and the low end never sits right, no matter what you try.</p>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <span style="font-size: 2rem; font-weight: 800; color: #DD3333; line-height: 1; min-width: 40px;">02</span>
          <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Tracks sound great in the studio but <strong>fall apart</strong> on other systems: car, club, or phone.</p>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <span style="font-size: 2rem; font-weight: 800; color: #DD3333; line-height: 1; min-width: 40px;">03</span>
          <p style="font-size: 1rem; line-height: 1.6; opacity: 0.8;">Can't get masters <strong>loud enough</strong> without the low end distorting or losing punch.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<div style="height: 3rem; background: #ddd;"></div>

<!-- OPTION C: Full-width dark band with stats + pain points inline -->
<section style="background-color: #1a1a1a; color: white; padding: 5rem 6%;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <p style="text-align: center; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin-bottom: 0.75rem;">OPTION C</p>

    <div style="text-align: center; margin-bottom: 3.5rem;">
      <p style="font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.4; margin-bottom: 1rem;">+ 400 HAPPY STUDENTS ⭐️⭐️⭐️⭐️⭐️</p>
      <h2 style="font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 700; line-height: 1.2; max-width: 700px; margin: 0 auto;">
        Your low end is the foundation. <span style="color: #DD3333;">Get it right, everything else follows.</span>
      </h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
      <div style="text-align: center; padding: 2rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px;">
        <div style="font-size: 3rem; margin-bottom: 0.5rem;">🔇</div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.7;">Mixes sound <strong style="color: white;">muddy or thin</strong> and the low end never sits right.</p>
      </div>
      <div style="text-align: center; padding: 2rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px;">
        <div style="font-size: 3rem; margin-bottom: 0.5rem;">📱</div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.7;">Tracks sound great in the studio but <strong style="color: white;">fall apart</strong> on other systems.</p>
      </div>
      <div style="text-align: center; padding: 2rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px;">
        <div style="font-size: 3rem; margin-bottom: 0.5rem;">📊</div>
        <p style="font-size: 1rem; line-height: 1.6; opacity: 0.7;">Can't get masters <strong style="color: white;">loud enough</strong> without distorting or losing punch.</p>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
