---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mastering Challenge - SLATIN Academy"
  description="7-day intensive mastering challenge with Ruslan Slatin. Currently available in Spanish only."
  lang="en"
>
  <section class="mc-en" aria-labelledby="mc-en-heading">
    <div class="mc-en__bg" style="background-image: url('/images/mentoring/mentor-photo.jpg')" aria-hidden="true"></div>
    <div class="mc-en__vignette" aria-hidden="true"></div>
    <div class="mc-en__halo" aria-hidden="true"></div>

    <div class="mc-en__inner">
      <h1 id="mc-en-heading" class="mc-en__heading">
        Mastering Challenge is<br/>currently in <span class="mc-en__grad">Spanish</span>
      </h1>

      <p class="mc-en__sub">
        In the meantime, check out our <strong>Mentoring program</strong> — available in English.
      </p>

      <div class="mc-en__ctas">
        <a class="mc-en__cta-primary" href="/mentoring">
          Explore Mentoring
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <a class="mc-en__cta-secondary" href="/es/mastering-challenge">
          <span class="mc-en__flag-sm" aria-hidden="true">&#x1F1EA;&#x1F1F8;</span>
          Ver en Español
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mc-en {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    isolation: isolate;
    background: #020202;
    color: #fff;
  }

  .mc-en__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) contrast(1.1) saturate(0.7);
    z-index: 0;
  }

  .mc-en__vignette {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(180deg, rgba(2,2,2,0.6) 0%, rgba(2,2,2,0.55) 50%, rgba(2,2,2,0.85) 100%),
      radial-gradient(ellipse at 50% 40%, transparent 30%, rgba(2,2,2,0.5) 100%);
  }

  .mc-en__halo {
    position: absolute;
    width: 500px; height: 500px;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(221,51,51,0.12), transparent 70%);
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
  }

  .mc-en__inner {
    position: relative; z-index: 10;
    min-height: 100vh;
    padding: clamp(120px, 14vh, 160px) clamp(24px, 8vw, 120px) clamp(80px, 10vh, 120px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 28px;
  }

  .mc-en__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    padding: 8px 18px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
  }

  .mc-en__flag { font-size: 16px; }
  .mc-en__flag-sm { font-size: 14px; }

  .mc-en__heading {
    margin: 0;
    max-width: 800px;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .mc-en__grad {
    font-weight: 800;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .mc-en__sub {
    margin: 0;
    max-width: 560px;
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    text-wrap: balance;
  }
  .mc-en__sub strong { color: #fff; font-weight: 700; }

  .mc-en__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .mc-en__cta-primary {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 22px 40px;
    border-radius: 14px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 30px rgba(221,51,51,0.3), inset 0 0 0 1px rgba(255,255,255,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .mc-en__cta-primary:hover {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    box-shadow: 0 16px 50px rgba(221,51,51,0.5), inset 0 0 0 1px rgba(255,255,255,0.10);
    transform: translateY(-2px);
  }

  .mc-en__cta-secondary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 18px 24px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    background: transparent;
    color: rgba(255,255,255,0.8);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .mc-en__cta-secondary:hover {
    background: rgba(255,255,255,0.05);
    color: #fff;
    border-color: rgba(255,255,255,0.25);
  }

  @media (max-width: 640px) {
    .mc-en__cta-primary { width: 100%; justify-content: center; padding: 20px 28px; }
    .mc-en__cta-secondary { width: 100%; justify-content: center; }
  }
</style>
