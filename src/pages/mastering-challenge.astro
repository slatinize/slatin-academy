---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mastering Challenge - SLATIN Academy"
  description="7-day intensive mastering challenge with Ruslan Slatin. Currently available in Spanish only."
  lang="en"
>
  <section class="mc-en" aria-labelledby="mc-en-heading">
    <div class="mc-en__bg" style="background-image: url('/images/mentoring/mentor-photo.jpg')" aria-hidden="true"></div>
    <div class="mc-en__vignette" aria-hidden="true"></div>
    <div class="mc-en__halo" aria-hidden="true"></div>

    <div class="mc-en__inner">
      <div class="mc-en__badge">
        <span class="mc-en__flag" aria-hidden="true">&#x1F1EA;&#x1F1F8;</span>
        Spanish only
      </div>

      <h1 id="mc-en-heading" class="mc-en__heading">
        This event is held<br/>entirely in <span class="mc-en__grad">Spanish</span>
      </h1>

      <p class="mc-en__sub">
        <strong>Mastering Challenge</strong> is a 7-day intensive with Ruslan Slatin — 5 live sessions, 5 genres, real feedback. All sessions, materials, and community interactions are in Spanish.
      </p>

      <div class="mc-en__ctas">
        <a class="mc-en__cta-primary" href="/es/mastering-challenge">
          Visit the Spanish page
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <button class="mc-en__cta-secondary" type="button" id="notify-toggle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
          Notify me for English
        </button>
      </div>

      <!-- Email capture (hidden by default) -->
      <div class="mc-en__email-form" id="notify-form" style="display:none">
        <div class="mc-en__email-inner" id="notify-form-state">
          <input type="email" id="notify-email" placeholder="your@email.com" required />
          <button type="button" class="mc-en__email-submit" id="notify-submit">Notify me</button>
        </div>
        <div class="mc-en__email-success" id="notify-success" style="display:none">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span>We'll let you know when an English edition is available.</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mc-en {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    isolation: isolate;
    background: #020202;
    color: #fff;
  }

  .mc-en__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.25) contrast(1.1) saturate(0.7);
    z-index: 0;
  }

  .mc-en__vignette {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(2,2,2,0.75) 0%,
      rgba(2,2,2,0.35) 40%,
      rgba(2,2,2,0.95) 100%
    );
  }

  .mc-en__halo {
    position: absolute;
    width: 500px; height: 500px;
    top: 20%; left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(221,51,51,0.12), transparent 70%);
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
  }

  .mc-en__inner {
    position: relative; z-index: 10;
    min-height: 100vh;
    padding: clamp(120px, 14vh, 160px) clamp(24px, 8vw, 120px) clamp(80px, 10vh, 120px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    gap: 28px;
  }

  .mc-en__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    padding: 8px 18px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
  }

  .mc-en__flag {
    font-size: 16px;
  }

  .mc-en__heading {
    margin: 0;
    max-width: 800px;
    font-size: clamp(32px, 5vw, 64px);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .mc-en__grad {
    font-weight: 800;
    background: linear-gradient(90deg, #ED8E00, #DD3333);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .mc-en__sub {
    margin: 0;
    max-width: 580px;
    font-size: 1.05rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.55);
    text-wrap: balance;
  }
  .mc-en__sub strong { color: #fff; font-weight: 700; }

  .mc-en__ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 4px;
  }

  .mc-en__cta-primary {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 22px 40px;
    border-radius: 14px;
    background: linear-gradient(180deg, #DD3333, #BA1616);
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    box-shadow: 0 10px 30px rgba(221,51,51,0.3), inset 0 0 0 1px rgba(255,255,255,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .mc-en__cta-primary:hover {
    background: linear-gradient(180deg, #FB4141, #DD3333);
    box-shadow: 0 16px 50px rgba(221,51,51,0.5), inset 0 0 0 1px rgba(255,255,255,0.10);
    transform: translateY(-2px);
  }

  .mc-en__cta-secondary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 18px 24px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    background: transparent;
    color: rgba(255,255,255,0.8);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .mc-en__cta-secondary:hover {
    background: rgba(255,255,255,0.05);
    color: #fff;
    border-color: rgba(255,255,255,0.25);
  }

  /* Email capture */
  .mc-en__email-form {
    animation: email-slide-in 0.25s ease-out;
  }

  @keyframes email-slide-in {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mc-en__email-inner {
    display: flex;
    gap: 8px;
    max-width: 420px;
  }

  .mc-en__email-inner input {
    flex: 1;
    min-width: 0;
    padding: 14px 16px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    color: #fff;
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .mc-en__email-inner input:focus {
    border-color: #DD3333;
  }
  .mc-en__email-inner input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .mc-en__email-submit {
    padding: 14px 20px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s;
  }
  .mc-en__email-submit:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.25);
  }

  .mc-en__email-success {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.7);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .mc-en__cta-primary { width: 100%; justify-content: center; padding: 20px 28px; }
    .mc-en__cta-secondary { width: 100%; justify-content: center; }
    .mc-en__email-inner { flex-direction: column; width: 100%; }
    .mc-en__email-submit { width: 100%; }
  }
</style>

<script>
  const toggleBtn = document.getElementById('notify-toggle');
  const form = document.getElementById('notify-form');
  const submitBtn = document.getElementById('notify-submit');
  const formState = document.getElementById('notify-form-state');
  const success = document.getElementById('notify-success');

  toggleBtn?.addEventListener('click', () => {
    if (form) {
      const visible = form.style.display !== 'none';
      form.style.display = visible ? 'none' : '';
      if (!visible) {
        const input = document.getElementById('notify-email') as HTMLInputElement;
        input?.focus();
      }
    }
  });

  submitBtn?.addEventListener('click', () => {
    const input = document.getElementById('notify-email') as HTMLInputElement;
    if (input && input.value && input.validity.valid) {
      if (formState) formState.style.display = 'none';
      if (success) success.style.display = '';
    }
  });
</script>
