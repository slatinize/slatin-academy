---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing Intro Options">
  <section class="section-dark" style="padding: 4rem 2rem;">
    <div style="max-width: 900px; margin: 0 auto;">

      <!-- Option A -->
      <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 3rem; margin-bottom: 3rem; text-align: center;">
        <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 1rem;">Option A — Minimal & Direct</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 1.1rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 0.5rem;">Your low end. Solved.</p>
        <h2 style="font-size: 3rem; font-weight: 800; color: white; line-height: 1.1;">Get <span style="color: #e85c5c;">Full Access</span> Today</h2>
      </div>

      <!-- Option B -->
      <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 3rem; margin-bottom: 3rem; text-align: center;">
        <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 1rem;">Option B — Stats + Urgency</p>
        <p style="color: rgba(255,255,255,0.5); font-size: 1rem; margin-bottom: 0.75rem;">7 modules. 30+ lessons. One investment.</p>
        <h2 style="font-size: 3rem; font-weight: 800; color: white; line-height: 1.1;">Everything You Need to <span style="color: #e85c5c;">Nail Your Low End.</span></h2>
      </div>

      <!-- Option C -->
      <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 3rem; margin-bottom: 3rem; text-align: center;">
        <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 1rem;">Option C — Question Hook</p>
        <h2 style="font-size: 3rem; font-weight: 800; color: white; line-height: 1.1;">Ready to Make Your Mixes <span style="color: #e85c5c;">Hit Hard?</span></h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 1.1rem; margin-top: 0.75rem;">Join 400+ producers who already did.</p>
      </div>

      <!-- Option D -->
      <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 3rem; margin-bottom: 3rem; text-align: center;">
        <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 1rem;">Option D — Bold & Simple</p>
        <div style="width: 60px; height: 3px; background: #e85c5c; margin: 0 auto 1.5rem;"></div>
        <h2 style="font-size: 3.5rem; font-weight: 800; color: white; line-height: 1.1;">Stop Guessing.<br><span style="color: #e85c5c;">Start Mastering.</span></h2>
        <div style="width: 60px; height: 3px; background: #e85c5c; margin: 1.5rem auto 0;"></div>
      </div>

    </div>
  </section>
</BaseLayout>
