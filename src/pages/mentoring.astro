---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedGradient from '../components/AnimatedGradient.astro';
import HeroCentered from '../components/HeroCentered.astro';
import SplitSection from '../components/SplitSection.astro';
import FullWidthImage from '../components/FullWidthImage.astro';
import BackgroundQuote from '../components/BackgroundQuote.astro';
import TestimonialCarousel from '../components/TestimonialCarousel.astro';
import CenteredHeadline from '../components/CenteredHeadline.astro';
import OutcomeCards from '../components/OutcomeCards.astro';
import MarqueeBanner from '../components/MarqueeBanner.astro';
import PricingDuo from '../components/PricingDuo.astro';
import TabbedTestimonials from '../components/TabbedTestimonials.astro';
import FAQ from '../components/FAQ.astro';
import {
  testimonials,
  featureCards,
  outcomeCards,
  pricingPlans,
  alumniTestimonials,
  faqItems,
} from '../data/mentoring';
---

<BaseLayout
  title="Mentoring - SLATIN Academy"
  description="Build a Profitable Music Career on Your Own Terms. Revamp your Mixing and Mastering Skills in Record Time with SLATIN's Mentoring Program."
>
  <!-- 1. Hero -->
  <div class="section-dark relative">
    <div class="absolute inset-0 z-0" style="width: 100%; height: 100%; -webkit-mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%); mask-image: linear-gradient(to bottom, black 0%, black 40%, transparent 65%);">
      <AnimatedGradient color1="#DD3333" color2="#1a0000" speed={1300} blendingMode="linear" />
    </div>
    <HeroCentered
      title="Build a Profitable Music Career on Your Own Terms"
      subtitle='Revamp your Mixing and Mastering Skills in Record Time 🧨'
      ctaText="START TODAY"
      ctaHref="#getaccess"
      subCtaText="Weekly Calls + Daily Feedback + Pro Community"
      avatars={[
        "/images/mentoring/circle-auriga.jpg",
        "/images/mentoring/circle-krumel.jpg",
        "/images/mentoring/circle-65649546.jpg",
        "/images/mentoring/circle-screenshot.jpg",
        "/images/mentoring/circle-nicolas.jpg",
      ]}
    />
  </div>

  <!-- 2. Intro/Bio -->
  <SplitSection
    variant="dark"
    imagePosition="left"
    imageSrc="/images/mentoring/headshot.jpg"
    imageAlt="Ruslan Slatin"
    imageClass="rounded-full"
  >
    <h2 class="text-2xl md:text-3xl font-semibold mb-6 leading-snug">My name is Ruslan, and I am an Award-Winning Music Producer and Engineer.</h2>
    <p class="text-white/70 text-base leading-relaxed" style="max-width: 450px;">
      Music has been my passion since I was young, and I've worked hard to turn it into a thriving career. With +15 years of experience, I'm excited to share my knowledge and guide you on your own path to success.
    </p>
  </SplitSection>

  <!-- 3. Logos bar -->
  <section class="section-dark py-0 overflow-hidden">
    <div class="px-[5%] md:px-[5%] lg:px-[5%]">
      <img
        src="/images/mentoring/logos-white.png"
        alt="Client logos"
        class="w-full md:w-[70%] mx-auto object-contain"
        loading="lazy"
      />
    </div>
  </section>

  <!-- 4. Background quote -->
  <BackgroundQuote
    backgroundImage="/images/mentoring/studio-bg.jpg"
    quote='Unlock your <strong>full potential</strong> and accelerate your growth by joining my <strong>Mentoring Program.</strong>'
  />

  <!-- 5. Testimonial carousel -->
  <TestimonialCarousel testimonials={testimonials} />

  <!-- 6. "What's Included?" title -->
  <section class="section-dark px-6 pt-4 pb-4 md:px-[5%] md:pt-20 md:pb-10 lg:px-[10%]">
    <div class="container-content text-center max-w-5xl mx-auto reveal">
      <h2 class="text-5xl md:text-heading">
        <em><strong><span class="squiggle-basic">What's Included?</span></strong></em>
      </h2>
    </div>
  </section>

  <!-- 7. Feature cards (2x2 grid — matches WP layout) -->
  <section class="section-dark px-[2%] pt-4 pb-4 md:pt-6 md:pb-8">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {featureCards.map((card) => (
          <div class="included-card rounded-2xl p-[2%] text-center reveal">
            <img
              src={card.iconSrc}
              alt=""
              class="w-full aspect-video object-cover rounded-xl mb-4"
              loading="lazy"
            />
            <h3 class="included-title" set:html={card.title} />
            <p class="text-white/50 text-xs md:text-sm mt-1" style="max-width: 550px; margin: 0 auto;">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .included-card {
      transition: background-color 0.35s ease;
    }
    .included-card:hover {
      background-color: #1e0000;
    }
    .included-title {
      font-size: clamp(1.2rem, 1.8vw, 1.5rem);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
  </style>

  <!-- 8. "+++ Extras" list -->
  <section class="section-dark px-6 py-2 md:px-[5%] md:py-3 lg:px-[10%] text-center">
    <div class="container-content max-w-3xl mx-auto reveal">
      <h2 class="text-4xl md:text-5xl font-bold gradient-text-red mb-5">+++</h2>
      <p class="text-white/60 text-base leading-loose">
        Exclusive access to insider information.<br />
        Special Music Industry Guests.<br />
        Networking and building community with like-minded individuals.<br />
        An extensive selection of the best Samples, Presets, and Books.<br />
        Email Templates for reaching out to Labels, Managers, and Promoters.<br />
        <a href="/fusion" class="text-accent-red hover:underline">FUSION</a> &ndash; Valhalla VintageVerb Reverb Pack &ndash; for free.<br />
        And much more&hellip;
      </p>
    </div>
  </section>

  <!-- 9. Key Outcomes -->
  <OutcomeCards
    sectionTitle='Key <em><span class="squiggle-basic">Outcomes</span></em>'
    cards={outcomeCards}
  />

  <!-- 10. "Start Today" marquee + registration CTA -->
  <MarqueeBanner
    text="Start Today"
    subtitle="Public Registration - Open Now! 🧨"
    id="getaccess"
  />

  <!-- 11. Pricing cards -->
  <PricingDuo plans={pricingPlans} />

  <!-- 12. Alumni feedback (tabbed) -->
  <TabbedTestimonials
    title='Alumni <em><span class="squiggle-basic">Feedback</span></em>'
    alumni={alumniTestimonials}
  />

  <!-- 13. FAQ -->
  <FAQ items={faqItems} />
</BaseLayout>
